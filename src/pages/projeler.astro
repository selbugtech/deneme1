---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import { CANONICAL_BASE } from '../config';
import { projects } from '../data/projects';

const leftProjects = projects.filter((_, i) => i % 2 === 0);
const rightProjects = projects.filter((_, i) => i % 2 === 1);
---

<Layout
  title="Projelerimiz — İstanbul İç Mimarlık"
  description="Master İç Mimarlık'ın İstanbul'da tamamladığı 150+ ev, villa, mağaza ve ofis yenileme projesi. Anahtar teslim çalışmalarımızı inceleyin."
  canonicalUrl={`${CANONICAL_BASE}/projeler`}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": `${CANONICAL_BASE}/` },
      { "@type": "ListItem", "position": 2, "name": "Projeler", "item": `${CANONICAL_BASE}/projeler` }
    ]
  }}
>
  <Header />

  <main class="pt-24 bg-charcoal min-h-screen">

    <div class="max-w-6xl mx-auto px-6 py-16">
      <div class="flex items-center gap-3 mb-2 reveal">
        <a href="/" class="text-white/40 hover:text-gold text-sm tracking-wide transition-colors flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          Ana Sayfa
        </a>
        <span class="text-white/20">/</span>
        <span class="text-white/40 text-sm tracking-wide">Projeler</span>
      </div>

      <div class="mt-6 reveal">
        <div class="flex items-center gap-3 mb-4">
          <span class="w-8 h-px bg-gold"></span>
          <span class="text-xs tracking-[0.3em] uppercase text-gold font-medium">Tüm Projelerimiz</span>
        </div>
        <h1 class="font-display text-4xl md:text-5xl font-bold text-white max-w-lg leading-tight">
          Tamamlanan<br />Çalışmalarımız
        </h1>
        <p class="text-white/50 mt-4 max-w-md leading-relaxed">
          150'den fazla tamamlanan proje ile İstanbul'un güvenilir iç mimarlık firması. Ev yenileme, villa, mağaza ve ofis projelerimizi inceleyin.
        </p>
      </div>
    </div>

    <div class="max-w-6xl mx-auto px-6 pb-24">
      <div class="grid md:grid-cols-2 gap-8 md:gap-10">
        <div class="flex flex-col gap-10 md:gap-16">
          {leftProjects.map((p, i) => (
            <a
              href={`/projeler/${p.slug}`}
              class={`relative block group overflow-hidden reveal reveal-d${(i % 3) + 1}`}
            >
              <img
                src={p.heroImage}
                srcset={p.heroSrcset}
                sizes="(min-width:768px) 50vw, 100vw"
                alt={p.title}
                loading="lazy"
                decoding="async"
                class="w-full aspect-[5/3] object-cover transition-transform duration-500 group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-gradient-to-r from-charcoal/70 via-charcoal/20 to-transparent pointer-events-none"></div>
              <div class="absolute top-6 left-6 right-6">
                <span class="text-[10px] tracking-[0.3em] uppercase text-gold font-medium">{p.category}</span>
                <h3 class="font-display text-2xl md:text-3xl font-bold text-white uppercase mt-2 leading-tight">{p.title}</h3>
                <span class="block w-12 h-px bg-gold mt-3"></span>
              </div>
            </a>
          ))}
        </div>

        <div class="flex flex-col gap-10 md:gap-16 md:mt-32">
          {rightProjects.map((p, i) => (
            <a
              href={`/projeler/${p.slug}`}
              class={`relative block group overflow-hidden reveal reveal-d${(i % 3) + 1}`}
            >
              <img
                src={p.heroImage}
                srcset={p.heroSrcset}
                sizes="(min-width:768px) 50vw, 100vw"
                alt={p.title}
                loading="lazy"
                decoding="async"
                class="w-full aspect-[5/3] object-cover transition-transform duration-500 group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-gradient-to-r from-charcoal/70 via-charcoal/20 to-transparent pointer-events-none"></div>
              <div class="absolute top-6 left-6 right-6">
                <span class="text-[10px] tracking-[0.3em] uppercase text-gold font-medium">{p.category}</span>
                <h3 class="font-display text-2xl md:text-3xl font-bold text-white uppercase mt-2 leading-tight">{p.title}</h3>
                <span class="block w-12 h-px bg-gold mt-3"></span>
              </div>
            </a>
          ))}
        </div>
      </div>

      <div class="mt-16 text-center reveal">
        <p class="text-white/40 text-sm mb-6 tracking-wide">Projenizi hayata geçirmek için iletişime geçin</p>
        <a
          href="https://wa.me/905330391565?text=Merhaba%2C%20projeleriniz%20hakk%C4%B1nda%20bilgi%20almak%20istiyorum."
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 bg-gold text-charcoal px-10 py-4 text-sm font-semibold tracking-wide hover:bg-[#B8965A] transition-colors duration-200"
        >
          Ücretsiz Keşif Randevusu Al
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>

  </main>

  <Footer />
  <WhatsAppFloat />
</Layout>
