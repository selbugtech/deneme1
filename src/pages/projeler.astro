---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import { CANONICAL_BASE } from '../config';
import { optimizedImage } from '../lib/cloudinary';

const projects = [
  { slug: 'beyoglu-galata', title: 'Beyoğlu Galata Daire', category: 'Anahtar Teslim Ev Yenileme', size: 'large', year: '2023', image: optimizedImage('/images/beyoglu galata daire/aakapak.jpg') },
  { slug: 'beykoz-pasabahce', title: 'Beykoz Paşabahçe Villa', category: 'Villa Yenileme', size: 'small', year: '2022', image: optimizedImage('/images/beykoz pasabahce villa/aakapak.HEIC') },
  { slug: 'caddebostan', title: 'Caddebostan Daire', category: 'Anahtar Teslim Ev Yenileme', size: 'small', year: '2022', image: optimizedImage('/images/caddebostan daire/aakapak.jpg') },
  { slug: 'mecidiyekoy', title: 'Mecidiyeköy Daire', category: 'Anahtar Teslim Ev Yenileme', size: 'small', year: '2024', image: optimizedImage('/images/mecidiyeköy daire/aakapak.HEIC') },
  { slug: 'artas-ofis', title: 'Artaş Ofis', category: 'Ofis Yenileme', size: 'small', year: '2024', image: optimizedImage('/images/Artaş Ofis/aakapak.HEIC') },
  { slug: 'artas-ofis-2', title: 'Artaş Ofis 2', category: 'Ofis Yenileme', size: 'small', year: '2023', image: optimizedImage('/images/artasOfis 2/aakapak.HEIC') },
  { slug: 'tepekent', title: 'Tepekent Villa', category: 'Anahtar Teslim Ev Yenileme', size: 'large', year: '2024', image: optimizedImage('/images/tepekent villa/aakapak.HEIC') },
  { slug: 'kozyatagi-banyo', title: 'Kozyatağı Banyo', category: 'Kısmi Yenileme', size: 'small', year: '2022', image: optimizedImage('/images/kozyatağı banyo/aakapak.JPG') },
  { slug: 'zeytinburnu', title: 'Zeytinburnu Daire', category: 'Anahtar Teslim Ev Yenileme', size: 'small', year: '2023', image: optimizedImage('/images/zeytinburnu daire/aakapak.jpg') },
];
---

<Layout
  title="Projelerimiz — İstanbul İç Mimarlık"
  description="Master İç Mimarlık'ın İstanbul'da tamamladığı 150+ ev, villa, mağaza ve ofis yenileme projesi. Anahtar teslim çalışmalarımızı inceleyin."
  canonicalUrl={`${CANONICAL_BASE}/projeler`}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": `${CANONICAL_BASE}/` },
      { "@type": "ListItem", "position": 2, "name": "Projeler", "item": `${CANONICAL_BASE}/projeler` }
    ]
  }}
>
  <Header />

  <main class="pt-24 bg-charcoal min-h-screen">

    <!-- Page header -->
    <div class="max-w-6xl mx-auto px-6 py-16">
      <div class="flex items-center gap-3 mb-2 reveal">
        <a href="/" class="text-white/40 hover:text-gold text-sm tracking-wide transition-colors flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          Ana Sayfa
        </a>
        <span class="text-white/20">/</span>
        <span class="text-white/40 text-sm tracking-wide">Projeler</span>
      </div>

      <div class="mt-6 reveal">
        <div class="flex items-center gap-3 mb-4">
          <span class="w-8 h-px bg-gold"></span>
          <span class="text-xs tracking-[0.3em] uppercase text-gold font-medium">Tüm Projelerimiz</span>
        </div>
        <h1 class="font-display text-4xl md:text-5xl font-bold text-white max-w-lg leading-tight">
          Tamamlanan<br />Çalışmalarımız
        </h1>
        <p class="text-white/50 mt-4 max-w-md leading-relaxed">
          150'den fazla tamamlanan proje ile İstanbul'un güvenilir iç mimarlık firması. Ev yenileme, villa, mağaza ve ofis projelerimizi inceleyin.
        </p>
      </div>
    </div>

    <!-- Projects grid -->
    <div class="max-w-6xl mx-auto px-6 pb-24">
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
        {projects.map((p, i) => (
          <a
            href={`/projeler/${p.slug}`}
            class={`relative group overflow-hidden reveal reveal-d${(i % 3) + 1} ${p.size === 'large' ? 'row-span-2' : ''}`}
          >
            <img
              src={p.image}
              alt={p.title}
              loading="lazy"
              decoding="async"
              class={`w-full object-cover object-center transition-transform duration-500 group-hover:scale-105 ${p.size === 'large' ? 'h-[400px] md:h-[480px]' : 'h-[190px] md:h-[230px]'}`}
            />

            <!-- Overlay on hover -->
            <div class="absolute inset-0 bg-charcoal/80 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col items-start justify-end p-5">
              <span class="text-[10px] tracking-[0.25em] uppercase text-gold/70 mb-1">{p.year}</span>
              <span class="text-[10px] tracking-[0.25em] uppercase text-gold mb-2">{p.category}</span>
              <h3 class="font-display text-white text-lg font-semibold">{p.title}</h3>
              <span class="mt-2 inline-flex items-center gap-1.5 text-white/60 text-xs">
                Projeyi İncele
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </span>
            </div>

            <!-- Always-visible label (mobile) -->
            <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-charcoal/90 to-transparent p-4 md:hidden">
              <p class="text-[10px] tracking-widest uppercase text-gold">{p.category}</p>
              <p class="font-display text-white text-sm font-semibold">{p.title}</p>
            </div>
          </a>
        ))}
      </div>

      <!-- CTA -->
      <div class="mt-16 text-center reveal">
        <p class="text-white/40 text-sm mb-6 tracking-wide">Projenizi hayata geçirmek için iletişime geçin</p>
        <a
          href="https://wa.me/905330391565?text=Merhaba%2C%20projeleriniz%20hakk%C4%B1nda%20bilgi%20almak%20istiyorum."
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 bg-gold text-charcoal px-10 py-4 text-sm font-semibold tracking-wide hover:bg-[#B8965A] transition-colors duration-200"
        >
          Ücretsiz Keşif Randevusu Al
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>

  </main>

  <Footer />
  <WhatsAppFloat />
</Layout>
