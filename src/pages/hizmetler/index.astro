---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import { CANONICAL_BASE } from '../../config';

const services = [
  {
    title: 'Anahtar Teslim Ev Yenileme',
    slug: 'anahtar-teslim-ev-yenileme',
    desc: 'Tasarımdan uygulamaya tüm süreci biz yönetiyoruz. Siz anahtarı teslim alırken eviniz hazır.',
    keyword: 'En çok tercih edilen',
  },
  {
    title: 'Villa Yenileme',
    slug: 'villa-yenileme',
    desc: 'Villalarınızı lüks, konforlu ve kişisel tarzınızı yansıtan yaşam mekanlarına dönüştürüyoruz.',
    keyword: 'Zekeriyaköy · Acıbadem',
  },
  {
    title: 'Mağaza Yenileme',
    slug: 'magaza-yenileme',
    desc: 'Markanızı güçlendiren, müşteri deneyimini artıran çarpıcı ticari mekanlar tasarlıyoruz.',
    keyword: 'Nişantaşı · Levent',
  },
  {
    title: 'Ofis Yenileme',
    slug: 'ofis-yenileme',
    desc: 'Ekibinizin verimliliğini ve motivasyonunu artıran modern, estetik çalışma ortamları.',
    keyword: 'Kurumsal mekan',
  },
  {
    title: 'İç Mimarlık Danışmanlığı',
    slug: 'ic-mimarlik-danismanligi',
    desc: 'Projeniz için profesyonel görüş, malzeme seçimi ve uygulama sürecinde uzman rehberlik.',
    keyword: 'Esnek paketler',
  },
  {
    title: '3D Tasarım & Proje',
    slug: '3d-tasarim',
    desc: 'Uygulamaya başlamadan önce mekanınızı gerçekçi 3D görseller ile deneyimleyin.',
    keyword: 'Tüm projelerde standart',
  },
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": `${CANONICAL_BASE}/` },
    { "@type": "ListItem", "position": 2, "name": "Hizmetler", "item": `${CANONICAL_BASE}/hizmetler` }
  ]
};
---

<Layout
  title="Hizmetlerimiz | İç Mimarlık ve Ev Yenileme İstanbul | Master"
  description="Master İç Mimarlık'ın İstanbul'daki tüm hizmetleri: Anahtar teslim ev yenileme, villa yenileme, mağaza yenileme, ofis yenileme, danışmanlık ve 3D tasarım."
  canonicalUrl={`${CANONICAL_BASE}/hizmetler`}
  structuredData={breadcrumbSchema}
>
  <Header />

  <main class="pt-24 bg-warm-white min-h-screen">

    <div class="max-w-6xl mx-auto px-6 py-16">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 mb-8 text-sm" aria-label="Breadcrumb">
        <a href={`${CANONICAL_BASE}/`} class="text-muted hover:text-gold transition-colors">Ana Sayfa</a>
        <span class="text-border">/</span>
        <span class="text-charcoal">Hizmetler</span>
      </nav>

      <div class="flex items-center gap-3 mb-4">
        <span class="w-8 h-px bg-gold"></span>
        <span class="text-xs tracking-[0.3em] uppercase text-gold font-medium">Hizmetlerimiz</span>
      </div>
      <h1 class="font-display text-4xl md:text-5xl font-bold text-charcoal leading-tight mb-4">
        İç Mimarlık ve<br />
        <em class="not-italic text-gold">Ev Yenileme</em> Hizmetleri
      </h1>
      <p class="text-muted leading-relaxed max-w-xl mb-16">
        İstanbul'da anahtar teslim ev yenilemeden villa tasarımına, mağaza düzenlemesinden ofis yenilemeye kadar tüm iç mimarlık hizmetleri tek çatı altında.
      </p>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((s) => (
          <a href={`${CANONICAL_BASE}/hizmetler/${s.slug}`} class="group border border-border p-7 hover:border-gold transition-colors duration-200">
            <span class="text-[10px] tracking-[0.25em] uppercase text-gold/70 mb-3 block">{s.keyword}</span>
            <h2 class="font-display text-xl font-bold text-charcoal mb-3 group-hover:text-gold transition-colors">{s.title}</h2>
            <p class="text-muted text-sm leading-relaxed mb-4">{s.desc}</p>
            <span class="text-xs text-gold inline-flex items-center gap-1.5">
              Detaylı Bilgi
              <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </span>
          </a>
        ))}
      </div>

      <div class="mt-16 p-8 bg-charcoal text-center">
        <h2 class="font-display text-2xl font-bold text-white mb-2">Projenizi Konuşalım</h2>
        <p class="text-white/50 text-sm mb-6">Ücretsiz keşif için WhatsApp veya telefon.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="https://wa.me/905330391565?text=Merhaba%2C%20hizmetleriniz%20hakk%C4%B1nda%20bilgi%20almak%20istiyorum."
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 bg-[#25D366] text-white px-8 py-3 text-sm font-semibold hover:bg-[#1EBD5A] transition-colors"
          >
            WhatsApp'tan Yaz
          </a>
          <a href="tel:+905330391565" class="inline-flex items-center justify-center bg-gold text-charcoal px-8 py-3 text-sm font-semibold hover:bg-[#B8965A] transition-colors">
            0533 039 15 65
          </a>
        </div>
      </div>

    </div>
  </main>

  <Footer />
  <WhatsAppFloat />
</Layout>
