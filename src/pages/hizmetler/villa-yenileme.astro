---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import { CANONICAL_BASE } from '../../config';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Villa Yenileme",
  "name": "Villa Yenileme İstanbul",
  "description": "İstanbul'da lüks villa yenileme ve iç mimarlık hizmetleri. Zekeriyaköy, Acıbadem ve tüm İstanbul'da villa projesi uygulama deneyimi.",
  "provider": { "@type": "Organization", "@id": `${CANONICAL_BASE}/#organization`, "name": "Master İç Mimarlık" },
  "areaServed": [
    { "@type": "City", "name": "İstanbul" },
    { "@type": "AdministrativeArea", "name": "Zekeriyaköy" },
    { "@type": "AdministrativeArea", "name": "Acıbadem" },
    { "@type": "AdministrativeArea", "name": "Sarıyer" }
  ],
  "url": `${CANONICAL_BASE}/hizmetler/villa-yenileme`,
  "offers": { "@type": "Offer", "priceCurrency": "TRY", "description": "Villa büyüklüğü ve kapsamına göre özel fiyatlandırma", "availability": "https://schema.org/InStock" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Villa yenileme ne kadar sürer?", "acceptedAnswer": { "@type": "Answer", "text": "Villanın büyüklüğü ve iş kapsamına göre 8–20 hafta arasında tamamlanmaktadır. Bahçe ve dış cephe dahil büyük projelerde süre uzayabilir." } },
    { "@type": "Question", "name": "Villa yenileme maliyeti ne kadar?", "acceptedAnswer": { "@type": "Answer", "text": "İstanbul'da villa yenileme maliyeti villanın büyüklüğü, seçilen malzeme kalitesi ve yapılacak işlerin kapsamına göre belirlenir. Metrekare başına ortalama 4.000–12.000 ₺ arasında değişmektedir. Kesin fiyat için ücretsiz keşif randevusu alabilirsiniz." } },
    { "@type": "Question", "name": "Dış cephe ve bahçe düzenlemesi de yapıyor musunuz?", "acceptedAnswer": { "@type": "Answer", "text": "Evet. Villa projelerinde dış cephe mantolama, bahçe peyzajı, havuz çevresi ve aydınlatma gibi dış mekan uygulamalarını da koordine ediyoruz." } },
    { "@type": "Question", "name": "Zekeriyaköy ve Beykoz'a hizmet veriyor musunuz?", "acceptedAnswer": { "@type": "Answer", "text": "Evet. Zekeriyaköy, Beykoz, Acıbadem, Sarıyer ve İstanbul'un tüm villa bölgelerine hizmet veriyoruz." } }
  ]
};
---

<ServiceLayout
  title="Villa Yenileme İstanbul — Lüks Villa İç Mimarlık | Master İç Mimarlık"
  description="İstanbul'da lüks villa yenileme ve iç mimarlık. Zekeriyaköy, Acıbadem, Sarıyer başta olmak üzere tüm İstanbul villa bölgelerinde anahtar teslim hizmet. Ücretsiz keşif: 0533 039 15 65"
  canonicalUrl={`${CANONICAL_BASE}/hizmetler/villa-yenileme`}
  h1="İstanbul'da Villa Yenileme ve İç Mimarlık"
  eyebrow="Hizmet"
  lead="Villalarınızı lüks, konforlu ve kişisel tarzınızı yansıtan yaşam mekanlarına dönüştürüyoruz. Zekeriyaköy'den Acıbadem'e İstanbul'un prestijli bölgelerinde deneyimli ekibimizle yanınızdayız."
  breadcrumb={[
    { label: "Ana Sayfa", href: `${CANONICAL_BASE}/` },
    { label: "Hizmetler", href: `${CANONICAL_BASE}/hizmetler` },
    { label: "Villa Yenileme" }
  ]}
  heroImage="/deneme1/images/hero-villa-sea.jpg"
  ogImage={`${CANONICAL_BASE}/images/hero-villa-sea.jpg`}
  structuredData={[serviceSchema, faqSchema]}
>

  <!-- Scope -->
  <div class="grid md:grid-cols-2 gap-12 py-12 border-b border-border">
    <div>
      <h2 class="font-display text-3xl font-bold text-charcoal mb-4">Villa Yenileme Hizmeti</h2>
      <p class="text-muted leading-relaxed mb-4">
        Villa yenileme, daire yenilemesinden farklı olarak çok daha geniş alanlı, iç ve dış mekan düzenlemesini, bahçe tasarımını ve yapısal düzenlemeleri de kapsayabilen kapsamlı bir süreçtir.
      </p>
      <p class="text-muted leading-relaxed mb-4">
        Master İç Mimarlık olarak 8+ yıllık deneyimimizle İstanbul'da onlarca villa projesini başarıyla tamamladık. Zekeriyaköy, Acıbadem, Sarıyer ve Beşiktaş'taki projelerimiz referans portfolyomuzun önemli bir parçasını oluşturmaktadır.
      </p>
      <p class="text-muted leading-relaxed">
        Her villa projesi özgündür. Sahibinin kişisel zevki, ailenin yaşam alışkanlıkları ve villanın mimarisi doğrultusunda özelleştirilmiş bir tasarım sunuyoruz.
      </p>
    </div>
    <div>
      <h3 class="font-semibold text-charcoal mb-4 text-xs uppercase tracking-wider">Villa Projelerinde Kapsamımız</h3>
      <ul class="space-y-3">
        {[
          'Tüm iç mekanların yenilenmesi',
          'Mutfak ve banyo yenileme',
          'Zemin kaplamaları (parke, mermer, seramik)',
          'Özel mobilya ve built-in çözümler',
          'Aydınlatma tasarımı ve uygulaması',
          'Dış cephe ve bahçe koordinasyonu',
          'Havuz çevresi düzenlemesi',
          'Akıllı ev sistemleri entegrasyonu',
          'Gerçekçi 3D görselleştirme hizmeti',
        ].map(item => (
          <li class="flex items-start gap-3 text-sm text-muted">
            <span class="w-4 h-4 mt-0.5 shrink-0 bg-gold/15 rounded-full flex items-center justify-center">
              <svg class="w-2.5 h-2.5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Gallery -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Referans Projeler</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-4">
      {[
        { src: '/deneme1/images/sariyer-villa5.jpg',       title: 'Sarıyer Villa',      detail: '380 m² · Komple yenileme · 2024' },
        { src: '/deneme1/images/hero-villa-forest.png',    title: 'Zekeriyaköy Villa',  detail: '450 m² · İç mekan + bahçe · 2024' },
        { src: '/deneme1/images/269796335_287998196622038_3115674097994505357_n.jpg', title: 'Acıbadem Villa', detail: '320 m² · Lüks yenileme · 2023' },
      ].map(p => (
        <div class="group">
          <div class="overflow-hidden mb-3">
            <img src={p.src} alt={p.title} class="w-full h-52 object-cover group-hover:scale-105 transition-transform duration-500" />
          </div>
          <h3 class="font-semibold text-charcoal text-sm">{p.title}</h3>
          <p class="text-muted text-xs mt-0.5">{p.detail}</p>
        </div>
      ))}
    </div>
    <div class="mt-6">
      <a href={`${CANONICAL_BASE}/projeler`} class="text-sm text-gold hover:underline inline-flex items-center gap-2">
        Tüm projelerimizi görün
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- Pricing & Duration -->
  <div class="grid md:grid-cols-2 gap-12 py-12 border-b border-border">
    <div>
      <h2 class="font-display text-2xl font-bold text-charcoal mb-4">Süre ve Maliyet</h2>
      <p class="text-muted leading-relaxed mb-4">
        Villa yenileme projeleri kapsamına göre <strong class="text-charcoal">8–20 hafta</strong> arasında tamamlanmaktadır. Yapısal değişiklik içeren projeler bu süreyi uzatabilir.
      </p>
      <ul class="space-y-2 mb-4">
        {['Orta segment iç mekan (250 m²): 1.5M – 3M ₺', 'Üst segment tam yenileme (400 m²): 4M – 8M ₺', 'Lüks segment anahtar teslim (500 m²+): 8M ₺ ve üzeri'].map(item => (
          <li class="flex items-start gap-2 text-sm text-muted"><span class="text-gold mt-0.5">—</span>{item}</li>
        ))}
      </ul>
      <p class="text-muted text-sm">Fiyatlar yalnızca işçilik ve temel malzemeleri kapsar; özel mobilya ve akıllı ev sistemleri ayrıca değerlendirilir.</p>
    </div>
    <div>
      <h2 class="font-display text-2xl font-bold text-charcoal mb-4">Neden Master İç Mimarlık?</h2>
      <div class="space-y-4">
        {[
          { title: 'Deneyim', desc: '8+ yıl, 150+ tamamlanan proje. Villa projelerinde özel uzmanlaşma.' },
          { title: 'Tek Muhatap', desc: 'Tasarımdan uygulamaya, bahçeden dış cepheye kadar tüm süreç.' },
          { title: 'Şeffaf Sözleşme', desc: 'Kesin bütçe ve takvim taahhüdü. Gizli maliyet yok.' },
        ].map(item => (
          <div class="flex gap-4">
            <span class="w-1 bg-gold shrink-0 mt-1"></span>
            <div>
              <h3 class="font-semibold text-charcoal text-sm">{item.title}</h3>
              <p class="text-muted text-xs leading-relaxed mt-0.5">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- FAQ -->
  <div class="py-12">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Sık Sorulan Sorular</h2>
    </div>
    <div class="divide-y divide-border">
      {[
        { q: 'Villa yenileme ne kadar sürer?', a: 'Villanın büyüklüğü ve kapsamına göre 8–20 hafta arasında tamamlanmaktadır. Bahçe ve dış cephe dahil büyük projelerde süre uzayabilir.' },
        { q: 'Villa yenileme maliyeti ne kadar?', a: 'İstanbul\'da villa yenileme metrekare başına ortalama 4.000–12.000 ₺ arasında değişmektedir. Kesin fiyat için ücretsiz keşif randevusu alabilirsiniz.' },
        { q: 'Dış cephe ve bahçe düzenlemesi de yapıyor musunuz?', a: 'Evet. Villa projelerinde dış cephe mantolama, bahçe peyzajı, havuz çevresi ve aydınlatma gibi dış mekan uygulamalarını da koordine ediyoruz.' },
        { q: 'Zekeriyaköy ve Beykoz\'a hizmet veriyor musunuz?', a: 'Evet. Zekeriyaköy, Beykoz, Acıbadem, Sarıyer ve İstanbul\'un tüm villa bölgelerine hizmet veriyoruz.' },
      ].map((faq, i) => (
        <details class="group py-5" open={i === 0}>
          <summary class="flex items-start justify-between cursor-pointer list-none gap-4">
            <h3 class="font-semibold text-charcoal text-sm md:text-base group-open:text-gold transition-colors">{faq.q}</h3>
            <svg class="shrink-0 w-5 h-5 text-gold mt-0.5 group-open:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <p class="mt-3 text-muted text-sm leading-relaxed pr-8">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>

</ServiceLayout>
