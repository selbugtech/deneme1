---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import { CANONICAL_BASE } from '../../config';
import { optimizedImage } from '../../lib/cloudinary';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "İç Mimar Danışmanlık Hizmetleri",
  "name": "İç Mimar Danışmanlık Hizmetleri | Master İç Mimarlık",
  "description": "İstanbul'da iç mimar danışmanlık hizmetleri, iç mimar danışmanlık ücreti ve fiyatları hakkında şeffaf bilgi. Tek oturumdan süreç boyunca rehberliğe esnek paketler.",
  "provider": { "@type": "Organization", "@id": `${CANONICAL_BASE}/#organization`, "name": "Master İç Mimarlık" },
  "areaServed": { "@type": "City", "name": "İstanbul" },
  "url": `${CANONICAL_BASE}/hizmetler/ic-mimarlik-danismanligi`,
  "offers": { "@type": "Offer", "priceCurrency": "TRY", "description": "İlk görüşme ücretsiz — iç mimar danışmanlık fiyatları projeye özel belirlenir", "availability": "https://schema.org/InStock" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "İç mimar danışmanlık fiyatlandırması nasıl belirlenir?", "acceptedAnswer": { "@type": "Answer", "text": "İç mimar danışmanlık fiyatlandırması; hizmet kapsamı, mekanın büyüklüğü, seçilen paket türü (tek oturum / proje paketi / süreç danışmanlığı) ve talep edilen ziyaret sayısına göre şekillenir. Master İç Mimarlık'ta ilk görüşme ücretsizdir; projenize özel rekabetçi fiyatlandırma için iletişime geçin." } },
    { "@type": "Question", "name": "İç mimar danışmanlık fiyatları neye göre belirlenir?", "acceptedAnswer": { "@type": "Answer", "text": "İç mimar danışmanlık fiyatları; mekanın büyüklüğü, projenin kapsamı, istenen hizmet paketi (tek oturum / proje paketi / süreç danışmanlığı) ve mimarın deneyim düzeyine göre belirlenir." } },
    { "@type": "Question", "name": "İç mimar danışmanlık hizmetleri neler kapsar?", "acceptedAnswer": { "@type": "Answer", "text": "İç mimar danışmanlık hizmetleri; mekan analizi, renk paleti ve stil danışmanlığı, malzeme seçimi, mobilya yerleşim planı, uygulama sürecinde yerinde denetim, sözleşme ve fiyat değerlendirmesi ile teslim öncesi punch-list incelemesini kapsar." } },
    { "@type": "Question", "name": "Kendi müteahhidimle çalışırken iç mimar danışmanlığı alabilir miyim?", "acceptedAnswer": { "@type": "Answer", "text": "Evet. İç mimar danışmanlık hizmeti, kendi yüklenicilerinizle çalışıp tasarım ve malzeme kararlarında uzman görüşü almak isteyenler için özellikle uygundur." } },
    { "@type": "Question", "name": "Tek seferlik danışmanlık oturumu mümkün mü?", "acceptedAnswer": { "@type": "Answer", "text": "Evet. Tek seferlik danışmanlık oturumundan süreç boyunca rehberliğe kadar ihtiyacınıza özel esnek paketler sunuyoruz. Tek oturum yaklaşık 1–2 saat sürmektedir." } },
    { "@type": "Question", "name": "İç mimar danışmanlığı için nasıl başvurabilirim?", "acceptedAnswer": { "@type": "Answer", "text": "WhatsApp, telefon veya e-posta ile iletişime geçebilirsiniz. İlk görüşme ücretsizdir; projenizi değerlendirip size uygun paketi birlikte belirliyoruz." } }
  ]
};
---

<ServiceLayout
  title="İç Mimar Danışmanlık Hizmetleri — Fiyatlandırma & Hizmet Paketleri | Master İç Mimarlık"
  description="İstanbul'da iç mimar danışmanlık hizmetleri, danışmanlık ücreti ve fiyatları. Tek oturumdan süreç danışmanlığına esnek paketler. İlk görüşme ücretsiz. 0533 039 15 65"
  canonicalUrl={`${CANONICAL_BASE}/hizmetler/ic-mimarlik-danismanligi`}
  h1="İç Mimar Danışmanlık Hizmetleri ve Fiyatlandırma"
  eyebrow="İç Mimar Danışmanlığı"
  lead="İstanbul'da iç mimar danışmanlık hizmetleri, danışmanlık ücreti ve fiyatları hakkında şeffaf bilgi. 8 yılı aşkın deneyim ve 150'den fazla proje ile malzeme seçiminden uygulama denetimine uzman rehberlik sunuyoruz. İlk görüşme ücretsizdir."
  breadcrumb={[
    { label: "Ana Sayfa", href: "/" },
    { label: "Hizmetler", href: "/#hizmetler" },
    { label: "İç Mimarlık Danışmanlığı" }
  ]}
  heroImage={optimizedImage('/images/salon4.jpeg')}
  ogImage={optimizedImage('/images/salon4.jpeg')}
  structuredData={[serviceSchema, faqSchema]}
>

  <!-- Proje Görselleri -->
  <div class="w-full mb-12 grid grid-cols-1 md:grid-cols-3 gap-3">
    <img src={optimizedImage('/images/salon5.jpeg')} alt="İç mimarlık danışmanlığı — salon tasarımı" class="w-full h-64 object-cover" loading="lazy" decoding="async" />
    <img src={optimizedImage('/images/salon6.jpeg')} alt="İç mimarlık danışmanlığı — oturma odası" class="w-full h-64 object-cover" loading="lazy" decoding="async" />
    <img src={optimizedImage('/images/salon7.jpeg')} alt="İç mimarlık danışmanlığı — mekan tasarımı" class="w-full h-64 object-cover" loading="lazy" decoding="async" />
  </div>

  <!-- Scope -->
  <div class="grid md:grid-cols-2 gap-12 py-12 border-b border-border">
    <div>
      <h2 class="font-display text-3xl font-bold text-charcoal mb-4">İç Mimar Danışmanlık Hizmetleri Nedir?</h2>
      <p class="text-muted leading-relaxed mb-4">
        <strong>İç mimar danışmanlık hizmetleri</strong>, kendi yüklenicilerinizle veya ekibinizle çalışırken profesyonel perspektif almak isteyen ev ve iş yeri sahipleri için idealdir. Tüm proje yönetimini devralmak yerine belirli konularda uzman desteği alırsınız.
      </p>
      <p class="text-muted leading-relaxed mb-4">
        Malzeme seçiminde yanlış karar vermek, uzun vadede hem estetik hem mali kayıplara yol açar. <strong>İç mimar danışmanlığı</strong> ile bu riski minimize ediyor, bütçenizi koruyor ve projenizin doğru ilerlemesini güvence altına alıyoruz.
      </p>
      <p class="text-muted leading-relaxed">
        Tek seferlik danışmanlık oturumundan tadilat süreci boyunca rehberliğe kadar ihtiyacınıza özel esnek paketler sunuyoruz.
      </p>
    </div>
    <div>
      <h3 class="font-semibold text-charcoal mb-4 text-xs uppercase tracking-wider">İç Mimar Danışmanlık Hizmetleri Kapsamı</h3>
      <ul class="space-y-3">
        {[
          'Mekan analizi ve alan planlaması',
          'Renk paleti ve stil danışmanlığı',
          'Malzeme seçimi ve tedarikçi önerileri',
          'Mobilya yerleşim planı',
          'Uygulama sürecinde yerinde denetim',
          'Sözleşme ve fiyat değerlendirmesi',
          'Uygulamanın doğruluğunu kontrol',
          'Son teslim öncesi punch-list incelemesi',
        ].map(item => (
          <li class="flex items-start gap-3 text-sm text-muted">
            <span class="w-4 h-4 mt-0.5 shrink-0 bg-gold/15 rounded-full flex items-center justify-center">
              <svg class="w-2.5 h-2.5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Pricing Section -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-4">
      <span class="w-8 h-px bg-gold"></span>
      <span class="text-xs tracking-[0.3em] uppercase text-gold font-medium">Şeffaf Fiyatlandırma</span>
    </div>
    <h2 class="font-display text-3xl font-bold text-charcoal mb-3">İç Mimar Danışmanlık Fiyatlandırma Seçenekleri</h2>
    <p class="text-muted leading-relaxed mb-10 max-w-2xl">
      <strong>İç mimar danışmanlık fiyatlandırması</strong>; hizmet kapsamı, mekanın büyüklüğü ve istenen destek modeline göre şekillenir. İhtiyacınıza en uygun paketi birlikte belirliyor, projeye özel rekabetçi fiyatlandırma sunuyoruz.
    </p>
    <div class="grid md:grid-cols-3 gap-6 mb-8">
      {[
        {
          tag: 'Başlangıç',
          title: 'Tek Oturum Danışmanlık',
          price: 'Projeye özel fiyatlandırma',
          desc: 'Tek bir görüşmede mekan değerlendirmesi, malzeme ve renk önerileri ile yazılı özet rapor.',
          items: ['1–2 saatlik görüşme', 'Mekan değerlendirmesi', 'Malzeme ve renk önerileri', 'Yazılı özet rapor'],
        },
        {
          tag: 'Popüler',
          title: 'Proje Paketi',
          price: 'Projeye özel fiyatlandırma',
          desc: 'Konsept tasarım, malzeme seçim rehberi ve tedarikçi önerileri dahil kapsamlı danışmanlık.',
          items: ['Konsept tasarım', '3D taslak görseller', 'Malzeme seçim rehberi', 'Tedarikçi önerileri', 'E-posta desteği'],
        },
        {
          tag: 'Kapsamlı',
          title: 'Süreç Danışmanlığı',
          price: 'Projeye özel fiyatlandırma',
          desc: 'Tadilat boyunca yerinde denetim, sözleşme değerlendirmesi ve teslim öncesi kontrol dahil tam destek.',
          items: ['Tüm proje danışmanlığı', 'Yerinde denetim ziyaretleri', 'Teslim öncesi kontrol', 'Sözleşme değerlendirmesi', 'WhatsApp desteği'],
        },
      ].map(pkg => (
        <div class="border border-border p-6 flex flex-col">
          <p class="text-[10px] tracking-widest uppercase text-gold mb-2">{pkg.tag}</p>
          <h3 class="font-display font-bold text-charcoal text-lg mb-1">{pkg.title}</h3>
          <p class="text-gold font-semibold text-base mb-3">{pkg.price}</p>
          <p class="text-muted text-xs leading-relaxed mb-4">{pkg.desc}</p>
          <ul class="space-y-2 mt-auto">
            {pkg.items.map(item => (
              <li class="flex items-start gap-2 text-xs text-muted">
                <svg class="w-3 h-3 text-gold mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <div class="border border-gold/30 bg-gold/5 p-5 flex flex-col md:flex-row md:items-center gap-4">
      <svg class="w-6 h-6 text-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <p class="text-sm text-charcoal leading-relaxed">
        <strong>İlk görüşme ücretsizdir.</strong> Projenizi ve bütçenizi paylaşın; size en uygun <strong>iç mimar danışmanlık fiyatı</strong>nı şeffaf biçimde sunalım. Gizli ücret veya sürpriz fatura yoktur.
      </p>
    </div>
  </div>

  <!-- Fiyatı Etkileyen Faktörler -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">İç Mimar Danışmanlık Fiyatını Etkileyen Faktörler</h2>
    </div>
    <div class="grid md:grid-cols-2 gap-6">
      {[
        { title: 'Mekanın Büyüklüğü', desc: 'Daha büyük alanlarda değerlendirme ve denetim süresi uzar; bu durum danışmanlık ücretini doğrudan etkiler.' },
        { title: 'Hizmet Kapsamı', desc: 'Tek oturum ile süreç boyunca danışmanlık arasında ciddi bir fark vardır. Kapsam ne kadar genişse ücret o ölçüde artar.' },
        { title: 'Ziyaret Sayısı', desc: 'Yerinde denetim ziyaretleri ek ücrete tabidir. Ziyaret sayısı proje türüne ve tadilat süresine göre değişir.' },
        { title: 'Projenin Karmaşıklığı', desc: 'Yapısal değişiklik, teknik altyapı veya özel malzeme içeren projeler daha yoğun danışmanlık gerektirir.' },
        { title: 'Mimarin Deneyimi', desc: 'Ödüllü ya da uluslararası referanslı mimarların danışmanlık ücreti daha yüksektir. Portföy incelemesi bu konuda karar vermenizi kolaylaştırır.' },
        { title: 'Lokasyon', desc: 'İstanbul\'da Boğaz hattı, Nişantaşı veya Levent gibi prestijli bölgelerdeki projelerde ulaşım ve yerel maliyet farklılıkları fiyatı etkileyebilir.' },
      ].map(card => (
        <div class="border border-border p-5 flex gap-4">
          <span class="w-2 h-2 rounded-full bg-gold shrink-0 mt-2"></span>
          <div>
            <h3 class="font-semibold text-charcoal text-sm mb-1">{card.title}</h3>
            <p class="text-muted text-xs leading-relaxed">{card.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- When to choose -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-8">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">İç Mimar Danışmanlık Hizmeti Ne Zaman Tercih Edilmeli?</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {[
        { title: 'Kısmi Proje', desc: 'Sadece tek bir oda veya belirli bir alanı yenileyecekseniz ve tam kapsamlı iç mimar danışmanlık hizmeti almak istemiyorsanız.' },
        { title: 'Kendi Yüklenicin Var', desc: 'Bir müteahhit veya ustanızla çalışıyorsunuz; ancak tasarım ve malzeme kararlarında uzman görüşü istiyorsunuz.' },
        { title: 'İkinci Görüş', desc: 'Başka bir yerden aldığınız tasarım veya fiyat teklifi için bağımsız bir uzman değerlendirmesi istiyorsunuz.' },
        { title: 'Bütçe Yönetimi', desc: 'Malzeme ve hizmet tekliflerini değerlendirmek, gereksiz harcamaları önlemek ve bütçenizi korumak istiyorsunuz.' },
        { title: 'Tadilat Denetimi', desc: 'Uygulama sürecinin doğru ilerlediğinden emin olmak, standart dışı işçilikleri tespit etmek istiyorsunuz.' },
        { title: 'Yeni Konut / Ofis', desc: 'Yeni taşındığınız alanı döşemeden önce profesyonel bir yerleşim planı ve malzeme rehberliği almak istiyorsunuz.' },
      ].map(card => (
        <div class="border border-border p-6">
          <h3 class="font-semibold text-charcoal mb-2 text-sm">{card.title}</h3>
          <p class="text-muted text-xs leading-relaxed">{card.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- FAQ -->
  <div class="py-12">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Sık Sorulan Sorular</h2>
    </div>
    <div class="divide-y divide-border">
      {[
        { q: 'İç mimar danışmanlık fiyatlandırması nasıl belirlenir?', a: 'İç mimar danışmanlık fiyatlandırması; hizmet kapsamı, mekanın büyüklüğü ve seçilen paket türüne göre şekillenir. Tek oturum, proje paketi ve süreç danışmanlığı olmak üzere üç farklı fiyatlandırma modelimiz mevcuttur. Projenize özel rekabetçi fiyatlandırma için WhatsApp veya telefon ile iletişime geçebilirsiniz. Master İç Mimarlık\'ta ilk görüşme ücretsizdir.' },
        { q: 'İç mimar danışmanlık fiyatları neye göre belirlenir?', a: 'İç mimar danışmanlık fiyatları; mekanın büyüklüğü, projenin kapsamı, seçilen hizmet modeli (tek oturum / proje paketi / süreç danışmanlığı) ve yapılacak yerinde denetim ziyaretlerinin sayısına göre belirlenir.' },
        { q: 'İç mimar danışmanlık hizmetleri neler kapsar?', a: 'İç mimar danışmanlık hizmetleri; mekan analizi, renk ve stil danışmanlığı, malzeme seçimi, mobilya yerleşim planı, uygulama sürecinde yerinde denetim, sözleşme değerlendirmesi ve teslim öncesi punch-list incelemesini kapsar.' },
        { q: 'Kendi müteahhidimle çalışırken iç mimar danışmanlığı alabilir miyim?', a: 'Evet. İç mimar danışmanlık hizmeti, kendi yüklenicilerinizle çalışıp tasarım ve malzeme kararlarında uzman görüşü almak isteyenler için özellikle uygundur. Uygulama yönetimi olmaksızın yalnızca rehberlik sağlıyoruz.' },
        { q: 'Tek seferlik danışmanlık oturumu mümkün mü?', a: 'Evet. Tek seferlik danışmanlık oturumundan süreç boyunca rehberliğe kadar ihtiyacınıza özel esnek paketler sunuyoruz. Tek oturum yaklaşık 1–2 saat sürmektedir.' },
        { q: 'İç mimar danışmanlığı için nasıl başvurabilirim?', a: 'WhatsApp, telefon veya e-posta ile iletişime geçebilirsiniz. İlk görüşme ücretsizdir; projenizi değerlendirip size uygun iç mimar danışmanlık paketini birlikte belirliyoruz.' },
      ].map((faq, i) => (
        <details class="group py-5" open={i === 0}>
          <summary class="flex items-start justify-between cursor-pointer list-none gap-4">
            <h3 class="font-semibold text-charcoal text-sm md:text-base group-open:text-gold transition-colors">{faq.q}</h3>
            <svg class="shrink-0 w-5 h-5 text-gold mt-0.5 group-open:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <p class="mt-3 text-muted text-sm leading-relaxed pr-8">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>

</ServiceLayout>
