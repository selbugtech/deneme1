---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import { CANONICAL_BASE } from '../../config';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "İç Mimarlık Danışmanlığı",
  "name": "İstanbul'un En İyi İç Mimarlık Ofisleri ve Firmaları — Danışmanlık Hizmeti",
  "description": "İstanbul'un en iyi iç mimarlık firmalarından Master İç Mimarlık. Profesyonel iç mimarlık danışmanlığı, malzeme seçimi, uygulama rehberliği.",
  "provider": { "@type": "Organization", "@id": `${CANONICAL_BASE}/#organization`, "name": "Master İç Mimarlık" },
  "areaServed": { "@type": "City", "name": "İstanbul" },
  "url": `${CANONICAL_BASE}/hizmetler/ic-mimarlik-danismanligi`,
  "offers": { "@type": "Offer", "priceCurrency": "TRY", "description": "Ücretsiz ilk görüşme ve projeye özel teklif", "availability": "https://schema.org/InStock" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "İç mimarlık danışmanlığı ne içerir?", "acceptedAnswer": { "@type": "Answer", "text": "Mekan analizi, renk paleti ve stil danışmanlığı, malzeme seçimi, mobilya yerleşim planı, uygulama sürecinde yerinde denetim ve teslim öncesi punch-list incelemesi gibi hizmetleri kapsamaktadır." } },
    { "@type": "Question", "name": "Kendi müteahhidimle çalışırken danışmanlık alabilir miyim?", "acceptedAnswer": { "@type": "Answer", "text": "Evet. Danışmanlık hizmeti özellikle kendi yüklenicilerinizle çalışıyor olup tasarım ve malzeme kararlarında uzman görüşü isteyenler için idealdir. Uygulama yönetimi olmaksızın yalnızca tasarım rehberliği sağlıyoruz." } },
    { "@type": "Question", "name": "Tek seferlik danışmanlık oturumu alabilir miyim?", "acceptedAnswer": { "@type": "Answer", "text": "Evet. Tek seferlik danışmanlık oturumundan süreç boyunca rehberliğe kadar ihtiyacınıza özel esnek paketler sunuyoruz. Tek oturum danışmanlık için yaklaşık 1–2 saatlik bir görüşme yapılmaktadır." } },
    { "@type": "Question", "name": "Danışmanlık için nasıl başvurabilirim?", "acceptedAnswer": { "@type": "Answer", "text": "WhatsApp, telefon veya e-posta ile iletişime geçebilirsiniz. İlk görüşmede projenizi ve ihtiyaçlarınızı değerlendirip size uygun paketi belirliyoruz." } }
  ]
};
---

<ServiceLayout
  title="İstanbul'un En İyi İç Mimarlık Ofisleri ve Firmaları | Master İç Mimarlık"
  description="İstanbul'un en iyi iç mimarlık ofisleri arasında yer alan Master İç Mimarlık. Profesyonel iç mimarlık danışmanlığı, malzeme seçimi ve uzman rehberlik. Ücretsiz ilk görüşme: 0533 039 15 65"
  canonicalUrl={`${CANONICAL_BASE}/hizmetler/ic-mimarlik-danismanligi`}
  h1="İstanbul'un En İyi İç Mimarlık Ofisleri ve Firmaları"
  eyebrow="İç Mimarlık Danışmanlığı"
  lead="İstanbul'da 8 yılı aşkın deneyimi ve 150'den fazla tamamlanan projesiyle Master İç Mimarlık, profesyonel iç mimarlık danışmanlığı, malzeme seçimi ve uygulama sürecinde uzman rehberlik sunmaktadır."
  breadcrumb={[
    { label: "Ana Sayfa", href: "/deneme1/" },
    { label: "Hizmetler", href: "/deneme1/#hizmetler" },
    { label: "İç Mimarlık Danışmanlığı" }
  ]}
  heroImage="/deneme1/images/francesca-tosolini-XcVm8mn7NUM-unsplash.jpg"
  ogImage={`${CANONICAL_BASE}/images/francesca-tosolini-XcVm8mn7NUM-unsplash.jpg`}
  structuredData={[serviceSchema, faqSchema]}
>

  <!-- Hero Placeholder -->
  <div class="w-full bg-charcoal flex items-center justify-center mb-12" style="height: 420px;">
    <div class="text-center">
      <svg class="w-16 h-16 text-gold/40 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
      <p class="text-white/30 text-sm tracking-widest uppercase">Proje Görselleri Yakında</p>
    </div>
  </div>

  <!-- Scope -->
  <div class="grid md:grid-cols-2 gap-12 py-12 border-b border-border">
    <div>
      <h2 class="font-display text-3xl font-bold text-charcoal mb-4">İç Mimarlık Danışmanlığı Hizmetimiz</h2>
      <p class="text-muted leading-relaxed mb-4">
        İç mimarlık danışmanlığı, kendi yüklenicilerinizle veya ekibinizle çalışırken profesyonel perspektif almak isteyen ev sahipleri için idealdir. Tüm proje yönetimini devralmak yerine belirli konularda uzman desteği alırsınız.
      </p>
      <p class="text-muted leading-relaxed mb-4">
        Malzeme seçiminde yanlış karar vermek, uzun vadede hem estetik hem mali kayıplara yol açar. Danışmanlık hizmetimizde bu riski minimize etmenize yardımcı oluyoruz.
      </p>
      <p class="text-muted leading-relaxed">
        Tek seferlik danışmanlık oturumundan süreç boyunca rehberliğe kadar ihtiyacınıza özel esnek paketler sunuyoruz.
      </p>
    </div>
    <div>
      <h3 class="font-semibold text-charcoal mb-4 text-xs uppercase tracking-wider">Danışmanlık Kapsamı</h3>
      <ul class="space-y-3">
        {[
          'Mekan analizi ve alan planlaması',
          'Renk paleti ve stil danışmanlığı',
          'Malzeme seçimi ve tedarikçi önerileri',
          'Mobilya yerleşim planı',
          'Uygulama sürecinde yerinde denetim',
          'Sözleşme ve fiyat değerlendirmesi',
          'Uygulamanın doğruluğunu kontrol',
          'Son teslim öncesi punch-list incelemesi',
        ].map(item => (
          <li class="flex items-start gap-3 text-sm text-muted">
            <span class="w-4 h-4 mt-0.5 shrink-0 bg-gold/15 rounded-full flex items-center justify-center">
              <svg class="w-2.5 h-2.5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- When to choose -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-8">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Ne Zaman İç Mimarlık Danışmanlığı Seçilmeli?</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {[
        { title: 'Kısmi Proje', desc: 'Sadece tek bir oda veya belirli bir alanı yenileyecekseniz ve genel bir iç mimar tutmak istemiyorsanız.' },
        { title: 'Kendi Yüklenicin Var', desc: 'Bir müteahhit veya ustanızla çalışıyorsunuz ancak tasarım ve malzeme kararlarında uzman görüşü istiyorsunuz.' },
        { title: 'İkinci Görüş', desc: 'Başka bir yerden aldığınız tasarım veya teklif için bağımsız bir uzman değerlendirmesi istiyorsunuz.' },
      ].map(card => (
        <div class="border border-border p-6">
          <h3 class="font-semibold text-charcoal mb-2 text-sm">{card.title}</h3>
          <p class="text-muted text-xs leading-relaxed">{card.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Packages -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-8">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Danışmanlık Paketlerimiz</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {[
        { title: 'Tek Oturum', items: ['1–2 saatlik görüşme', 'Mekan değerlendirmesi', 'Malzeme ve renk önerileri', 'Yazılı özet rapor'], tag: 'Başlangıç' },
        { title: 'Proje Paketi', items: ['Konsept tasarım', '3D taslak görseller', 'Malzeme seçim rehberi', 'Tedarikçi önerileri', 'E-posta desteği'], tag: 'Popüler' },
        { title: 'Süreç Boyunca', items: ['Tüm proje danışmanlığı', 'Yerinde denetim ziyaretleri', 'Teslim öncesi kontrol', 'Sözleşme değerlendirmesi', 'WhatsApp desteği'], tag: 'Kapsamlı' },
      ].map(pkg => (
        <div class="border border-border p-6">
          <p class="text-[10px] tracking-widest uppercase text-gold mb-2">{pkg.tag}</p>
          <h3 class="font-display font-bold text-charcoal text-lg mb-4">{pkg.title}</h3>
          <ul class="space-y-2">
            {pkg.items.map(item => (
              <li class="flex items-start gap-2 text-xs text-muted">
                <svg class="w-3 h-3 text-gold mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <!-- FAQ -->
  <div class="py-12">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Sık Sorulan Sorular</h2>
    </div>
    <div class="divide-y divide-border">
      {[
        { q: 'İç mimarlık danışmanlığı ne içerir?', a: 'Mekan analizi, renk paleti ve stil danışmanlığı, malzeme seçimi, mobilya yerleşim planı ve uygulama sürecinde yerinde denetim gibi hizmetleri kapsamaktadır.' },
        { q: 'Kendi müteahhidimle çalışırken danışmanlık alabilir miyim?', a: 'Evet. Danışmanlık hizmeti özellikle kendi yüklenicilerinizle çalışıyor olup tasarım ve malzeme kararlarında uzman görüşü isteyenler için idealdir.' },
        { q: 'Tek seferlik danışmanlık oturumu alabilir miyim?', a: 'Evet. Tek seferlik oturumdan süreç boyunca rehberliğe kadar ihtiyacınıza özel esnek paketler sunuyoruz.' },
        { q: 'Danışmanlık için nasıl başvurabilirim?', a: 'WhatsApp, telefon veya e-posta ile iletişime geçebilirsiniz. İlk görüşmede projenizi değerlendirip size uygun paketi belirliyoruz.' },
      ].map((faq, i) => (
        <details class="group py-5" open={i === 0}>
          <summary class="flex items-start justify-between cursor-pointer list-none gap-4">
            <h3 class="font-semibold text-charcoal text-sm md:text-base group-open:text-gold transition-colors">{faq.q}</h3>
            <svg class="shrink-0 w-5 h-5 text-gold mt-0.5 group-open:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <p class="mt-3 text-muted text-sm leading-relaxed pr-8">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>

</ServiceLayout>
