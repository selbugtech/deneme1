---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import { CANONICAL_BASE } from '../../config';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "3D Tasarım ve İç Mimarlık Projesi",
  "name": "İç Mimarlık 3D Tasarım İstanbul",
  "description": "İstanbul'da iç mimarlık 3D görselleştirme ve mimari proje hizmetleri. Uygulamadan önce mekanınızı gerçekçi 3D görseller ile deneyimleyin.",
  "provider": {
    "@type": "InteriorDesigner",
    "@id": `${CANONICAL_BASE}/#business`,
    "name": "Master İç Mimarlık"
  },
  "areaServed": { "@type": "City", "name": "İstanbul" },
  "url": `${CANONICAL_BASE}/hizmetler/3d-tasarim`
};
---

<ServiceLayout
  title="3D Tasarım ve İç Mimarlık Projesi İstanbul | Master"
  description="İstanbul'da iç mimarlık 3D tasarım ve görselleştirme hizmetleri. Uygulamaya başlamadan önce mekanınızı gerçekçi 3D görseller ile görün. 0533 039 15 65"
  canonicalUrl={`${CANONICAL_BASE}/hizmetler/3d-tasarim`}
  h1="3D Tasarım ve İç Mimarlık Projesi"
  eyebrow="Hizmet"
  lead="Uygulamaya başlamadan önce mekanınızı gerçekçi 3D görseller ile deneyimleyin. Malzeme, renk ve mobilya seçimlerini somut olarak görerek onaylayın — sürprizle karşılaşmayın."
  breadcrumb={[
    { label: "Ana Sayfa", href: `${CANONICAL_BASE}/` },
    { label: "Hizmetler", href: `${CANONICAL_BASE}/hizmetler` },
    { label: "3D Tasarım" }
  ]}
  structuredData={serviceSchema}
>

  <div class="grid md:grid-cols-2 gap-12 py-12 border-b border-border">
    <div>
      <h2 class="font-display text-3xl font-bold text-charcoal mb-4">Neden 3D Tasarım?</h2>
      <p class="text-muted leading-relaxed mb-4">
        Mekan tasarımı söz konusu olduğunda iki boyutlu çizimler genellikle yeterli fikir vermez. Renk, malzeme, ışık ve hacim ilişkisini ikinci boyutta hayal etmek zordur.
      </p>
      <p class="text-muted leading-relaxed mb-4">
        Gerçekçi 3D görselleştirme ile müşterimiz projeye başlamadan önce her detayı görür ve onaylar. Bu sayede uygulama sırasında fikir değişiklikleri ve buna bağlı maliyet artışları minimuma iner.
      </p>
      <p class="text-muted leading-relaxed">
        3D tasarım hizmeti tüm anahtar teslim projelerimizde standarttır. Ayrıca uygulama olmaksızın sadece 3D tasarım paketi de sunuyoruz.
      </p>
    </div>
    <div>
      <h3 class="font-semibold text-charcoal mb-4">3D Tasarım Sürecimiz</h3>
      <ul class="space-y-3">
        {[
          'Mekan ölçüm ve mevcut durum analizi',
          'Fonksiyon ve estetik ihtiyaç analizi',
          'Konsept tasarım alternatifleri',
          'Fotorealistik 3D render görseller',
          'Malzeme ve renk entegrasyonu',
          'Aydınlatma simülasyonu',
          'Revizyon ve onay aşamaları',
          'Uygulama için teknik çizimler',
        ].map(item => (
          <li class="flex items-start gap-3 text-sm text-muted">
            <span class="w-4 h-4 mt-0.5 shrink-0 bg-gold/15 rounded-full flex items-center justify-center">
              <svg class="w-2.5 h-2.5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="py-12">
    <h2 class="font-display text-2xl font-bold text-charcoal mb-4">3D Tasarımın Faydaları</h2>
    <div class="grid md:grid-cols-3 gap-6">
      {[
        { title: 'Karar Güveni', desc: 'Mekanı gerçekçi biçimde görünce malzeme ve renk kararları çok daha kolay verilir.' },
        { title: 'Maliyet Tasarrufu', desc: 'Uygulama sırasındaki fikir değişiklikleri en büyük maliyet artış kaynağıdır. 3D onayı bu riski ortadan kaldırır.' },
        { title: 'Zaman Tasarrufu', desc: 'Revizyon döngüleri azalır, uygulama daha hızlı ve verimli ilerler.' },
      ].map(card => (
        <div class="border border-border p-6">
          <h3 class="font-semibold text-charcoal mb-2">{card.title}</h3>
          <p class="text-muted text-sm leading-relaxed">{card.desc}</p>
        </div>
      ))}
    </div>
  </div>

</ServiceLayout>
