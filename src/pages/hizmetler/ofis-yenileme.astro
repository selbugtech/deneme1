---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import { CANONICAL_BASE } from '../../config';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Ofis Yenileme",
  "name": "Ofis Yenileme İstanbul",
  "description": "İstanbul'da modern ofis yenileme ve kurumsal mekan tasarımı. Levent, Şişli ve tüm İstanbul'da ofis iç mimarlık hizmetleri.",
  "provider": { "@type": "Organization", "@id": `${CANONICAL_BASE}/#organization`, "name": "Master İç Mimarlık" },
  "areaServed": [
    { "@type": "City", "name": "İstanbul" },
    { "@type": "AdministrativeArea", "name": "Levent" },
    { "@type": "AdministrativeArea", "name": "Şişli" },
    { "@type": "AdministrativeArea", "name": "Maslak" }
  ],
  "url": `${CANONICAL_BASE}/hizmetler/ofis-yenileme`,
  "offers": { "@type": "Offer", "priceCurrency": "TRY", "description": "Ofis büyüklüğü ve kapsamına göre özel fiyatlandırma", "availability": "https://schema.org/InStock" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Ofis yenileme süresince iş sürekliliği sağlanabilir mi?", "acceptedAnswer": { "@type": "Answer", "text": "Evet. Ofis yenileme projelerini faz faz planlayarak operasyonunuzun minimum etkilenmesini sağlıyoruz. Hafta sonu ve mesai dışı saatlerde yoğun iş yapabiliyoruz." } },
    { "@type": "Question", "name": "Ofis yenileme maliyeti ne kadar?", "acceptedAnswer": { "@type": "Answer", "text": "İstanbul'da ofis yenileme metrekare başına yaklaşık 2.500–7.000 ₺ arasında değişmektedir. Kapsam (açık ofis, toplantı odaları, lobi vb.) ve seçilen malzemelere göre fiyat belirlenir." } },
    { "@type": "Question", "name": "Kurumsal kimliğimizi ofis tasarımına yansıtabilir misiniz?", "acceptedAnswer": { "@type": "Answer", "text": "Evet. Marka renkleri, logotypografi ve kurumsal kimlik unsurlarını ofis tasarımına yansıtmak uzmanlık alanlarımızdan biridir. Öncelikle marka yönergelerinizi inceleyerek tasarım sürecine başlıyoruz." } },
    { "@type": "Question", "name": "Levent ve Maslak'a hizmet veriyor musunuz?", "acceptedAnswer": { "@type": "Answer", "text": "Evet. Levent, Maslak, Şişli, Ataşehir ve İstanbul'un tüm iş merkezlerinde ofis yenileme hizmeti sunuyoruz." } }
  ]
};
---

<ServiceLayout
  title="Ofis Yenileme İstanbul — Kurumsal Mekan Tasarımı | Master İç Mimarlık"
  description="İstanbul'da ofis yenileme ve kurumsal mekan tasarımı. Çalışan verimliliğini artıran modern ofis çözümleri. Levent, Maslak, Şişli ve tüm İstanbul iş merkezlerinde hizmet. 0533 039 15 65"
  canonicalUrl={`${CANONICAL_BASE}/hizmetler/ofis-yenileme`}
  h1="İstanbul'da Ofis Yenileme ve Kurumsal Mekan Tasarımı"
  eyebrow="Hizmet"
  lead="Ekibinizin verimliliğini ve motivasyonunu artıran, marka kimliğinizi yansıtan modern çalışma ortamları tasarlıyoruz. İş sürekliliğinizi koruyarak faz faz uygulama yapıyoruz."
  breadcrumb={[
    { label: "Ana Sayfa", href: `${CANONICAL_BASE}/` },
    { label: "Hizmetler", href: `${CANONICAL_BASE}/hizmetler` },
    { label: "Ofis Yenileme" }
  ]}
  heroImage="/deneme1/images/todd-kent-178j8tJrNlc-unsplash.jpg"
  ogImage={`${CANONICAL_BASE}/images/todd-kent-178j8tJrNlc-unsplash.jpg`}
  structuredData={[serviceSchema, faqSchema]}
>

  <!-- Scope -->
  <div class="grid md:grid-cols-2 gap-12 py-12 border-b border-border">
    <div>
      <h2 class="font-display text-3xl font-bold text-charcoal mb-4">Kurumsal Mekan Tasarımı</h2>
      <p class="text-muted leading-relaxed mb-4">
        Ofis ortamı, çalışan performansını ve firma imajını doğrudan etkiler. İyi tasarlanmış bir ofis hem çalışanların motivasyonunu artırır hem de müşteriler ve iş ortakları üzerinde güçlü bir izlenim bırakır.
      </p>
      <p class="text-muted leading-relaxed mb-4">
        Kurumsal mekan projelerinde çalışma alanı planlaması, toplantı odaları, lobi tasarımı ve ortak alanların düzenlenmesinde bütünleşik yaklaşım sunuyoruz.
      </p>
      <p class="text-muted leading-relaxed">
        Ofis yenileme sürecinde iş sürekliliğini gözetiyoruz. Uygulamayı faz faz planlayarak operasyonunuzun minimum şekilde etkilenmesini sağlıyoruz.
      </p>
    </div>
    <div>
      <h3 class="font-semibold text-charcoal mb-4 text-xs uppercase tracking-wider">Ofis Projelerinde Kapsamımız</h3>
      <ul class="space-y-3">
        {[
          'Çalışma alanı (workspace) planlaması',
          'Toplantı odaları ve konferans alanları',
          'Lobi ve resepsiyon tasarımı',
          'Mutfak, kafeterya ve dinlenme alanları',
          'Akustik çözümler ve ses yalıtımı',
          'Aydınlatma tasarımı (sağlıklı çalışma ışığı)',
          'Marka renkleri ve kurumsal kimlik uyumu',
          'Ofis mobilyası koordinasyonu',
          'Faz faz uygulama (iş sürekliliği)',
        ].map(item => (
          <li class="flex items-start gap-3 text-sm text-muted">
            <span class="w-4 h-4 mt-0.5 shrink-0 bg-gold/15 rounded-full flex items-center justify-center">
              <svg class="w-2.5 h-2.5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Gallery -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Referans Projeler</h2>
    </div>
    <div class="grid md:grid-cols-2 gap-4">
      {[
        { src: '/deneme1/images/270210256_1299189580524073_8666915339070247329_n.jpg', title: 'Levent Ofis', detail: '320 m² · Finans sektörü kurumsal ofisi · 2023' },
        { src: '/deneme1/images/269918400_1013177626208480_5105469845896302754_n.jpg', title: 'Maslak Teknoloji Ofisi', detail: '240 m² · Açık plan + toplantı odaları · 2024' },
      ].map(p => (
        <div class="group">
          <div class="overflow-hidden mb-3">
            <img src={p.src} alt={p.title} class="w-full h-56 object-cover group-hover:scale-105 transition-transform duration-500" />
          </div>
          <h3 class="font-semibold text-charcoal text-sm">{p.title}</h3>
          <p class="text-muted text-xs mt-0.5">{p.detail}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Why us -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-8">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Ofis Tasarımında Öne Çıkan Özelliklerimiz</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {[
        { title: 'İş Sürekliliği', desc: 'Faz faz uygulama yaparak ofis faaliyetlerinizin minimum kesintiye uğramasını sağlıyoruz.' },
        { title: 'Akustik Çözümler', desc: 'Açık ofis düzenlerinde ses yalıtımı ve akustik tasarım, verimli çalışma ortamı için kritik öneme sahiptir.' },
        { title: 'Marka Uyumu', desc: 'Kurumsal kimliğinizi mekana yansıtıyor, çalışan ve ziyaretçi deneyimini güçlendiriyoruz.' },
      ].map(card => (
        <div class="border border-border p-6">
          <h3 class="font-semibold text-charcoal mb-2 text-sm">{card.title}</h3>
          <p class="text-muted text-xs leading-relaxed">{card.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- FAQ -->
  <div class="py-12">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Sık Sorulan Sorular</h2>
    </div>
    <div class="divide-y divide-border">
      {[
        { q: 'Ofis yenileme süresince iş sürekliliği sağlanabilir mi?', a: 'Evet. Ofis yenileme projelerini faz faz planlayarak operasyonunuzun minimum etkilenmesini sağlıyoruz. Hafta sonu ve mesai dışı saatlerde yoğun çalışabiliyoruz.' },
        { q: 'Ofis yenileme maliyeti ne kadar?', a: 'İstanbul\'da ofis yenileme metrekare başına yaklaşık 2.500–7.000 ₺ arasında değişmektedir. Kapsam ve seçilen malzemelere göre fiyat belirlenir.' },
        { q: 'Kurumsal kimliğimizi ofis tasarımına yansıtabilir misiniz?', a: 'Evet. Marka renkleri, tipografi ve kurumsal kimlik unsurlarını ofis tasarımına yansıtmak uzmanlık alanlarımızdan biridir.' },
        { q: 'Levent ve Maslak\'a hizmet veriyor musunuz?', a: 'Evet. Levent, Maslak, Şişli, Ataşehir ve İstanbul\'un tüm iş merkezlerinde ofis yenileme hizmeti sunuyoruz.' },
      ].map((faq, i) => (
        <details class="group py-5" open={i === 0}>
          <summary class="flex items-start justify-between cursor-pointer list-none gap-4">
            <h3 class="font-semibold text-charcoal text-sm md:text-base group-open:text-gold transition-colors">{faq.q}</h3>
            <svg class="shrink-0 w-5 h-5 text-gold mt-0.5 group-open:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <p class="mt-3 text-muted text-sm leading-relaxed pr-8">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>

</ServiceLayout>
