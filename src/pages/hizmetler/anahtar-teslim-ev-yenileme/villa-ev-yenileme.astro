---
import ServiceLayout from '../../../layouts/ServiceLayout.astro';
import { CANONICAL_BASE } from '../../../config';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Villa ve Ev Yenileme",
  "name": "İstanbul Villa ve Ev Yenileme",
  "description": "İstanbul'da anahtar teslim villa ve ev yenileme. Yaşam kalitenizi artıran, kişisel tarzınızı yansıtan kapsamlı konut yenileme projeleri.",
  "provider": { "@type": "Organization", "@id": `${CANONICAL_BASE}/#organization`, "name": "Master İç Mimarlık" },
  "areaServed": [
    { "@type": "City", "name": "İstanbul" },
    { "@type": "AdministrativeArea", "name": "Zekeriyaköy" },
    { "@type": "AdministrativeArea", "name": "Acıbadem" },
    { "@type": "AdministrativeArea", "name": "Beşiktaş" }
  ],
  "url": `${CANONICAL_BASE}/hizmetler/anahtar-teslim-ev-yenileme/villa-ev-yenileme`,
  "offers": { "@type": "Offer", "priceCurrency": "TRY", "description": "Ücretsiz keşif ve özel teklif için iletişime geçin", "availability": "https://schema.org/InStock" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Villa yenileme bütçesi nasıl belirlenir?", "acceptedAnswer": { "@type": "Answer", "text": "Bütçe; villanın büyüklüğü, mevcut yapı durumu ve seçilen malzeme kalitesine göre belirlenir. Ücretsiz keşif ziyaretimizde projenize özel bütçe sunuyoruz." } },
    { "@type": "Question", "name": "Villa yenileme ne kadar sürer?", "acceptedAnswer": { "@type": "Answer", "text": "Ortalama bir villa yenileme projesi (250–400 m²) 10–20 hafta içinde tamamlanmaktadır. Kapsamlı yapısal değişiklikler içeren projeler daha uzun sürebilir. Sözleşmede kesin takvim belirlenir." } },
    { "@type": "Question", "name": "Yenileme süresince evde oturabilir miyim?", "acceptedAnswer": { "@type": "Answer", "text": "Komple yenileme projelerinde evde oturmanızı tavsiye etmiyoruz. Kısmi yenilemelerde (tek kat veya belirli odalar) mümkün olabilir. Her projenin planlamasında bu konuyu müşterimizle önceden değerlendiriyoruz." } }
  ]
};
---

<ServiceLayout
  title="İstanbul Villa ve Ev Yenileme | Master İç Mimarlık"
  description="İstanbul'da villa ve ev yenileme. Yaşam kalitenizi artıran, kişisel tarzınızı yansıtan anahtar teslim konut yenileme. Zekeriyaköy, Acıbadem, Beşiktaş. Ücretsiz keşif: 0533 039 15 65"
  canonicalUrl={`${CANONICAL_BASE}/hizmetler/anahtar-teslim-ev-yenileme/villa-ev-yenileme`}
  h1="İstanbul Villa ve Ev Yenileme"
  eyebrow="Anahtar Teslim"
  lead="Yaşam kalitenizi artıran, kişisel tarzınızı yansıtan villa ve ev yenileme projeleri. Küçük daireden büyük villaya, kısmi yenilemeden komple dönüşüme kadar tüm konut projeleri."
  breadcrumb={[
    { label: "Ana Sayfa", href: "/deneme1/" },
    { label: "Hizmetler", href: "/deneme1/#hizmetler" },
    { label: "Anahtar Teslim Hizmetler", href: "/deneme1/hizmetler/anahtar-teslim-ev-yenileme" },
    { label: "Villa & Ev Yenileme" }
  ]}
  structuredData={[serviceSchema, faqSchema]}
>

  <!-- Hero Placeholder -->
  <div class="w-full bg-charcoal flex items-center justify-center mb-12" style="height: 420px;">
    <div class="text-center">
      <svg class="w-16 h-16 text-gold/40 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
      <p class="text-white/30 text-sm tracking-widest uppercase">Proje Görselleri Yakında</p>
    </div>
  </div>

  <!-- Scope -->
  <div class="grid md:grid-cols-2 gap-12 py-12 border-b border-border">
    <div>
      <h2 class="font-display text-3xl font-bold text-charcoal mb-4">Villa & Ev Yenileme Hizmetimiz</h2>
      <p class="text-muted leading-relaxed mb-4">
        Eviniz kişisel tarzınızın ve yaşam anlayışınızın yansımasıdır. Küçük bir dairenin yenilenmesinden büyük bir villanın baştan tasarlanmasına kadar her ölçekte konut projesi yürütüyoruz.
      </p>
      <p class="text-muted leading-relaxed mb-4">
        Mutfak ve banyo yenilemeden salon tasarımına, yatak odası düzenlemesinden dış cepheye kadar evinizin her köşesini sizin için planlıyoruz.
      </p>
      <p class="text-muted leading-relaxed">
        İstanbul genelinde Zekeriyaköy, Acıbadem, Beşiktaş, Kadıköy ve tüm ilçelerde hizmet veriyoruz.
      </p>
    </div>
    <div>
      <h3 class="font-semibold text-charcoal mb-4 text-xs uppercase tracking-wider">Hizmete Dahil Olanlar</h3>
      <ul class="space-y-3">
        {[
          'İç mimari konsept tasarım',
          'Fotorealistik 3D görselleştirme',
          'Mutfak ve banyo yenileme',
          'Salon ve yatak odası tasarımı',
          'Elektrik, tesisat iyileştirme',
          'Zemin, duvar ve tavan kaplamaları',
          'Aydınlatma ve dekor uygulamaları',
          'Son temizlik ve anahtar teslim',
        ].map(item => (
          <li class="flex items-start gap-3 text-sm text-muted">
            <span class="w-4 h-4 mt-0.5 shrink-0 bg-gold/15 rounded-full flex items-center justify-center">
              <svg class="w-2.5 h-2.5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Process -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-8">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Villa ve Ev Yenileme Sürecimiz</h2>
    </div>
    <div class="grid md:grid-cols-5 gap-6">
      {[
        { step: '01', title: 'Ücretsiz Keşif', desc: 'Evinizi ve yaşam tarzınızı yerinde değerlendiriyoruz.' },
        { step: '02', title: '3D Tasarım', desc: 'Mekanınızı gerçekçi görsellerle deneyimleyin ve onaylayın.' },
        { step: '03', title: 'Sözleşme', desc: 'Kesin bütçe ve takvim belirlenerek sözleşme imzalanır.' },
        { step: '04', title: 'Uygulama', desc: 'Şantiye yönetimi tamamen bizde. Sizi düzenli bilgilendiriyoruz.' },
        { step: '05', title: 'Teslim', desc: 'Temizlenmiş, eksiksiz hazır evinizi teslim alırsınız.' },
      ].map(item => (
        <div class="text-center">
          <div class="w-12 h-12 bg-gold/10 rounded-full flex items-center justify-center mx-auto mb-3">
            <span class="text-gold font-display font-bold text-sm">{item.step}</span>
          </div>
          <h3 class="font-semibold text-charcoal text-sm mb-2">{item.title}</h3>
          <p class="text-muted text-xs leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Service Areas -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Hizmet Verdiğimiz İlçeler</h2>
    </div>
    <div class="flex flex-wrap gap-2">
      {['Zekeriyaköy', 'Acıbadem', 'Beşiktaş', 'Kadıköy', 'Levent', 'Nişantaşı', 'Ataşehir', 'Şişli', 'Sarıyer', 'Üsküdar', 'Bakırköy', 'Maltepe'].map(ilce => (
        <span class="px-3 py-1.5 border border-border text-charcoal text-xs font-medium">{ilce}</span>
      ))}
    </div>
  </div>

  <!-- FAQ -->
  <div class="py-12">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Sık Sorulan Sorular</h2>
    </div>
    <div class="divide-y divide-border">
      {[
        { q: 'Villa yenileme bütçesi nasıl belirlenir?', a: 'Bütçe; villanın büyüklüğü, mevcut yapı durumu ve seçilen malzeme kalitesine göre belirlenir. Ücretsiz keşif ziyaretimizde projenize özel bütçe sunuyoruz.' },
        { q: 'Villa yenileme ne kadar sürer?', a: 'Ortalama bir villa yenileme projesi (250–400 m²) 10–20 hafta içinde tamamlanmaktadır. Sözleşmede kesin takvim belirlenir.' },
        { q: 'Yenileme süresince evde oturabilir miyim?', a: 'Komple yenileme projelerinde evde oturmanızı tavsiye etmiyoruz. Kısmi yenilemelerde mümkün olabilir. Her projenin planlamasında bu konuyu müşterimizle önceden değerlendiriyoruz.' },
      ].map((faq, i) => (
        <details class="group py-5" open={i === 0}>
          <summary class="flex items-start justify-between cursor-pointer list-none gap-4">
            <h3 class="font-semibold text-charcoal text-sm md:text-base group-open:text-gold transition-colors">{faq.q}</h3>
            <svg class="shrink-0 w-5 h-5 text-gold mt-0.5 group-open:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <p class="mt-3 text-muted text-sm leading-relaxed pr-8">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>

</ServiceLayout>
