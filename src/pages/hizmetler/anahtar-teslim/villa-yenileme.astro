---
import ServiceLayout from '../../../layouts/ServiceLayout.astro';
import { CANONICAL_BASE } from '../../../config';
import { optimizedImage } from '../../../lib/cloudinary';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Villa Yenileme",
  "name": "İstanbul Villa Yenileme",
  "description": "İstanbul'da anahtar teslim villa yenileme. Yapısal müdahale gerektirmeyen estetik güncelleme; zemin, kaplama, malzeme ve aydınlatma yenilemesi ile lüks villa dönüşümü.",
  "provider": { "@type": "Organization", "@id": `${CANONICAL_BASE}/#organization`, "name": "Master İç Mimarlık" },
  "areaServed": [
    { "@type": "City", "name": "İstanbul" },
    { "@type": "AdministrativeArea", "name": "Zekeriyaköy" },
    { "@type": "AdministrativeArea", "name": "Acıbadem" },
    { "@type": "AdministrativeArea", "name": "Sarıyer" }
  ],
  "url": `${CANONICAL_BASE}/hizmetler/anahtar-teslim/villa-yenileme`,
  "offers": { "@type": "Offer", "priceCurrency": "TRY", "description": "Ücretsiz keşif ve özel teklif için iletişime geçin", "availability": "https://schema.org/InStock" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Villa yenileme ne kadar sürer?", "acceptedAnswer": { "@type": "Answer", "text": "Yapısal müdahale içermeyen bir villa yenilemesi kapsamına bağlı olarak 6–14 hafta içinde tamamlanabilir. Yalnızca iç mekan kaplama ve aydınlatma güncellemesi yapılıyorsa bu süre daha kısa olabilir. Komple villa yenilemelerinde malzeme temin ve işçilik takvimi önceden netleştirilir." } },
    { "@type": "Question", "name": "Villa yenileme ile tadilat arasındaki fark nedir?", "acceptedAnswer": { "@type": "Answer", "text": "Villa yenilemesi; altyapıya dokunmadan estetik ve malzeme güncellemesi yapmayı kapsar — zemin, kaplama, boya, armatür ve aydınlatma değişimi gibi işler. Villa tadilat ise elektrik, tesisat, yapısal duvar müdahalesi ve dış cephe onarımı gibi teknik altyapı işlerini içerir. Villanızın altyapısı sorunsuzsa yenileme çok daha hızlı ve ekonomik bir seçenektir." } },
    { "@type": "Question", "name": "Yenileme süresince villada oturabilir miyim?", "acceptedAnswer": { "@type": "Answer", "text": "Kısmi villa yenilemesinde — örneğin yalnızca zemin katı veya belirli odalar yenileniyorsa — villada oturmak mümkün olabilir. Komple villa yenilemesinde ise zemin, boyama ve tüm kat çalışmaları eş zamanlı yürütüleceğinden geçici taşınma daha verimli olur. Her projenin planlamasında bu konuyu müşterimizle önceden değerlendiriyoruz." } },
    { "@type": "Question", "name": "Villa yenileme bütçesi nasıl belirlenir?", "acceptedAnswer": { "@type": "Answer", "text": "Bütçe; villanın büyüklüğü, yenileme kapsamı ve seçilen malzeme kalitesine göre belirlenir. Lüks segmentte premium malzeme seçimleri bütçeyi önemli ölçüde etkiler; bu nedenle teklif aşamasında materyal seçimlerini önceden netleştiriyoruz. Ücretsiz keşif ziyaretimizde tüm kalemleri içeren şeffaf bir bütçe sunuyoruz." } },
    { "@type": "Question", "name": "Villa yenilemede bahçe ve dış cephe dahil mi?", "acceptedAnswer": { "@type": "Answer", "text": "Dış cephe boyası ve bahçe düzenlemesi gibi yüzeysel güncellemeler yenileme kapsamında değerlendirilebilir. Yapısal dış cephe onarımı veya peyzaj projesi gerekiyorsa bu işler villa tadilat kapsamına girer. Keşif aşamasında projenizin tam kapsamını birlikte belirliyoruz." } }
  ]
};
---

<ServiceLayout
  title="İstanbul Villa Yenileme | Lüks Villa Görünüm Güncelleme"
  description="İstanbul'da anahtar teslim villa yenileme. Altyapıya dokunmadan zemin, kaplama ve malzeme güncellemesiyle lüks villa dönüşümü. Zekeriyaköy, Sarıyer, Acıbadem. Ücretsiz keşif: 0533 039 15 65"
  canonicalUrl={`${CANONICAL_BASE}/hizmetler/anahtar-teslim/villa-yenileme`}
  h1="İstanbul Villa Yenileme"
  eyebrow="Anahtar Teslim"
  lead="Altyapısı sağlam ama görünümü güncelleme isteyen lüks villalar için estetik dönüşüm. Zemin, kaplama, malzeme ve aydınlatma seçimleriyle yapısal müdahale olmadan villanızı çağdaş bir kimliğe kavuşturuyoruz."
  breadcrumb={[
    { label: "Ana Sayfa", href: "/" },
    { label: "Hizmetler", href: "/#hizmetler" },
    { label: "Anahtar Teslim Hizmetler", href: "/hizmetler/anahtar-teslim" },
    { label: "Villa Yenileme" }
  ]}
  structuredData={[serviceSchema, faqSchema]}
>

  <!-- Proje Görselleri -->
  <div class="w-full mb-12 grid grid-cols-1 md:grid-cols-3 gap-3">
    <img src={optimizedImage('/images/salon8.jpeg')} alt="Villa yenileme — salon görünüm güncellemesi" class="w-full h-64 object-cover" loading="lazy" decoding="async" />
    <img src={optimizedImage('/images/yatakodasi1.jpeg')} alt="Villa yenileme — yatak odası yenileme" class="w-full h-64 object-cover" loading="lazy" decoding="async" />
    <img src={optimizedImage('/images/mutfak4.jpeg')} alt="Villa yenileme — mutfak yenileme" class="w-full h-64 object-cover" loading="lazy" decoding="async" />
  </div>

  <!-- Scope -->
  <div class="grid md:grid-cols-2 gap-12 py-12 border-b border-border">
    <div>
      <h2 class="font-display text-3xl font-bold text-charcoal mb-4">Villa Yenileme Hizmetimiz</h2>
      <p class="text-muted leading-relaxed mb-4">
        Villa yenilemesi; elektrik, tesisat ve yapısal sisteme dokunmadan villanın iç mekan malzeme, kaplama ve estetik görünümünü güncellemek demektir. Doğal taş zemin değişimi, duvar kaplama yenilemesi, mutfak donanımı güncelleme ve özel mobilya tasarımı gibi işleri kapsar. Lüks segmentte malzeme kalitesi tasarım kararları kadar belirleyicidir.
      </p>
      <p class="text-muted leading-relaxed mb-4">
        Altyapı sorunu olmayan ama görünümü eskimiş veya stil değişikliği isteyen villa sahipleri için yenileme çok daha hızlı ve ekonomik bir seçenektir. <a href="/hizmetler/3d-tasarim" class="text-gold hover:underline">3D görselleştirme</a> ile yeni görünümü uygulamadan önce onaylayabilirsiniz.
      </p>
      <p class="text-muted leading-relaxed">
        Altyapı sorunu varsa veya yapısal değişiklik gerekiyorsa <a href="/hizmetler/anahtar-teslim/villa-tadilat" class="text-gold hover:underline">villa tadilat</a> hizmetimiz daha uygun seçenek olacaktır. İstanbul genelinde Zekeriyaköy, Acıbadem, Sarıyer, Beşiktaş ve Boğaz hattı boyunca hizmet veriyoruz.
      </p>
    </div>
    <div>
      <h3 class="font-semibold text-charcoal mb-4 text-xs uppercase tracking-wider">Hizmete Dahil Olanlar</h3>
      <ul class="space-y-3">
        {[
          'İç mimari konsept ve malzeme danışmanlığı',
          'Fotorealistik 3D görselleştirme',
          'Premium zemin kaplama değişimi',
          'Duvar kaplama ve boya yenileme',
          'Mutfak donanımı ve yüzey güncellemesi',
          'Banyo armatür ve aksesuar yenileme',
          'Aydınlatma tasarımı ve armatür değişimi',
          'Son temizlik ve anahtar teslim',
        ].map(item => (
          <li class="flex items-start gap-3 text-sm text-muted">
            <span class="w-4 h-4 mt-0.5 shrink-0 bg-gold/15 rounded-full flex items-center justify-center">
              <svg class="w-2.5 h-2.5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Ne Değişir -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-8">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Villa Yenileme ile Ne Değişir?</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      {[
        {
          title: 'Malzeme Kalitesi Lüks Deneyimi Belirler',
          desc: 'Doğal taş, ahşap parke veya İtalyan seramik gibi premium zemin malzemeleri ile mermer veya travertenin duvarlarda kullanımı villanın genel ambiyansını köklü biçimde dönüştürür. Altyapıya dokunmadan yalnızca malzeme güncellemesiyle lüks hissi çok daha güçlendirilebilir.',
        },
        {
          title: 'Aydınlatma Atmosferi Yeniden Kurgular',
          desc: 'Geniş villa alanlarında doğru aydınlatma tasarımı mekanı bölgelendirir ve her alanın atmosferini ayrı ayrı şekillendirir. Sarkıt aydınlatmalar, duvar aplikleri ve zemin spot kombinasyonu yapısal değişiklik olmadan dramtik bir görünüm dönüşümü sağlar.',
        },
        {
          title: 'Mutfak ve Banyo Hızla Modernleşiyor',
          desc: 'Altyapıya dokunmadan tezgah, dolap kapağı ve armatür değişimi ile mutfak ve banyo günümüz trendlerine kavuşabilir. Lüks segmentte bu güncellemeler hem yaşam kalitesini hem de mülk değerini olumlu etkiler.',
        },
      ].map(item => (
        <div class="bg-white p-6 border border-border">
          <h3 class="font-semibold text-charcoal mb-3 text-sm">{item.title}</h3>
          <p class="text-muted text-sm leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Process -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-8">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Villa Yenileme Sürecimiz</h2>
    </div>
    <div class="grid md:grid-cols-5 gap-6">
      {[
        { step: '01', title: 'Ücretsiz Keşif', desc: 'Villanın mevcut durumunu ve yenileme hedeflerini yerinde değerlendiriyoruz. Tadilat mı yenileme mi gerektiğini de bu aşamada birlikte belirleyebiliriz.' },
        { step: '02', title: '3D Tasarım', desc: 'Tüm alanları fotorealistik görsellerle deneyimleyin ve onaylayın. Lüks malzeme seçimleri 3D üzerinde karşılaştırmalı olarak sunulur.' },
        { step: '03', title: 'Sözleşme', desc: 'Kesin bütçe, kapsam ve takvim belirlenerek sözleşme imzalanır. Premium malzeme tedarik süreleri takvime dahil edilir.' },
        { step: '04', title: 'Uygulama', desc: 'Şantiye yönetimi ve usta koordinasyonu tamamen bizde. Haftalık ilerleme raporuyla her aşamada bilgilendiriyoruz.' },
        { step: '05', title: 'Teslim', desc: 'Final temizliği tamamlanmış, yenilenmiş villanızı teslim alırsınız. İşçilik garantisi sözleşmede belirtilir.' },
      ].map(item => (
        <div class="text-center">
          <div class="w-12 h-12 bg-gold/10 rounded-full flex items-center justify-center mx-auto mb-3">
            <span class="text-gold font-display font-bold text-sm">{item.step}</span>
          </div>
          <h3 class="font-semibold text-charcoal text-sm mb-2">{item.title}</h3>
          <p class="text-muted text-xs leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Service Areas -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Hizmet Verdiğimiz İlçeler</h2>
    </div>
    <div class="flex flex-wrap gap-2">
      {['Zekeriyaköy', 'Sarıyer', 'Beşiktaş', 'Acıbadem', 'Levent', 'Nişantaşı', 'Ataşehir', 'Şişli', 'Üsküdar', 'Bakırköy', 'Kadıköy', 'Maltepe'].map(ilce => (
        <span class="px-3 py-1.5 border border-border text-charcoal text-xs font-medium">{ilce}</span>
      ))}
    </div>
  </div>

  <!-- FAQ -->
  <div class="py-12">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Sık Sorulan Sorular</h2>
    </div>
    <div class="divide-y divide-border">
      {[
        { q: 'Villa yenileme ne kadar sürer?', a: 'Yapısal müdahale içermeyen bir villa yenilemesi kapsamına bağlı olarak 6–14 hafta içinde tamamlanabilir. Yalnızca iç mekan kaplama ve aydınlatma güncellemesi yapılıyorsa bu süre daha kısa olabilir. Komple villa yenilemelerinde malzeme temin ve işçilik takvimi önceden netleştirilir.' },
        { q: 'Villa yenileme ile tadilat arasındaki fark nedir?', a: 'Villa yenilemesi; altyapıya dokunmadan estetik ve malzeme güncellemesi yapmayı kapsar — zemin, kaplama, boya, armatür ve aydınlatma değişimi gibi işler. Villa tadilat ise elektrik, tesisat, yapısal duvar müdahalesi ve dış cephe onarımı gibi teknik altyapı işlerini içerir. Villanızın altyapısı sorunsuzsa yenileme çok daha hızlı ve ekonomik bir seçenektir.' },
        { q: 'Yenileme süresince villada oturabilir miyim?', a: 'Kısmi villa yenilemesinde — örneğin yalnızca zemin katı veya belirli odalar yenileniyorsa — villada oturmak mümkün olabilir. Komple villa yenilemesinde ise zemin, boyama ve tüm kat çalışmaları eş zamanlı yürütüleceğinden geçici taşınma daha verimli olur. Her projenin planlamasında bu konuyu müşterimizle önceden değerlendiriyoruz.' },
        { q: 'Villa yenileme bütçesi nasıl belirlenir?', a: 'Bütçe; villanın büyüklüğü, yenileme kapsamı ve seçilen malzeme kalitesine göre belirlenir. Lüks segmentte premium malzeme seçimleri bütçeyi önemli ölçüde etkiler; bu nedenle teklif aşamasında materyal seçimlerini önceden netleştiriyoruz. Ücretsiz keşif ziyaretimizde şeffaf ve detaylı bütçe sunuyoruz.' },
        { q: 'Villa yenilemede bahçe ve dış cephe dahil mi?', a: 'Dış cephe boyası ve bahçe düzenlemesi gibi yüzeysel güncellemeler yenileme kapsamında değerlendirilebilir. Yapısal dış cephe onarımı veya kapsamlı peyzaj projesi gerekiyorsa bu işler villa tadilat kapsamına girer. Keşif aşamasında projenizin tam kapsamını birlikte belirliyoruz.' },
      ].map((faq, i) => (
        <details class="group py-5" open={i === 0}>
          <summary class="flex items-start justify-between cursor-pointer list-none gap-4">
            <h3 class="font-semibold text-charcoal text-sm md:text-base group-open:text-gold transition-colors">{faq.q}</h3>
            <svg class="shrink-0 w-5 h-5 text-gold mt-0.5 group-open:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <p class="mt-3 text-muted text-sm leading-relaxed pr-8">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>

</ServiceLayout>
