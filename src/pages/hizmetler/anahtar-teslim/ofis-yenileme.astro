---
import ServiceLayout from '../../../layouts/ServiceLayout.astro';
import { CANONICAL_BASE } from '../../../config';
import { optimizedImage } from '../../../lib/cloudinary';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Ofis Yenileme",
  "name": "İstanbul Ofis Yenileme",
  "description": "İstanbul'da anahtar teslim ofis yenileme. Yapısal müdahale gerektirmeyen estetik güncelleme, kaplama yenileme ve kurumsal görünüm tazelemesi.",
  "provider": { "@type": "Organization", "@id": `${CANONICAL_BASE}/#organization`, "name": "Master İç Mimarlık" },
  "areaServed": { "@type": "City", "name": "İstanbul" },
  "url": `${CANONICAL_BASE}/hizmetler/anahtar-teslim/ofis-yenileme`,
  "offers": { "@type": "Offer", "priceCurrency": "TRY", "description": "Ücretsiz keşif ve özel teklif için iletişime geçin", "availability": "https://schema.org/InStock" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Ofis yenileme ne kadar sürer?", "acceptedAnswer": { "@type": "Answer", "text": "Yapısal müdahale içermeyen bir ofis yenileme projesi (100–200 m²) genellikle 2–4 hafta içinde tamamlanabilir. Yalnızca boyama ve zemin değişimi gibi minimal projeler 1 haftada bitebilir. Hafta sonu ve mesai dışı çalışma ile iş sürekliliği korunur." } },
    { "@type": "Question", "name": "Ofis yenileme ile tadilat arasındaki fark nedir?", "acceptedAnswer": { "@type": "Answer", "text": "Yenileme; mevcut elektrik, tesisat ve bölme sistemlerine dokunmadan estetik güncelleme yapmak demektir — zemin, boya, aydınlatma armatürleri ve mobilya gibi görünür unsurları kapsar. Tadilat ise altyapı değişikliği, duvar müdahalesi ve teknik sistem yenilemesi gerektirir. Ofisinizin altyapısı sorunsuzsa yenileme çok daha hızlı ve ekonomik bir seçenektir." } },
    { "@type": "Question", "name": "Çalışanlar ofiste çalışırken yenileme yapılabilir mi?", "acceptedAnswer": { "@type": "Answer", "text": "Ofis yenilemesi yapısal müdahale içermediğinden çoğunlukla ofis açıkken yapılabilir. Alan alan ilerleyen bir takvimle çalışanları minimumda etkileyerek ilerliyoruz. Zemin veya boyama gibi kapsamlı işler için hafta sonu çalışmayı tercih eden müşterilerimize de bu seçeneği sunuyoruz." } },
    { "@type": "Question", "name": "Ofis yenileme bütçesi nasıl belirlenir?", "acceptedAnswer": { "@type": "Answer", "text": "Bütçe; ofisin büyüklüğü, seçilen malzeme kalitesi ve yenileme kapsamına göre belirlenir. Altyapı müdahalesi olmadığından yenileme, tadilata kıyasla çok daha ekonomiktir. Ücretsiz keşif ziyaretimizde tüm kalemleri içeren şeffaf bir teklif sunuyoruz." } }
  ]
};
---

<ServiceLayout
  title="İstanbul Ofis Yenileme | Hızlı Kurumsal Görünüm Güncelleme | Master İç Mimarlık"
  description="İstanbul'da ofis yenileme. Altyapıya dokunmadan hızlı ve ekonomik kurumsal görünüm tazelemesi. Levent, Maslak, Beşiktaş. Ücretsiz keşif: 0533 039 15 65"
  canonicalUrl={`${CANONICAL_BASE}/hizmetler/anahtar-teslim/ofis-yenileme`}
  h1="İstanbul Ofis Yenileme"
  eyebrow="Anahtar Teslim"
  lead="Altyapısı sağlam ama görünümü eskimiş ofisler için hızlı ve ekonomik çözüm. Zemin, boya, aydınlatma ve mobilya güncellemeleriyle ofisinizin kurumsal kimliğini altyapıya dokunmadan tazeliyoruz."
  breadcrumb={[
    { label: "Ana Sayfa", href: "/" },
    { label: "Hizmetler", href: "/#hizmetler" },
    { label: "Anahtar Teslim Hizmetler", href: "/hizmetler/anahtar-teslim" },
    { label: "Ofis Yenileme" }
  ]}
  structuredData={[serviceSchema, faqSchema]}
>

  <!-- Proje Görselleri -->
  <div class="w-full mb-12 grid grid-cols-1 md:grid-cols-2 gap-3">
    <img src={optimizedImage('/images/ofis2.jpeg')} alt="Ofis yenileme — kurumsal ofis görünüm güncellemesi" class="w-full h-64 object-cover" loading="lazy" decoding="async" />
    <img src={optimizedImage('/images/toplantiodasi1.jpeg')} alt="Ofis yenileme — toplantı odası tazeleme" class="w-full h-64 object-cover" loading="lazy" decoding="async" />
  </div>

  <!-- Scope -->
  <div class="grid md:grid-cols-2 gap-12 py-12 border-b border-border">
    <div>
      <h2 class="font-display text-3xl font-bold text-charcoal mb-4">Ofis Yenileme Hizmetimiz</h2>
      <p class="text-muted leading-relaxed mb-4">
        Ofisinizin elektrik, tesisat ve bölme sistemleri işlevselliğini koruyorsa kapsamlı tadilat yerine daha hızlı ve ekonomik bir yenileme tercih edebilirsiniz. Zemin kaplaması, duvar rengi, aydınlatma armatürleri ve mobilya seçimleri gibi görünür unsurları güncelleyerek mekanı kısa sürede dönüştürüyoruz.
      </p>
      <p class="text-muted leading-relaxed mb-4">
        Kısmi yenileme de yapıyoruz: yalnızca toplantı odalarını mı tazelemek istiyorsunuz, yoksa resepsiyon alanını mı? Her ölçekte projeyi yönetiyoruz. <a href="/hizmetler/3d-tasarim" class="text-gold hover:underline">3D görselleştirme</a> ile yeni görünümü uygulama başlamadan onaylayabilirsiniz.
      </p>
      <p class="text-muted leading-relaxed">
        Altyapı sorunu varsa veya yapısal değişiklik gerekiyorsa <a href="/hizmetler/anahtar-teslim/ofis-tadilat" class="text-gold hover:underline">ofis tadilat</a> hizmetimiz daha uygun seçenek olabilir. Levent, Maslak, Beşiktaş, Şişli ve tüm İstanbul'da hizmet veriyoruz.
      </p>
    </div>
    <div>
      <h3 class="font-semibold text-charcoal mb-4 text-xs uppercase tracking-wider">Hizmete Dahil Olanlar</h3>
      <ul class="space-y-3">
        {[
          'Kurumsal konsept ve renk danışmanlığı',
          'Fotorealistik 3D görselleştirme',
          'Zemin kaplama yenileme',
          'Duvar boyama ve grafik uygulamaları',
          'Aydınlatma armatürü güncelleme',
          'Mobilya seçimi ve yerleşim optimizasyonu',
          'Akustik panel ve dekor güncellemesi',
          'Son temizlik ve anahtar teslim',
        ].map(item => (
          <li class="flex items-start gap-3 text-sm text-muted">
            <span class="w-4 h-4 mt-0.5 shrink-0 bg-gold/15 rounded-full flex items-center justify-center">
              <svg class="w-2.5 h-2.5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Ne Değişir -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-8">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Ofis Yenileme ile Ne Değişir?</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      {[
        {
          title: 'Kurumsal İmaj Güçleniyor',
          desc: 'Müşteri ziyaretlerinde ilk izlenimi belirleyen resepsiyon ve toplantı odaları, güncel malzeme ve renk paleti ile çok daha profesyonel bir görünüm kazanır. Büyük bir tadilat olmadan kurumsal kimliği mekan deneyimine yansıtmak mümkündür.',
        },
        {
          title: 'Çalışan Memnuniyeti Artıyor',
          desc: 'Eskimiş zemin, soluk duvar rengi ve yetersiz aydınlatma ekip motivasyonunu olumsuz etkiler. Doğru renk ve ışık tercihleriyle ofisin genel ambiyansı yükseltildiğinde çalışan memnuniyeti ve verimliliği de olumlu etkilenir.',
        },
        {
          title: 'Hızlı Sonuç, Minimum Kesinti',
          desc: 'Ofis yenilemesi yapısal müdahale içermediğinden proje süreci çok daha kısadır. Alan alan ilerleyen takvim sayesinde çalışmalar büyük ölçüde ofis saatleri dışında tamamlanabilir, iş sürekliliği korunur.',
        },
      ].map(item => (
        <div class="bg-white p-6 border border-border">
          <h3 class="font-semibold text-charcoal mb-3 text-sm">{item.title}</h3>
          <p class="text-muted text-sm leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Process -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-8">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Ofis Yenileme Sürecimiz</h2>
    </div>
    <div class="grid md:grid-cols-5 gap-6">
      {[
        { step: '01', title: 'Ücretsiz Keşif', desc: 'Ofisinizin mevcut durumunu ve yenileme hedeflerini yerinde değerlendiriyoruz. Tadilat mı yenileme mi gerektiğini de bu aşamada birlikte belirliyoruz.' },
        { step: '02', title: 'Tasarım & 3D', desc: 'Kurumsal kimliğinize uygun renk ve malzeme seçimlerini 3D ile görselleştiriyoruz. Onay alındıktan sonra uygulamaya geçilir.' },
        { step: '03', title: 'Sözleşme', desc: 'Kesin bütçe ve takvim belirlenerek sözleşme imzalanır. Yenileme projeleri daha kısa ve öngörülebilir takvimle ilerler.' },
        { step: '04', title: 'Uygulama', desc: 'Alan alan ilerleyen takvimle minimum kesinti sağlanır. Çalışmalar mümkün olduğunda mesai dışı saatlerde yürütülür.' },
        { step: '05', title: 'Teslim', desc: 'Hazır ofisinizi teslim alıp operasyona devam ediyorsunuz. İşçilik garantisi sözleşmede belirtilir.' },
      ].map(item => (
        <div class="text-center">
          <div class="w-12 h-12 bg-gold/10 rounded-full flex items-center justify-center mx-auto mb-3">
            <span class="text-gold font-display font-bold text-sm">{item.step}</span>
          </div>
          <h3 class="font-semibold text-charcoal text-sm mb-2">{item.title}</h3>
          <p class="text-muted text-xs leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Service Areas -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Hizmet Verdiğimiz İlçeler</h2>
    </div>
    <div class="flex flex-wrap gap-2">
      {['Levent', 'Maslak', 'Beşiktaş', 'Şişli', 'Kadıköy', 'Ataşehir', 'Nişantaşı', 'Sarıyer', 'Üsküdar', 'Bakırköy', 'Maltepe', 'Ümraniye'].map(ilce => (
        <span class="px-3 py-1.5 border border-border text-charcoal text-xs font-medium">{ilce}</span>
      ))}
    </div>
  </div>

  <!-- FAQ -->
  <div class="py-12">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Sık Sorulan Sorular</h2>
    </div>
    <div class="divide-y divide-border">
      {[
        { q: 'Ofis yenileme ne kadar sürer?', a: 'Yapısal müdahale içermeyen bir ofis yenileme projesi (100–200 m²) genellikle 2–4 hafta içinde tamamlanabilir. Yalnızca boyama ve zemin değişimi gibi minimal projeler 1 haftada bitebilir. Hafta sonu ve mesai dışı çalışma ile iş sürekliliği korunur.' },
        { q: 'Ofis yenileme ile tadilat arasındaki fark nedir?', a: 'Yenileme; mevcut elektrik, tesisat ve bölme sistemlerine dokunmadan estetik güncelleme yapmak demektir — zemin, boya, aydınlatma armatürleri ve mobilya gibi görünür unsurları kapsar. Tadilat ise altyapı değişikliği, duvar müdahalesi ve teknik sistem yenilemesi gerektirir. Ofisinizin altyapısı sorunsuzsa yenileme çok daha hızlı ve ekonomik bir seçenektir.' },
        { q: 'Çalışanlar ofiste çalışırken yenileme yapılabilir mi?', a: 'Ofis yenilemesi yapısal müdahale içermediğinden çoğunlukla ofis açıkken yapılabilir. Alan alan ilerleyen bir takvimle çalışanları minimumda etkileyerek ilerliyoruz. Zemin veya boyama gibi kapsamlı işler için hafta sonu çalışmayı tercih eden müşterilerimize de bu seçeneği sunuyoruz.' },
        { q: 'Ofis yenileme bütçesi nasıl belirlenir?', a: 'Bütçe; ofisin büyüklüğü, seçilen malzeme kalitesi ve yenileme kapsamına göre belirlenir. Altyapı müdahalesi olmadığından yenileme, tadilata kıyasla çok daha ekonomiktir. Ücretsiz keşif ziyaretimizde tüm kalemleri içeren şeffaf bir teklif sunuyoruz.' },
      ].map((faq, i) => (
        <details class="group py-5" open={i === 0}>
          <summary class="flex items-start justify-between cursor-pointer list-none gap-4">
            <h3 class="font-semibold text-charcoal text-sm md:text-base group-open:text-gold transition-colors">{faq.q}</h3>
            <svg class="shrink-0 w-5 h-5 text-gold mt-0.5 group-open:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <p class="mt-3 text-muted text-sm leading-relaxed pr-8">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>

</ServiceLayout>
