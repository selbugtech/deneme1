---
import ServiceLayout from '../../../layouts/ServiceLayout.astro';
import { CANONICAL_BASE } from '../../../config';
import { optimizedImage } from '../../../lib/cloudinary';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Villa Tadilat",
  "name": "İstanbul Villa Tadilat",
  "description": "İstanbul'da anahtar teslim villa tadilat. Lüks villalarda kapsamlı iç mimari tasarım, yapısal dönüşüm ve anahtar teslim uygulama hizmetleri.",
  "provider": { "@type": "Organization", "@id": `${CANONICAL_BASE}/#organization`, "name": "Master İç Mimarlık" },
  "areaServed": [
    { "@type": "City", "name": "İstanbul" },
    { "@type": "AdministrativeArea", "name": "Zekeriyaköy" },
    { "@type": "AdministrativeArea", "name": "Acıbadem" },
    { "@type": "AdministrativeArea", "name": "Sarıyer" }
  ],
  "url": `${CANONICAL_BASE}/hizmetler/anahtar-teslim/villa-tadilat`,
  "offers": { "@type": "Offer", "priceCurrency": "TRY", "description": "Ücretsiz keşif ve özel teklif için iletişime geçin", "availability": "https://schema.org/InStock" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Villa tadilat bütçesi nasıl belirlenir?", "acceptedAnswer": { "@type": "Answer", "text": "Bütçe; villanın büyüklüğü, mevcut yapı durumu, bahçe ve dış cephe kapsamı ile seçilen malzeme kalitesine göre belirlenir. Ücretsiz keşif ziyaretimizde projenize özel bütçe sunuyoruz." } },
    { "@type": "Question", "name": "Villa tadilat ne kadar sürer?", "acceptedAnswer": { "@type": "Answer", "text": "Ortalama bir villa tadilatı (250–400 m²) 10–20 hafta içinde tamamlanmaktadır. Kapsamlı yapısal değişiklikler veya ruhsat gerektiren işler süreci uzatabilir. Sözleşmede kesin takvim belirlenir." } },
    { "@type": "Question", "name": "Tadilat süresince villada oturabilir miyim?", "acceptedAnswer": { "@type": "Answer", "text": "Komple villa tadilat çalışmalarında villada oturmanızı tavsiye etmiyoruz. Kısmi tadilatlarda (belirli kat veya bölümler) mümkün olabilir. Her projenin planlamasında bu konuyu müşterimizle önceden değerlendiriyoruz." } },
    { "@type": "Question", "name": "Villa tadilatta bahçe ve dış cephe dahil mi?", "acceptedAnswer": { "@type": "Answer", "text": "Evet. Villa projelerinde iç mekânın yanı sıra bahçe düzenlemesi, dış cephe tadilat ve teras tasarımı da proje kapsamına dahil edilebilir. Keşif aşamasında projenizin tüm kapsamını birlikte belirliyoruz." } }
  ]
};
---

<ServiceLayout
  title="İstanbul Villa Tadilat | Anahtar Teslim Villa Tadilat | Master İç Mimarlık"
  description="İstanbul'da anahtar teslim villa tadilat. Zekeriyaköy, Acıbadem, Sarıyer ve tüm İstanbul'da lüks villa tadilat ve iç mimari tasarım. Ücretsiz keşif: 0533 039 15 65"
  canonicalUrl={`${CANONICAL_BASE}/hizmetler/anahtar-teslim/villa-tadilat`}
  h1="İstanbul Villa Tadilat"
  eyebrow="Anahtar Teslim"
  lead="Lüks villalar için kapsamlı iç mimari tasarım ve anahtar teslim tadilat. Yapısal dönüşümden bahçe düzenlemesine, dış cephe tadilattan özel mobilya tasarımına kadar villanızın her detayını titizlikle planlıyoruz."
  breadcrumb={[
    { label: "Ana Sayfa", href: "/" },
    { label: "Hizmetler", href: "/#hizmetler" },
    { label: "Anahtar Teslim Hizmetler", href: "/hizmetler/anahtar-teslim" },
    { label: "Villa Tadilat" }
  ]}
  structuredData={[serviceSchema, faqSchema]}
>

  <!-- Proje Görselleri -->
  <div class="w-full mb-12 grid grid-cols-1 md:grid-cols-3 gap-3">
    <img src={optimizedImage('/images/salon8.jpeg')} alt="Villa tadilat — salon tasarımı" class="w-full h-64 object-cover" loading="lazy" decoding="async" />
    <img src={optimizedImage('/images/yatakodasi1.jpeg')} alt="Villa tadilat — yatak odası tasarımı" class="w-full h-64 object-cover" loading="lazy" decoding="async" />
    <img src={optimizedImage('/images/mutfak4.jpeg')} alt="Villa tadilat — mutfak tadilat" class="w-full h-64 object-cover" loading="lazy" decoding="async" />
  </div>

  <!-- Scope -->
  <div class="grid md:grid-cols-2 gap-12 py-12 border-b border-border">
    <div>
      <h2 class="font-display text-3xl font-bold text-charcoal mb-4">Villa Tadilat Hizmetimiz</h2>
      <p class="text-muted leading-relaxed mb-4">
        Villa tadilat, standart konut projelerinden farklı bir uzmanlık ve koordinasyon gerektiren kapsamlı bir süreçtir. Geniş alanlar, çoklu katlar, bahçe ve dış cephe entegrasyonu, ruhsat süreçleri ve yapısal müdahaleler bu sürecin ayrılmaz parçalarıdır.
      </p>
      <p class="text-muted leading-relaxed mb-4">
        Master İç Mimarlık olarak villa projelerinde iç mekândan dış cepheye, mutfak ve banyo tadilattan özel mobilya tasarımına kadar projenizin tüm kapsamını tek çatı altında yönetiyoruz.
      </p>
      <p class="text-muted leading-relaxed">
        İstanbul genelinde Zekeriyaköy, Acıbadem, Sarıyer, Beşiktaş ve Boğaz hattı boyunca villa tadilat hizmeti sunuyoruz.
      </p>
    </div>
    <div>
      <h3 class="font-semibold text-charcoal mb-4 text-xs uppercase tracking-wider">Hizmete Dahil Olanlar</h3>
      <ul class="space-y-3">
        {[
          'İç mimari konsept tasarım',
          'Fotorealistik 3D görselleştirme',
          'Yapısal dönüşüm ve duvar müdahaleleri',
          'Elektrik ve tesisat tadilat',
          'Mutfak ve banyo tadilat',
          'Zemin, duvar ve tavan kaplamaları',
          'Dış cephe ve bahçe koordinasyonu',
          'Son temizlik ve anahtar teslim',
        ].map(item => (
          <li class="flex items-start gap-3 text-sm text-muted">
            <span class="w-4 h-4 mt-0.5 shrink-0 bg-gold/15 rounded-full flex items-center justify-center">
              <svg class="w-2.5 h-2.5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Process -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-8">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Villa Tadilat Sürecimiz</h2>
    </div>
    <div class="grid md:grid-cols-5 gap-6">
      {[
        { step: '01', title: 'Ücretsiz Keşif', desc: 'Villayı yerinde inceliyor, yapısal durumu ve ihtiyaçları değerlendiriyoruz.' },
        { step: '02', title: '3D Tasarım', desc: 'Tüm alanları fotorealistik görsellerle deneyimleyin ve onaylayın.' },
        { step: '03', title: 'Sözleşme', desc: 'Kesin bütçe, kapsam ve takvim belirlenerek sözleşme imzalanır.' },
        { step: '04', title: 'Uygulama', desc: 'Şantiye yönetimi ve tüm usta koordinasyonu bizde. Düzenli raporlama yapıyoruz.' },
        { step: '05', title: 'Teslim', desc: 'Final temizliği tamamlanmış, eksiksiz villanızı teslim alırsınız.' },
      ].map(item => (
        <div class="text-center">
          <div class="w-12 h-12 bg-gold/10 rounded-full flex items-center justify-center mx-auto mb-3">
            <span class="text-gold font-display font-bold text-sm">{item.step}</span>
          </div>
          <h3 class="font-semibold text-charcoal text-sm mb-2">{item.title}</h3>
          <p class="text-muted text-xs leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Service Areas -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Hizmet Verdiğimiz İlçeler</h2>
    </div>
    <div class="flex flex-wrap gap-2">
      {['Zekeriyaköy', 'Sarıyer', 'Beşiktaş', 'Acıbadem', 'Levent', 'Nişantaşı', 'Ataşehir', 'Şişli', 'Üsküdar', 'Bakırköy', 'Kadıköy', 'Maltepe'].map(ilce => (
        <span class="px-3 py-1.5 border border-border text-charcoal text-xs font-medium">{ilce}</span>
      ))}
    </div>
  </div>

  <!-- FAQ -->
  <div class="py-12">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Sık Sorulan Sorular</h2>
    </div>
    <div class="divide-y divide-border">
      {[
        { q: 'Villa tadilat bütçesi nasıl belirlenir?', a: 'Bütçe; villanın büyüklüğü, mevcut yapı durumu, bahçe ve dış cephe kapsamı ile seçilen malzeme kalitesine göre belirlenir. Ücretsiz keşif ziyaretimizde projenize özel bütçe sunuyoruz.' },
        { q: 'Villa tadilat ne kadar sürer?', a: 'Ortalama bir villa tadilatı (250–400 m²) 10–20 hafta içinde tamamlanmaktadır. Yapısal değişiklikler veya ruhsat gerektiren işler bu süreyi uzatabilir. Sözleşmede kesin takvim belirlenir.' },
        { q: 'Tadilat süresince villada oturabilir miyim?', a: 'Komple villa tadilat çalışmalarında villada oturmanızı tavsiye etmiyoruz. Kısmi tadilatlarda (belirli kat veya bölümler) mümkün olabilir. Her projenin planlamasında bu konuyu müşterimizle önceden değerlendiriyoruz.' },
        { q: 'Villa tadilatta bahçe ve dış cephe dahil mi?', a: 'Evet. Villa projelerinde iç mekânın yanı sıra bahçe düzenlemesi, dış cephe tadilat ve teras tasarımı da proje kapsamına dahil edilebilir. Keşif aşamasında projenizin tüm kapsamını birlikte belirliyoruz.' },
      ].map((faq, i) => (
        <details class="group py-5" open={i === 0}>
          <summary class="flex items-start justify-between cursor-pointer list-none gap-4">
            <h3 class="font-semibold text-charcoal text-sm md:text-base group-open:text-gold transition-colors">{faq.q}</h3>
            <svg class="shrink-0 w-5 h-5 text-gold mt-0.5 group-open:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <p class="mt-3 text-muted text-sm leading-relaxed pr-8">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>

</ServiceLayout>
