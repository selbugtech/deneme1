---
import ServiceLayout from '../../../layouts/ServiceLayout.astro';
import { CANONICAL_BASE } from '../../../config';
import { optimizedImage } from '../../../lib/cloudinary';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Mağaza ve Dükkan Tadilat",
  "name": "İstanbul Mağaza ve Dükkan Tadilat",
  "description": "İstanbul'da anahtar teslim mağaza ve dükkan tadilat. Elektrik, tesisat, vitrin sistemi ve yapısal müdahale dahil kapsamlı perakende mekan dönüşümü.",
  "provider": { "@type": "Organization", "@id": `${CANONICAL_BASE}/#organization`, "name": "Master İç Mimarlık" },
  "areaServed": { "@type": "City", "name": "İstanbul" },
  "url": `${CANONICAL_BASE}/hizmetler/anahtar-teslim/magaza-dukkan-tadilat`,
  "offers": { "@type": "Offer", "priceCurrency": "TRY", "description": "Ücretsiz keşif ve özel teklif için iletişime geçin", "availability": "https://schema.org/InStock" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Mağaza tadilat ne kadar sürer?", "acceptedAnswer": { "@type": "Answer", "text": "Ortalama bir mağaza tadilatı (60–150 m²) 4–7 hafta içinde tamamlanmaktadır. Elektrik altyapısı güçlendirme veya yapısal müdahale gerektiren projeler daha uzun sürebilir. Kapalı kalma süresini minimize etmek için detaylı uygulama planı oluşturuyoruz." } },
    { "@type": "Question", "name": "Mağaza tadilat bütçesi nasıl belirlenir?", "acceptedAnswer": { "@type": "Answer", "text": "Bütçe; mekanın büyüklüğü, mevcut yapı ve altyapı durumu ile seçilen malzeme kalitesine göre belirlenir. Vitrin sistemi değişimi, elektrik güçlendirme ve zemin yenileme gibi kapsamlı işler maliyeti artırır. Ücretsiz keşif ziyaretimizde projenize özel şeffaf bütçe sunuyoruz." } },
    { "@type": "Question", "name": "Hangi mağaza türleri için hizmet veriyorsunuz?", "acceptedAnswer": { "@type": "Answer", "text": "Giyim mağazaları, butikler, eczaneler, güzellik salonları, elektronik mağazaları, spor malzemeleri ve her türlü perakende mekan için hizmet veriyoruz. Her sektörün kendine özgü ürün sergileme ve müşteri deneyimi ihtiyaçlarını dikkate alıyoruz." } },
    { "@type": "Question", "name": "Tadilat süresince mağaza açık kalabilir mi?", "acceptedAnswer": { "@type": "Answer", "text": "Elektrik altyapısı veya vitrin değişimi gibi kapsamlı işlerde kısa süreli kapanma gerekebilir. Kısmi tadilatlarda bölgeli uygulama ile mağazayı açık tutmak mümkündür. Kapalı kalma süresini minimize edecek en verimli takvimi keşif ziyaretimizde birlikte planlıyoruz." } }
  ]
};
---

<ServiceLayout
  title="İstanbul Mağaza ve Dükkan Tadilat"
  description="İstanbul'da mağaza ve dükkan tadilat. Elektrik, vitrin sistemi ve yapısal müdahale dahil kapsamlı perakende mekan dönüşümü. Nişantaşı, Levent, Kadıköy. Ücretsiz keşif: 0533 039 15 65"
  canonicalUrl={`${CANONICAL_BASE}/hizmetler/anahtar-teslim/magaza-dukkan-tadilat`}
  h1="İstanbul Mağaza ve Dükkan Tadilat"
  eyebrow="Anahtar Teslim"
  lead="Elektrik altyapısından vitrin sistemine, zemin değişiminden yapısal düzenlemeye kadar teknik müdahale gerektiren kapsamlı mağaza dönüşümleri. Marka kimliğini yansıtan, müşteri yolculuğunu optimize eden perakende mekanlar."
  breadcrumb={[
    { label: "Ana Sayfa", href: "/" },
    { label: "Hizmetler", href: "/#hizmetler" },
    { label: "Anahtar Teslim Hizmetler", href: "/hizmetler/anahtar-teslim" },
    { label: "Mağaza & Dükkan Tadilat" }
  ]}
  structuredData={[serviceSchema, faqSchema]}
>

  <!-- Proje Görselleri -->
  <div class="w-full mb-12 grid grid-cols-1 md:grid-cols-3 gap-3">
    <img src={optimizedImage('/images/salon3.jpeg')} alt="Mağaza ve dükkan tadilat — ticari mekan dönüşümü" class="w-full h-64 object-cover" loading="lazy" decoding="async" />
    <img src={optimizedImage('/images/salonvemutfak.jpeg')} alt="Mağaza ve dükkan tadilat — iç mekan tasarımı" class="w-full h-64 object-cover" loading="lazy" decoding="async" />
    <img src={optimizedImage('/images/merdiven1.jpeg')} alt="Mağaza ve dükkan tadilat — yapısal detay" class="w-full h-64 object-cover" loading="lazy" decoding="async" />
  </div>

  <!-- Scope -->
  <div class="grid md:grid-cols-2 gap-12 py-12 border-b border-border">
    <div>
      <h2 class="font-display text-3xl font-bold text-charcoal mb-4">Mağaza & Dükkan Tadilat Hizmetimiz</h2>
      <p class="text-muted leading-relaxed mb-4">
        Mağaza tadilat; yalnızca yeni bir boya veya raf değişimini değil, elektrik altyapısının güçlendirilmesini, vitrin sisteminin yenilenmesini, zemin ve duvar kaplama değişimini ya da mekânın baştan kurgulanmasını kapsayabilir. Özellikle farklı bir sektörden devralınan veya eski bir mekânda açılan mağazalar bu tür kapsamlı müdahale gerektirir.
      </p>
      <p class="text-muted leading-relaxed mb-4">
        Vitrin tasarımından iç mekana, ürün raflarından kasa alanına kadar tüm detayları marka kimliğiniz ve satış hedeflerinize göre optimize ediyoruz. <a href="/hizmetler/3d-tasarim" class="text-gold hover:underline">3D görselleştirme</a> ile mağazanın yeni görünümünü uygulamadan önce onaylayabilirsiniz.
      </p>
      <p class="text-muted leading-relaxed">
        Yalnızca estetik güncelleme istiyorsanız <a href="/hizmetler/anahtar-teslim/magaza-dukkan-yenileme" class="text-gold hover:underline">mağaza yenileme</a> hizmetimiz daha hızlı ve ekonomik bir seçenek olabilir. Nişantaşı, Levent, Kadıköy, Beşiktaş ve tüm İstanbul'da hizmet veriyoruz.
      </p>
    </div>
    <div>
      <h3 class="font-semibold text-charcoal mb-4 text-xs uppercase tracking-wider">Hizmete Dahil Olanlar</h3>
      <ul class="space-y-3">
        {[
          'Marka kimliğine uygun konsept tasarım',
          'Fotorealistik 3D görselleştirme',
          'Elektrik altyapısı güçlendirme',
          'Vitrin ve ön cephe sistemi yenileme',
          'Ürün sergileme ve raf planlaması',
          'Müşteri yolculuğu optimizasyonu',
          'Ticari aydınlatma tasarımı',
          'Zemin, duvar ve tavan kaplamaları',
        ].map(item => (
          <li class="flex items-start gap-3 text-sm text-muted">
            <span class="w-4 h-4 mt-0.5 shrink-0 bg-gold/15 rounded-full flex items-center justify-center">
              <svg class="w-2.5 h-2.5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Ne Zaman Gerekir -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-8">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Mağaza Tadilat Ne Zaman Gerekir?</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      {[
        {
          title: 'Yeni veya Devralınan Mekan',
          desc: 'Farklı bir sektörden devralınan ya da ham haldeki bir mekan, perakende standartlarını karşılamak için kapsamlı tadilat gerektirir. Elektrik kapasitesi, vitrin sistemi ve müşteri trafik düzeni baştan kurgulanmalıdır.',
        },
        {
          title: 'Marka Yeniden Konumlandı',
          desc: 'Yenilenen marka kimliği mekanın fiziksel görünümüne de yansıtılmalıdır. Yalnızca tabela değişikliği yetmez; malzeme, renk ve alan kurgusu yeni konumlamayı desteklemezse marka yatırımının getirisi düşer.',
        },
        {
          title: 'Altyapı ve Güvenlik Sorunları',
          desc: 'Eski elektrik tesisatı, yetersiz aydınlatma altyapısı veya standart dışı vitrin sistemleri hem güvenlik riski oluşturur hem de mağaza deneyimini olumsuz etkiler. Bu tür sorunlar görünümü güncellemekle çözülemez.',
        },
      ].map(item => (
        <div class="bg-white p-6 border border-border">
          <h3 class="font-semibold text-charcoal mb-3 text-sm">{item.title}</h3>
          <p class="text-muted text-sm leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Process -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-8">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Mağaza Tadilat Sürecimiz</h2>
    </div>
    <div class="grid md:grid-cols-5 gap-6">
      {[
        { step: '01', title: 'Ücretsiz Keşif', desc: 'Mağazanızı, marka hedeflerinizi ve teknik altyapı durumunu yerinde değerlendiriyoruz. Gerekli izin ve müdahale kapsamı bu aşamada netleşir.' },
        { step: '02', title: 'Konsept & 3D', desc: 'Marka kimliğinize uygun tasarımı 3D ile görselleştiriyoruz. Ürün sergileme planı ve müşteri yolculuğu bu aşamada optimize edilir.' },
        { step: '03', title: 'Sözleşme', desc: 'Kesin bütçe ve takvim belirlenerek sözleşme imzalanır. Kapalı kalma süresi taahhüt edilir.' },
        { step: '04', title: 'Uygulama', desc: 'Hızlı ve verimli uygulama; kapalı süre minimumda tutulur. Teknik altyapı ve estetik işler paralel yürütülür.' },
        { step: '05', title: 'Teslim', desc: 'Hazır mağazanızı teslim alıp açılışa geçiyorsunuz. Teslim sonrası işçilik garantisi sözleşmede belirtilir.' },
      ].map(item => (
        <div class="text-center">
          <div class="w-12 h-12 bg-gold/10 rounded-full flex items-center justify-center mx-auto mb-3">
            <span class="text-gold font-display font-bold text-sm">{item.step}</span>
          </div>
          <h3 class="font-semibold text-charcoal text-sm mb-2">{item.title}</h3>
          <p class="text-muted text-xs leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Service Areas -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Hizmet Verdiğimiz İlçeler</h2>
    </div>
    <div class="flex flex-wrap gap-2">
      {['Nişantaşı', 'Levent', 'Kadıköy', 'Beşiktaş', 'Şişli', 'Bağcılar', 'Bakırköy', 'Ataşehir', 'Maltepe', 'Ümraniye', 'Sarıyer', 'Üsküdar'].map(ilce => (
        <span class="px-3 py-1.5 border border-border text-charcoal text-xs font-medium">{ilce}</span>
      ))}
    </div>
  </div>

  <!-- FAQ -->
  <div class="py-12">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Sık Sorulan Sorular</h2>
    </div>
    <div class="divide-y divide-border">
      {[
        { q: 'Mağaza tadilat ne kadar sürer?', a: 'Ortalama bir mağaza tadilatı (60–150 m²) 4–7 hafta içinde tamamlanmaktadır. Elektrik altyapısı güçlendirme veya yapısal müdahale gerektiren projeler daha uzun sürebilir. Kapalı kalma süresini minimize etmek için detaylı uygulama planı oluşturuyoruz.' },
        { q: 'Mağaza tadilat bütçesi nasıl belirlenir?', a: 'Bütçe; mekanın büyüklüğü, mevcut yapı ve altyapı durumu ile seçilen malzeme kalitesine göre belirlenir. Vitrin sistemi değişimi, elektrik güçlendirme ve zemin yenileme gibi kapsamlı işler maliyeti artırır. Ücretsiz keşif ziyaretimizde projenize özel şeffaf bütçe sunuyoruz.' },
        { q: 'Hangi mağaza türleri için hizmet veriyorsunuz?', a: 'Giyim mağazaları, butikler, eczaneler, güzellik salonları, elektronik mağazaları, spor malzemeleri ve her türlü perakende mekan için hizmet veriyoruz. Her sektörün kendine özgü ürün sergileme ve müşteri deneyimi ihtiyaçlarını dikkate alıyoruz.' },
        { q: 'Tadilat süresince mağaza açık kalabilir mi?', a: 'Elektrik altyapısı veya vitrin değişimi gibi kapsamlı işlerde kısa süreli kapanma gerekebilir. Kısmi tadilatlarda bölgeli uygulama ile mağazayı açık tutmak mümkündür. Kapalı kalma süresini minimize edecek en verimli takvimi keşif ziyaretimizde birlikte planlıyoruz.' },
      ].map((faq, i) => (
        <details class="group py-5" open={i === 0}>
          <summary class="flex items-start justify-between cursor-pointer list-none gap-4">
            <h3 class="font-semibold text-charcoal text-sm md:text-base group-open:text-gold transition-colors">{faq.q}</h3>
            <svg class="shrink-0 w-5 h-5 text-gold mt-0.5 group-open:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <p class="mt-3 text-muted text-sm leading-relaxed pr-8">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>

</ServiceLayout>
