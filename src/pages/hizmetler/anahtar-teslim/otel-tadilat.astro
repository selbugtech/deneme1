---
import ServiceLayout from '../../../layouts/ServiceLayout.astro';
import { CANONICAL_BASE } from '../../../config';
import { optimizedImage } from '../../../lib/cloudinary';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Otel Tadilat",
  "name": "İstanbul Otel Tadilat",
  "description": "İstanbul'da anahtar teslim otel tadilat. Elektrik, tesisat, yapısal müdahale ve iklimlendirme dahil kapsamlı otel renovasyonu. Operasyon sürerken fazlı uygulama.",
  "provider": { "@type": "Organization", "@id": `${CANONICAL_BASE}/#organization`, "name": "Master İç Mimarlık" },
  "areaServed": [
    { "@type": "City", "name": "İstanbul" },
    { "@type": "AdministrativeArea", "name": "Beyoğlu" },
    { "@type": "AdministrativeArea", "name": "Fatih" },
    { "@type": "AdministrativeArea", "name": "Beşiktaş" }
  ],
  "url": `${CANONICAL_BASE}/hizmetler/anahtar-teslim/otel-tadilat`,
  "offers": { "@type": "Offer", "priceCurrency": "TRY", "description": "Ücretsiz keşif ve özel teklif için iletişime geçin", "availability": "https://schema.org/InStock" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Otel tadilat sırasında faaliyet sürdürülebilir mi?", "acceptedAnswer": { "@type": "Answer", "text": "Evet. Otel operasyonunu kesintisiz sürdürmeniz için bölüm bölüm (fazlı) tadilat planı hazırlıyoruz. Her aşama tamamlandıkça ilgili bölümler hizmete geri döner; gelir kaybını minimize ederken tadilat sürer. Hangi bölümlerin hangi sırayla tadilat yapılacağı sözleşme aşamasında müşterimizle birlikte planlanır." } },
    { "@type": "Question", "name": "Otel tadilat ne kadar sürer?", "acceptedAnswer": { "@type": "Answer", "text": "Süre; otel büyüklüğü, kapsam ve fazlı çalışma planına göre değişir. Küçük butik oteller için tekil aşamalar 6–10 hafta, büyük kapsamlı projeler birkaç aşamada ve uzun bir takvimde tamamlanabilir. Tüm aşama takvimleri sözleşmede net olarak belirlenir ve taahhüt edilir." } },
    { "@type": "Question", "name": "Otel tadilat ROI'si nasıl ölçülür?", "acceptedAnswer": { "@type": "Answer", "text": "Otel tadilat yatırımının getirisi; doluluk oranı artışı, oda başına gelir (RevPAR) yükselmesi, ortalama oda fiyatı (ADR) artışı ve online platform misafir puanlarındaki iyileşmeyle ölçülür. Tasarım kararlarımızı yalnızca estetik değil, bu operasyonel metrikler gözetilerek alıyoruz." } },
    { "@type": "Question", "name": "Hangi otel alanları için hizmet veriyorsunuz?", "acceptedAnswer": { "@type": "Answer", "text": "Odalar ve banyolar, lobi ve resepsiyon, restoran ve bar alanları, toplantı ve konferans salonları, ortak kullanım alanları, dış cephe ve çevre düzenlemesi dahil otel genelinde kapsamlı tadilat yapıyoruz. Her alan bütünsel bir misafir deneyimi perspektifiyle tasarlanır." } },
    { "@type": "Question", "name": "Otel tadilat için ruhsat gerekir mi?", "acceptedAnswer": { "@type": "Answer", "text": "Yapısal değişiklik, kat ekleme veya mekanik sistem revizyonu içeren kapsamlı projeler için belediye ve TÜRSAB gibi ilgili kurumlardan onay alınması gerekebilir. Standart oda tadilatı ve kaplama değişiminde ruhsat gerekmez. Projeniz izin gerektiriyorsa bu süreci sizin adınıza takip ediyoruz." } }
  ]
};
---

<ServiceLayout
  title="İstanbul Otel Tadilat | Butik Otel Tadilat"
  description="İstanbul'da anahtar teslim otel tadilat. Elektrik, tesisat ve yapısal müdahale dahil kapsamlı otel renovasyonu. Operasyon sürerken fazlı uygulama. Ücretsiz keşif: 0533 039 15 65"
  canonicalUrl={`${CANONICAL_BASE}/hizmetler/anahtar-teslim/otel-tadilat`}
  h1="İstanbul Otel Tadilat"
  eyebrow="Anahtar Teslim"
  lead="Elektrik ve tesisat yenilemesinden yapısal müdahaleye, oda tadilatından lobi dönüşümüne kadar kapsamlı otel renovasyonu. Fazlı uygulama planıyla operasyonunuz sürerken tadilat tamamlanır."
  breadcrumb={[
    { label: "Ana Sayfa", href: "/" },
    { label: "Hizmetler", href: "/#hizmetler" },
    { label: "Anahtar Teslim Hizmetler", href: "/hizmetler/anahtar-teslim" },
    { label: "Otel Tadilat" }
  ]}
  structuredData={[serviceSchema, faqSchema]}
>

  <!-- Proje Görselleri -->
  <div class="w-full mb-12 grid grid-cols-1 md:grid-cols-3 gap-3">
    <img src={optimizedImage('/images/restoran1.jpeg')} alt="Otel tadilat — restoran ve yemek alanı dönüşümü" class="w-full h-64 object-cover" loading="lazy" decoding="async" />
    <img src={optimizedImage('/images/toplantiodasi1.jpeg')} alt="Otel tadilat — toplantı salonu tadilat" class="w-full h-64 object-cover" loading="lazy" decoding="async" />
    <img src={optimizedImage('/images/salon9.jpeg')} alt="Otel tadilat — lobi ve ortak alan dönüşümü" class="w-full h-64 object-cover" loading="lazy" decoding="async" />
  </div>

  <!-- Scope -->
  <div class="grid md:grid-cols-2 gap-12 py-12 border-b border-border">
    <div>
      <h2 class="font-display text-3xl font-bold text-charcoal mb-4">Otel Tadilat Hizmetimiz</h2>
      <p class="text-muted leading-relaxed mb-4">
        Otel tadilat; yalnızca görsel yenileme değil, elektrik ve tesisat altyapısının modernizasyonunu, HVAC sisteminin güncellenmesini, oda sayısı veya büyüklüğünü etkileyen yapısal müdahaleleri de kapsar. Bu tür kapsamlı işler uzmanlık, doğru koordinasyon ve fazlı planlama gerektirir.
      </p>
      <p class="text-muted leading-relaxed mb-4">
        Tadilat yapılan bir otelde doluluk oranı, oda başına gelir ve misafir memnuniyeti ölçülebilir biçimde yükselir. Operasyonunuzu mümkün olduğunca az kesintiye uğratmak için fazlı çalışma planı hazırlıyoruz. <a href="/hizmetler/3d-tasarim" class="text-gold hover:underline">3D görselleştirme</a> ile tüm alanların yeni görünümünü uygulama öncesinde onaylayabilirsiniz.
      </p>
      <p class="text-muted leading-relaxed">
        Yalnızca estetik güncelleme ihtiyacınız varsa <a href="/hizmetler/anahtar-teslim/otel-yenileme" class="text-gold hover:underline">otel yenileme</a> hizmetimiz daha hızlı bir seçenek olabilir. Butik otellerden orta ölçekli tesislere, hostel tadilattan apart otel dönüşümlerine kadar tüm konaklama projelerinde deneyimliyiz.
      </p>
    </div>
    <div>
      <h3 class="font-semibold text-charcoal mb-4 text-xs uppercase tracking-wider">Hizmete Dahil Olanlar</h3>
      <ul class="space-y-3">
        {[
          'Lobi ve resepsiyon tasarımı ve dönüşümü',
          'Oda ve banyo kapsamlı tadilat',
          'Elektrik, tesisat ve iklimlendirme yenileme',
          'Restoran ve bar alanı tadilat',
          'Toplantı ve konferans salonları',
          'Yapısal müdahale ve kat planı revizyonu',
          'FF&E (Mobilya, Tefriş, Ekipman)',
          'Fazlı uygulama ve anahtar teslim',
        ].map(item => (
          <li class="flex items-start gap-3 text-sm text-muted">
            <span class="w-4 h-4 mt-0.5 shrink-0 bg-gold/15 rounded-full flex items-center justify-center">
              <svg class="w-2.5 h-2.5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Ne Zaman Gerekir -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-8">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Otel Tadilat Ne Zaman Gerekir?</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      {[
        {
          title: 'Teknik Altyapı Misafir Deneyimini Etkiliyor',
          desc: 'Eski iklimlendirme, yetersiz su basıncı veya elektrik arızaları misafir şikayetlerinin başında gelen nedenlerdir. Bu sorunlar görünümü güncelleyerek değil, altyapıyı tadilat ederek çözülebilir.',
        },
        {
          title: 'OTA Puanları ve Rekabetçilik',
          desc: 'Booking.com, Airbnb veya Google üzerindeki misafir puanları doğrudan doluluk oranını etkiler. Eski oda tasarımı ve eskimiş donanım puanları düşürür. Kapsamlı oda tadilatı bu puanları kalıcı olarak iyileştirir.',
        },
        {
          title: 'Mülk Satın Alma veya Kira Yenileme',
          desc: 'Yeni satın alınan ya da kira yenilenen bir otelde eski düzenin korunması marka potansiyelini sınırlar. Kapsamlı tadilat ile tesisin konumlama ve fiyat segmenti yeniden belirlenebilir.',
        },
      ].map(item => (
        <div class="bg-white p-6 border border-border">
          <h3 class="font-semibold text-charcoal mb-3 text-sm">{item.title}</h3>
          <p class="text-muted text-sm leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Process -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-8">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Otel Tadilat Sürecimiz</h2>
    </div>
    <div class="grid md:grid-cols-5 gap-6">
      {[
        { step: '01', title: 'Keşif & Analiz', desc: 'Mevcut teknik altyapıyı, operasyonel kısıtları ve tadilat hedeflerini değerlendiriyoruz. Gerekli izin ve ruhsat süreci bu aşamada belirlenir.' },
        { step: '02', title: 'Fazlı Plan', desc: 'Operasyonu en az etkileyen tadilat aşamalarını ve takvimleri belirliyoruz. Her aşamada hangi bölümlerin kapatılacağı önceden netleşir.' },
        { step: '03', title: '3D Tasarım', desc: 'Tüm alanları fotorealistik görsellerle deneyimleyin ve onaylayın. FF&E seçimleri ve malzeme paletleri bu aşamada kesinleşir.' },
        { step: '04', title: 'Uygulama', desc: 'Her aşama tamamlandıkça ilgili bölüm hizmete geri döner. Şantiye yönetimi ve koordinasyon tamamen bizde.' },
        { step: '05', title: 'Teslim', desc: 'Eksiksiz tadilat edilmiş otelinizi teslim alırsınız. Aşama garantileri ve teslim sonrası destek sözleşmede belirtilir.' },
      ].map(item => (
        <div class="text-center">
          <div class="w-12 h-12 bg-gold/10 rounded-full flex items-center justify-center mx-auto mb-3">
            <span class="text-gold font-display font-bold text-sm">{item.step}</span>
          </div>
          <h3 class="font-semibold text-charcoal text-sm mb-2">{item.title}</h3>
          <p class="text-muted text-xs leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Service Areas -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Hizmet Verdiğimiz İlçeler</h2>
    </div>
    <div class="flex flex-wrap gap-2">
      {['Beyoğlu', 'Fatih', 'Beşiktaş', 'Kadıköy', 'Şişli', 'Sarıyer', 'Üsküdar', 'Bakırköy', 'Ataşehir', 'Levent', 'Zekeriyaköy', 'Maltepe'].map(ilce => (
        <span class="px-3 py-1.5 border border-border text-charcoal text-xs font-medium">{ilce}</span>
      ))}
    </div>
  </div>

  <!-- FAQ -->
  <div class="py-12">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Sık Sorulan Sorular</h2>
    </div>
    <div class="divide-y divide-border">
      {[
        { q: 'Otel tadilat sırasında faaliyet sürdürülebilir mi?', a: 'Evet. Otel operasyonunu kesintisiz sürdürmeniz için bölüm bölüm (fazlı) tadilat planı hazırlıyoruz. Her aşama tamamlandıkça ilgili bölümler hizmete geri döner; gelir kaybını minimize ederken tadilat sürer. Aşama planı sözleşmede taahhüt edilir.' },
        { q: 'Otel tadilat ne kadar sürer?', a: 'Süre; otel büyüklüğü, kapsam ve fazlı çalışma planına göre değişir. Küçük butik oteller için tekil aşamalar 6–10 hafta, büyük kapsamlı projeler birkaç aşamada ve uzun bir takvimde tamamlanabilir. Tüm aşama takvimleri sözleşmede net olarak belirlenir.' },
        { q: 'Otel tadilat ROI\'si nasıl ölçülür?', a: 'Otel tadilat yatırımının getirisi; doluluk oranı artışı, oda başına gelir (RevPAR) yükselmesi, ortalama oda fiyatı (ADR) artışı ve online platform misafir puanlarındaki iyileşmeyle ölçülür. Tasarım kararlarımızı bu operasyonel metrikler gözetilerek alıyoruz.' },
        { q: 'Hangi otel alanları için hizmet veriyorsunuz?', a: 'Odalar ve banyolar, lobi ve resepsiyon, restoran ve bar alanları, toplantı ve konferans salonları, ortak kullanım alanları, dış cephe ve çevre düzenlemesi dahil otel genelinde kapsamlı tadilat yapıyoruz. Her alan bütünsel bir misafir deneyimi perspektifiyle tasarlanır.' },
        { q: 'Otel tadilat için ruhsat gerekir mi?', a: 'Yapısal değişiklik, kat ekleme veya mekanik sistem revizyonu içeren kapsamlı projeler için belediye ve ilgili kurumlardan onay alınması gerekebilir. Standart oda tadilatı ve kaplama değişiminde ruhsat gerekmez. Projeniz izin gerektiriyorsa bu süreci sizin adınıza takip ediyoruz.' },
      ].map((faq, i) => (
        <details class="group py-5" open={i === 0}>
          <summary class="flex items-start justify-between cursor-pointer list-none gap-4">
            <h3 class="font-semibold text-charcoal text-sm md:text-base group-open:text-gold transition-colors">{faq.q}</h3>
            <svg class="shrink-0 w-5 h-5 text-gold mt-0.5 group-open:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <p class="mt-3 text-muted text-sm leading-relaxed pr-8">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>

</ServiceLayout>
