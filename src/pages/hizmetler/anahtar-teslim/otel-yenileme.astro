---
import ServiceLayout from '../../../layouts/ServiceLayout.astro';
import { CANONICAL_BASE } from '../../../config';
import { optimizedImage } from '../../../lib/cloudinary';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Otel Yenileme",
  "name": "İstanbul Otel Yenileme",
  "description": "İstanbul'da anahtar teslim otel yenileme. Altyapıya dokunmadan oda, lobi ve ortak alan estetik güncellemesi. Operasyon sürerken hızlı renovasyon.",
  "provider": { "@type": "Organization", "@id": `${CANONICAL_BASE}/#organization`, "name": "Master İç Mimarlık" },
  "areaServed": [
    { "@type": "City", "name": "İstanbul" },
    { "@type": "AdministrativeArea", "name": "Beyoğlu" },
    { "@type": "AdministrativeArea", "name": "Fatih" },
    { "@type": "AdministrativeArea", "name": "Beşiktaş" }
  ],
  "url": `${CANONICAL_BASE}/hizmetler/anahtar-teslim/otel-yenileme`,
  "offers": { "@type": "Offer", "priceCurrency": "TRY", "description": "Ücretsiz keşif ve özel teklif için iletişime geçin", "availability": "https://schema.org/InStock" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Otel yenileme sırasında faaliyet sürdürülebilir mi?", "acceptedAnswer": { "@type": "Answer", "text": "Evet. Otel yenilemesi altyapıya dokunmadığından operasyon açıkken bölüm bölüm ilerlemek çok daha kolaydır. Her tamamlanan bölüm hemen hizmete girer; tadilata kıyasla çok daha az gelir kaybıyla yenileme tamamlanır. Aşama planı müşterimizle birlikte belirlenir." } },
    { "@type": "Question", "name": "Otel yenileme ile tadilat arasındaki fark nedir?", "acceptedAnswer": { "@type": "Answer", "text": "Otel yenilemesi; mevcut elektrik, tesisat ve yapısal sisteme dokunmadan oda, lobi ve ortak alanlarda estetik güncelleme yapmayı kapsar. Mobilya, kaplama, boya, aydınlatma ve tekstil değişimi bu kapsamdadır. Tadilat ise elektrik ve HVAC yenileme, duvar müdahalesi gibi teknik altyapı işlerini içerir. Altyapınız sorunsuzsa yenileme çok daha hızlı ve ekonomiktir." } },
    { "@type": "Question", "name": "Otel yenileme ne kadar sürer?", "acceptedAnswer": { "@type": "Answer", "text": "Yapısal müdahale içermeyen bir otel yenilemesinde her bölüm için 2–6 hafta yeterli olabilir. Otel büyüklüğüne ve aynı anda kapatılabilecek oda/bölüm sayısına göre toplam süre belirlenir. Tadilata kıyasla çok daha kısa olan bu takvim, gelir kaybını minimize eder." } },
    { "@type": "Question", "name": "Otel yenileme ROI'si nasıl ölçülür?", "acceptedAnswer": { "@type": "Answer", "text": "Otel yenileme yatırımının getirisi; online platform misafir puanlarındaki artış, ortalama oda fiyatı (ADR) yükselmesi ve doluluk oranı iyileşmesiyle ölçülür. Kısa süreli kapanma ve ekonomik maliyet sayesinde yenileme, tadilata kıyasla genellikle daha hızlı geri döner." } }
  ]
};
---

<ServiceLayout
  title="İstanbul Otel Yenileme | Hızlı Otel Renovasyonu"
  description="İstanbul'da anahtar teslim otel yenileme. Altyapıya dokunmadan oda, lobi ve ortak alan estetik güncellemesi. Operasyon sürerken hızlı renovasyon. Ücretsiz keşif: 0533 039 15 65"
  canonicalUrl={`${CANONICAL_BASE}/hizmetler/anahtar-teslim/otel-yenileme`}
  h1="İstanbul Otel Yenileme"
  eyebrow="Anahtar Teslim"
  lead="Altyapısı sağlam ama görünümü eskimiş otellar için hızlı ve ekonomik çözüm. Oda, lobi ve ortak alanları altyapıya dokunmadan yeniliyor, misafir memnuniyetini ve online puanları artırıyoruz."
  breadcrumb={[
    { label: "Ana Sayfa", href: "/" },
    { label: "Hizmetler", href: "/#hizmetler" },
    { label: "Anahtar Teslim Hizmetler", href: "/hizmetler/anahtar-teslim" },
    { label: "Otel Yenileme" }
  ]}
  structuredData={[serviceSchema, faqSchema]}
>

  <!-- Proje Görselleri -->
  <div class="w-full mb-12 grid grid-cols-1 md:grid-cols-3 gap-3">
    <img src={optimizedImage('/images/restoran1.jpeg')} alt="Otel yenileme — restoran ve yemek alanı güncellemesi" class="w-full h-64 object-cover" loading="lazy" decoding="async" />
    <img src={optimizedImage('/images/toplantiodasi1.jpeg')} alt="Otel yenileme — toplantı salonu yenileme" class="w-full h-64 object-cover" loading="lazy" decoding="async" />
    <img src={optimizedImage('/images/salon9.jpeg')} alt="Otel yenileme — lobi ve ortak alan yenileme" class="w-full h-64 object-cover" loading="lazy" decoding="async" />
  </div>

  <!-- Scope -->
  <div class="grid md:grid-cols-2 gap-12 py-12 border-b border-border">
    <div>
      <h2 class="font-display text-3xl font-bold text-charcoal mb-4">Otel Yenileme Hizmetimiz</h2>
      <p class="text-muted leading-relaxed mb-4">
        Otel yenilemesi; elektrik, tesisat ve yapısal sisteme dokunmadan oda, lobi, restoran ve ortak alanların görsel kimliğini güncellemek demektir. Mobilya değişimi, zemin ve duvar kaplama yenileme, aydınlatma güncelleme, tekstil ve dekor tazeleme gibi işlemler kısa sürede büyük etki yaratır.
      </p>
      <p class="text-muted leading-relaxed mb-4">
        Otel yenilemesi operasyon açıkken bölüm bölüm yapılabildiğinden misafir kabulünü kesintisiz sürdürebilirsiniz. Her tamamlanan oda veya bölüm hemen hizmete girer. <a href="/hizmetler/3d-tasarim" class="text-gold hover:underline">3D görselleştirme</a> ile yeni görünümü uygulama öncesinde onaylayabilirsiniz.
      </p>
      <p class="text-muted leading-relaxed">
        Teknik altyapı sorunu varsa veya yapısal müdahale gerekiyorsa <a href="/hizmetler/anahtar-teslim/otel-tadilat" class="text-gold hover:underline">otel tadilat</a> hizmetimiz daha uygun seçenektir. Beyoğlu, Fatih, Beşiktaş ve tüm İstanbul'da hizmet veriyoruz.
      </p>
    </div>
    <div>
      <h3 class="font-semibold text-charcoal mb-4 text-xs uppercase tracking-wider">Hizmete Dahil Olanlar</h3>
      <ul class="space-y-3">
        {[
          'Oda konsept yenileme ve tasarım',
          'Fotorealistik 3D görselleştirme',
          'Lobi ve resepsiyon görünüm güncellemesi',
          'Zemin ve duvar kaplama yenileme',
          'Aydınlatma armatürü değişimi',
          'Mobilya ve FF&E seçimi',
          'Tekstil ve dekor güncelleme',
          'Fazlı uygulama ve anahtar teslim',
        ].map(item => (
          <li class="flex items-start gap-3 text-sm text-muted">
            <span class="w-4 h-4 mt-0.5 shrink-0 bg-gold/15 rounded-full flex items-center justify-center">
              <svg class="w-2.5 h-2.5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Ne Değişir -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-8">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Otel Yenileme ile Ne Değişir?</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      {[
        {
          title: 'Online Puanlar Yükseliyor',
          desc: 'Booking.com ve Google gibi platformlarda oda fotoğrafları ve misafir puanları doğrudan doluluk oranını belirler. Güncel mobilya, taze kaplama ve modern aydınlatmayla misafir fotoğrafları ve yorumları olumlu yönde değişir.',
        },
        {
          title: 'Ortalama Oda Fiyatı Artıyor',
          desc: 'Yenilenmiş odaların görselleri daha yüksek fiyat segmentinde listelenmesini mümkün kılar. Sınırlı yatırımla görsel kaliteyi artırmak, oda başına geliri (RevPAR) iyileştirmenin en hızlı yollarından biridir.',
        },
        {
          title: 'Minimum Kapanma ile Hızlı Tamamlanma',
          desc: 'Altyapı değişikliği olmadığından yenileme çok daha kısa takvimde tamamlanır. Otel açıkken bölüm bölüm ilerleyebildiğimizden gelir kaybı minimize edilir ve yatırımın geri dönüş süresi kısalır.',
        },
      ].map(item => (
        <div class="bg-white p-6 border border-border">
          <h3 class="font-semibold text-charcoal mb-3 text-sm">{item.title}</h3>
          <p class="text-muted text-sm leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Process -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-8">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Otel Yenileme Sürecimiz</h2>
    </div>
    <div class="grid md:grid-cols-5 gap-6">
      {[
        { step: '01', title: 'Keşif & Analiz', desc: 'Mevcut durumu, operasyonel kısıtları ve yenileme hedeflerini değerlendiriyoruz. Tadilat mı yenileme mi gerektiğini de bu aşamada netleştiriyoruz.' },
        { step: '02', title: 'Fazlı Plan', desc: 'Operasyonu en az etkileyen yenileme aşamalarını ve takvimleri belirliyoruz. Her bölümün kapalı kalma süresi minimize edilir.' },
        { step: '03', title: '3D Tasarım', desc: 'Tüm alanları fotorealistik görsellerle deneyimleyin ve onaylayın. Mobilya ve malzeme seçimleri bu aşamada kesinleşir.' },
        { step: '04', title: 'Uygulama', desc: 'Her aşama tamamlandıkça ilgili bölüm hizmete geri döner. Şantiye yönetimi ve koordinasyon tamamen bizde.' },
        { step: '05', title: 'Teslim', desc: 'Yenilenmiş otelinizi teslim alırsınız. İşçilik garantisi ve teslim sonrası destek sözleşmede belirtilir.' },
      ].map(item => (
        <div class="text-center">
          <div class="w-12 h-12 bg-gold/10 rounded-full flex items-center justify-center mx-auto mb-3">
            <span class="text-gold font-display font-bold text-sm">{item.step}</span>
          </div>
          <h3 class="font-semibold text-charcoal text-sm mb-2">{item.title}</h3>
          <p class="text-muted text-xs leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Service Areas -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Hizmet Verdiğimiz İlçeler</h2>
    </div>
    <div class="flex flex-wrap gap-2">
      {['Beyoğlu', 'Fatih', 'Beşiktaş', 'Kadıköy', 'Şişli', 'Sarıyer', 'Üsküdar', 'Bakırköy', 'Ataşehir', 'Levent', 'Zekeriyaköy', 'Maltepe'].map(ilce => (
        <span class="px-3 py-1.5 border border-border text-charcoal text-xs font-medium">{ilce}</span>
      ))}
    </div>
  </div>

  <!-- FAQ -->
  <div class="py-12">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Sık Sorulan Sorular</h2>
    </div>
    <div class="divide-y divide-border">
      {[
        { q: 'Otel yenileme sırasında faaliyet sürdürülebilir mi?', a: 'Evet. Otel yenilemesi altyapıya dokunmadığından operasyon açıkken bölüm bölüm ilerlemek çok daha kolaydır. Her tamamlanan bölüm hemen hizmete girer; tadilata kıyasla çok daha az gelir kaybıyla yenileme tamamlanır. Aşama planı müşterimizle birlikte belirlenir.' },
        { q: 'Otel yenileme ile tadilat arasındaki fark nedir?', a: 'Otel yenilemesi; mevcut elektrik, tesisat ve yapısal sisteme dokunmadan oda, lobi ve ortak alanlarda estetik güncelleme yapmayı kapsar. Mobilya, kaplama, boya, aydınlatma ve tekstil değişimi bu kapsamdadır. Tadilat ise elektrik ve HVAC yenileme, duvar müdahalesi gibi teknik altyapı işlerini içerir. Altyapınız sorunsuzsa yenileme çok daha hızlı ve ekonomiktir.' },
        { q: 'Otel yenileme ne kadar sürer?', a: 'Yapısal müdahale içermeyen bir otel yenilemesinde her bölüm için 2–6 hafta yeterli olabilir. Otel büyüklüğüne ve aynı anda kapatılabilecek oda/bölüm sayısına göre toplam süre belirlenir. Tadilata kıyasla çok daha kısa olan bu takvim, gelir kaybını minimize eder.' },
        { q: 'Otel yenileme ROI\'si nasıl ölçülür?', a: 'Otel yenileme yatırımının getirisi; online platform misafir puanlarındaki artış, ortalama oda fiyatı (ADR) yükselmesi ve doluluk oranı iyileşmesiyle ölçülür. Kısa süreli kapanma ve ekonomik maliyet sayesinde yenileme, tadilata kıyasla genellikle daha hızlı geri döner.' },
      ].map((faq, i) => (
        <details class="group py-5" open={i === 0}>
          <summary class="flex items-start justify-between cursor-pointer list-none gap-4">
            <h3 class="font-semibold text-charcoal text-sm md:text-base group-open:text-gold transition-colors">{faq.q}</h3>
            <svg class="shrink-0 w-5 h-5 text-gold mt-0.5 group-open:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <p class="mt-3 text-muted text-sm leading-relaxed pr-8">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>

</ServiceLayout>
