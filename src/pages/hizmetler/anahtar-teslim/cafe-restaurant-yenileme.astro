---
import ServiceLayout from '../../../layouts/ServiceLayout.astro';
import { CANONICAL_BASE } from '../../../config';
import { optimizedImage } from '../../../lib/cloudinary';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Cafe ve Restaurant Yenileme",
  "name": "İstanbul Cafe ve Restaurant Yenileme",
  "description": "İstanbul'da anahtar teslim cafe, restoran ve bar yenileme. Altyapıya dokunmadan estetik güncelleme, konsept yenileme ve hızlı mekan tazelemesi.",
  "provider": { "@type": "Organization", "@id": `${CANONICAL_BASE}/#organization`, "name": "Master İç Mimarlık" },
  "areaServed": { "@type": "City", "name": "İstanbul" },
  "url": `${CANONICAL_BASE}/hizmetler/anahtar-teslim/cafe-restaurant-yenileme`,
  "offers": { "@type": "Offer", "priceCurrency": "TRY", "description": "Ücretsiz keşif ve özel teklif için iletişime geçin", "availability": "https://schema.org/InStock" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Cafe yenileme ne kadar sürer?", "acceptedAnswer": { "@type": "Answer", "text": "Altyapıya dokunmayan bir cafe veya restoran yenilemesi genellikle 2–4 haftada tamamlanabilir. Yalnızca boya, zemin ve dekor değişimi gibi minimal projeler daha kısa sürebilir. Bu süre tadilat projelerine kıyasla çok daha kısadır ve işletmenizin daha çabuk yeniden açılmasını sağlar." } },
    { "@type": "Question", "name": "Yenileme ile tadilat arasındaki fark nedir?", "acceptedAnswer": { "@type": "Answer", "text": "Yenileme; mevcut elektrik, havalandırma ve mutfak altyapısına dokunmadan estetik güncelleme yapmak demektir — duvar, zemin, aydınlatma ve mobilya değişimleri bu kapsamdadır. Tadilat ise mutfak altyapısı, elektrik güçlendirme veya yapısal değişiklik içerir. Altyapınız sorunsuzsa yenileme çok daha hızlı ve ekonomik bir seçenektir." } },
    { "@type": "Question", "name": "İşletme açıkken yenileme yapılabilir mi?", "acceptedAnswer": { "@type": "Answer", "text": "Cafe ve restoran yenilemelerinde bölgeli uygulama ile işletme açıkken çalışmak genellikle mümkündür. Zemin veya boyama gibi kapsamlı işler için kapalı saatlerde veya hafta sonu çalışmayı tercih edebiliriz. İşletmenizin kesintisiz sürmesini hedefleyerek takvimi buna göre planlıyoruz." } },
    { "@type": "Question", "name": "Restoran yenileme bütçesi nasıl belirlenir?", "acceptedAnswer": { "@type": "Answer", "text": "Bütçe; mekanın büyüklüğü, seçilen malzeme ve dekor kalitesi ile yenileme kapsamına göre belirlenir. Altyapı müdahalesi olmadığından yenileme, tadilata kıyasla çok daha ekonomiktir. Ücretsiz keşif ziyaretimizde tüm kalemleri içeren şeffaf bütçe sunuyoruz." } }
  ]
};
---

<ServiceLayout
  title="İstanbul Cafe ve Restaurant Yenileme | Hızlı Mekan Tazelemesi | Master İç Mimarlık"
  description="İstanbul'da cafe, restoran ve bar yenileme. Altyapıya dokunmadan hızlı ve ekonomik estetik güncelleme. Beşiktaş, Kadıköy, Nişantaşı. Ücretsiz keşif: 0533 039 15 65"
  canonicalUrl={`${CANONICAL_BASE}/hizmetler/anahtar-teslim/cafe-restaurant-yenileme`}
  h1="İstanbul Cafe ve Restaurant Yenileme"
  eyebrow="Anahtar Teslim"
  lead="Altyapısı sağlam ama görünümü eskimiş cafe ve restoranlar için hızlı ve ekonomik çözüm. Zemin, aydınlatma, mobilya ve dekor güncellemeleriyle mekanı kısa sürede yeniliyoruz, işletmeniz minimum kapalı kalıyor."
  breadcrumb={[
    { label: "Ana Sayfa", href: "/" },
    { label: "Hizmetler", href: "/#hizmetler" },
    { label: "Anahtar Teslim Hizmetler", href: "/hizmetler/anahtar-teslim" },
    { label: "Cafe & Restaurant Yenileme" }
  ]}
  structuredData={[serviceSchema, faqSchema]}
>

  <!-- Proje Görselleri -->
  <div class="w-full mb-12 grid grid-cols-1 md:grid-cols-2 gap-3">
    <img src={optimizedImage('/images/restoran1.jpeg')} alt="Cafe ve restaurant yenileme — estetik mekan güncellemesi" class="w-full h-64 object-cover" loading="lazy" decoding="async" />
    <img src={optimizedImage('/images/salon9.jpeg')} alt="Cafe ve restaurant yenileme — modern atmosfer" class="w-full h-64 object-cover" loading="lazy" decoding="async" />
  </div>

  <!-- Scope -->
  <div class="grid md:grid-cols-2 gap-12 py-12 border-b border-border">
    <div>
      <h2 class="font-display text-3xl font-bold text-charcoal mb-4">Cafe & Restaurant Yenileme Hizmetimiz</h2>
      <p class="text-muted leading-relaxed mb-4">
        Cafe ve restoran yenilemesi; işletmenizin mevcut altyapısına, mutfak düzenine ve elektrik sistemine dokunmadan estetik görünümü güncellemek demektir. Duvar kaplaması, zemin, aydınlatma armatürleri, mobilya ve dekor değişimiyle mekanın ambiyansı kısa sürede köklü biçimde dönüştürülebilir.
      </p>
      <p class="text-muted leading-relaxed mb-4">
        İşletmenizin kapalı kalma süresini minimumda tutmak önceliğimizdir. Bölgeli uygulama ve mesai dışı çalışma seçenekleriyle çoğu zaman işletme faaliyetlerini durdurmadan yenileme yapılabilir. <a href="/hizmetler/3d-tasarim" class="text-gold hover:underline">3D görselleştirme</a> ile yeni konsepti uygulamadan önce onaylayabilirsiniz.
      </p>
      <p class="text-muted leading-relaxed">
        Mutfak altyapısı, elektrik veya yapısal müdahale gerekiyorsa <a href="/hizmetler/anahtar-teslim/cafe-restaurant-tadilat" class="text-gold hover:underline">cafe ve restoran tadilat</a> hizmetimiz daha uygun seçenektir. Beşiktaş, Kadıköy, Nişantaşı, Levent ve tüm İstanbul'da hizmet veriyoruz.
      </p>
    </div>
    <div>
      <h3 class="font-semibold text-charcoal mb-4 text-xs uppercase tracking-wider">Hizmete Dahil Olanlar</h3>
      <ul class="space-y-3">
        {[
          'Konsept ve tema güncellemesi',
          'Fotorealistik 3D görselleştirme',
          'Zemin kaplama yenileme',
          'Duvar boyama ve grafik/mural uygulama',
          'Aydınlatma armatürü güncelleme',
          'Mobilya seçimi ve oturma düzeni',
          'Bar ve tezgah yüzey yenileme',
          'Son temizlik ve anahtar teslim',
        ].map(item => (
          <li class="flex items-start gap-3 text-sm text-muted">
            <span class="w-4 h-4 mt-0.5 shrink-0 bg-gold/15 rounded-full flex items-center justify-center">
              <svg class="w-2.5 h-2.5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Ne Değişir -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-8">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Cafe Yenileme ile Ne Değişir?</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      {[
        {
          title: 'Atmosfer Müşteri Kararını Etkiler',
          desc: 'Araştırmalar, mekan ambiyansının ortalama oturuş süresini ve harcama miktarını doğrudan etkilediğini göstermektedir. Doğru aydınlatma rengi ve sıcaklığı, zemin ve duvar malzemeleri müşteri deneyimini yenileme ile büyük ölçüde iyileştirilebilir.',
        },
        {
          title: 'Sosyal Medya Görünürlüğü Artıyor',
          desc: 'Fotoğraflanabilir ve paylaşılabilir mekanlar organik pazarlama açısından büyük değer taşır. Duvar grafikleri, özgün köşe tasarımları veya ilgi çekici aydınlatma çözümleri mekanınızın sosyal medyada görünürlüğünü artırır.',
        },
        {
          title: 'Minimum Kesinti ile Hızlı Sonuç',
          desc: 'Altyapı değişikliği olmadığından yenileme süreci çok daha kısa ve öngörülebilirdir. Bölgeli uygulama sayesinde çoğu zaman işletmeyi tamamen kapatmak zorunda kalmadan yenileme tamamlanabilir.',
        },
      ].map(item => (
        <div class="bg-white p-6 border border-border">
          <h3 class="font-semibold text-charcoal mb-3 text-sm">{item.title}</h3>
          <p class="text-muted text-sm leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Process -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-8">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Cafe Yenileme Sürecimiz</h2>
    </div>
    <div class="grid md:grid-cols-5 gap-6">
      {[
        { step: '01', title: 'Ücretsiz Keşif', desc: 'İşletmenizi ve hedeflerinizi yerinde değerlendiriyoruz. Tadilat mı yenileme mi gerektiğini ve kapalı kalma süresini bu aşamada netleştiriyoruz.' },
        { step: '02', title: 'Konsept & 3D', desc: 'Yeni atmosferi gerçekçi görsellerle deneyimleyin ve onaylayın. Renk, malzeme ve mobilya seçimleri bu aşamada kesinleşir.' },
        { step: '03', title: 'Sözleşme', desc: 'Kesin bütçe ve takvim belirlenerek sözleşme imzalanır. Kapalı kalma süresi taahhüt edilir.' },
        { step: '04', title: 'Uygulama', desc: 'Mümkün olduğunda işletme açıkken bölgeli ilerliyoruz. Kapalı saatlerde yoğun çalışma ile zaman tasarrufu sağlanır.' },
        { step: '05', title: 'Teslim', desc: 'Yenilenmiş mekanınızı teslim alıp açılışa geçiyorsunuz. İşçilik garantisi sözleşmede belirtilir.' },
      ].map(item => (
        <div class="text-center">
          <div class="w-12 h-12 bg-gold/10 rounded-full flex items-center justify-center mx-auto mb-3">
            <span class="text-gold font-display font-bold text-sm">{item.step}</span>
          </div>
          <h3 class="font-semibold text-charcoal text-sm mb-2">{item.title}</h3>
          <p class="text-muted text-xs leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Service Areas -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Hizmet Verdiğimiz İlçeler</h2>
    </div>
    <div class="flex flex-wrap gap-2">
      {['Beşiktaş', 'Kadıköy', 'Levent', 'Nişantaşı', 'Zekeriyaköy', 'Ataşehir', 'Acıbadem', 'Şişli', 'Sarıyer', 'Üsküdar', 'Bakırköy', 'Maltepe'].map(ilce => (
        <span class="px-3 py-1.5 border border-border text-charcoal text-xs font-medium">{ilce}</span>
      ))}
    </div>
  </div>

  <!-- FAQ -->
  <div class="py-12">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Sık Sorulan Sorular</h2>
    </div>
    <div class="divide-y divide-border">
      {[
        { q: 'Cafe yenileme ne kadar sürer?', a: 'Altyapıya dokunmayan bir cafe veya restoran yenilemesi genellikle 2–4 haftada tamamlanabilir. Yalnızca boya, zemin ve dekor değişimi gibi minimal projeler daha kısa sürebilir. Bu süre tadilat projelerine kıyasla çok daha kısadır ve işletmenizin daha çabuk yeniden açılmasını sağlar.' },
        { q: 'Yenileme ile tadilat arasındaki fark nedir?', a: 'Yenileme; mevcut elektrik, havalandırma ve mutfak altyapısına dokunmadan estetik güncelleme yapmak demektir — duvar, zemin, aydınlatma ve mobilya değişimleri bu kapsamdadır. Tadilat ise mutfak altyapısı, elektrik güçlendirme veya yapısal değişiklik içerir. Altyapınız sorunsuzsa yenileme çok daha hızlı ve ekonomik bir seçenektir.' },
        { q: 'İşletme açıkken yenileme yapılabilir mi?', a: 'Cafe ve restoran yenilemelerinde bölgeli uygulama ile işletme açıkken çalışmak genellikle mümkündür. Zemin veya boyama gibi kapsamlı işler için kapalı saatlerde veya hafta sonu çalışmayı tercih edebiliriz. İşletmenizin kesintisiz sürmesini hedefleyerek takvimi buna göre planlıyoruz.' },
        { q: 'Restoran yenileme bütçesi nasıl belirlenir?', a: 'Bütçe; mekanın büyüklüğü, seçilen malzeme ve dekor kalitesi ile yenileme kapsamına göre belirlenir. Altyapı müdahalesi olmadığından yenileme, tadilata kıyasla çok daha ekonomiktir. Ücretsiz keşif ziyaretimizde tüm kalemleri içeren şeffaf bütçe sunuyoruz.' },
      ].map((faq, i) => (
        <details class="group py-5" open={i === 0}>
          <summary class="flex items-start justify-between cursor-pointer list-none gap-4">
            <h3 class="font-semibold text-charcoal text-sm md:text-base group-open:text-gold transition-colors">{faq.q}</h3>
            <svg class="shrink-0 w-5 h-5 text-gold mt-0.5 group-open:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <p class="mt-3 text-muted text-sm leading-relaxed pr-8">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>

</ServiceLayout>
