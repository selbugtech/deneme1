---
import ServiceLayout from '../../../layouts/ServiceLayout.astro';
import { CANONICAL_BASE } from '../../../config';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Mağaza ve Dükkan Yenileme",
  "name": "İstanbul Mağaza ve Dükkan Yenileme",
  "description": "İstanbul'da anahtar teslim mağaza ve dükkan iç mekan yenileme. Markanızı yansıtan, müşteri yolculuğunu optimize eden perakende mekan tasarımı.",
  "provider": { "@type": "Organization", "@id": `${CANONICAL_BASE}/#organization`, "name": "Master İç Mimarlık" },
  "areaServed": { "@type": "City", "name": "İstanbul" },
  "url": `${CANONICAL_BASE}/hizmetler/anahtar-teslim/magaza-dukkan-yenileme`,
  "offers": { "@type": "Offer", "priceCurrency": "TRY", "description": "Ücretsiz keşif ve özel teklif için iletişime geçin", "availability": "https://schema.org/InStock" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Mağaza yenileme ne kadar sürer?", "acceptedAnswer": { "@type": "Answer", "text": "Ortalama bir mağaza yenileme projesi (60–150 m²) 4–7 hafta içinde tamamlanmaktadır. Kapalı kalma süresini minimize etmek için hızlı uygulama planı oluşturuyoruz." } },
    { "@type": "Question", "name": "Mağaza yenileme bütçesi nasıl belirlenir?", "acceptedAnswer": { "@type": "Answer", "text": "Bütçe; mekanın büyüklüğü, mevcut yapı durumu ve seçilen malzeme kalitesine göre belirlenir. Ücretsiz keşif ziyaretimizde projenize özel bütçe sunuyoruz." } },
    { "@type": "Question", "name": "Hangi mağaza türleri için hizmet veriyorsunuz?", "acceptedAnswer": { "@type": "Answer", "text": "Giyim mağazaları, butikler, eczaneler, güzellik salonları, elektronik mağazaları ve her türlü perakende mekan için hizmet veriyoruz." } }
  ]
};
---

<ServiceLayout
  title="İstanbul Mağaza ve Dükkan Yenileme | Master İç Mimarlık"
  description="İstanbul'da mağaza ve dükkan yenileme. Markanızı yansıtan, müşteri deneyimini artıran anahtar teslim perakende iç mekan tasarımı. Nişantaşı, Levent, Kadıköy. Ücretsiz keşif: 0533 039 15 65"
  canonicalUrl={`${CANONICAL_BASE}/hizmetler/anahtar-teslim/magaza-dukkan-yenileme`}
  h1="İstanbul Mağaza ve Dükkan Yenileme"
  eyebrow="Anahtar Teslim"
  lead="Markanızı yansıtan, müşteri yolculuğunu optimize eden mağaza ve dükkan tasarımı. Vitrin düzenlemesinden iç mekana, ürün sergileme alanlarından kasaya kadar her detayı satış hedeflerinize göre tasarlıyoruz."
  breadcrumb={[
    { label: "Ana Sayfa", href: "/" },
    { label: "Hizmetler", href: "/#hizmetler" },
    { label: "Anahtar Teslim Hizmetler", href: "/hizmetler/anahtar-teslim" },
    { label: "Mağaza & Dükkan Yenileme" }
  ]}
  structuredData={[serviceSchema, faqSchema]}
>

  <!-- Hero Placeholder -->
  <div class="w-full bg-charcoal flex items-center justify-center mb-12" style="height: 420px;">
    <div class="text-center">
      <svg class="w-16 h-16 text-gold/40 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
      <p class="text-white/30 text-sm tracking-widest uppercase">Proje Görselleri Yakında</p>
    </div>
  </div>

  <!-- Scope -->
  <div class="grid md:grid-cols-2 gap-12 py-12 border-b border-border">
    <div>
      <h2 class="font-display text-3xl font-bold text-charcoal mb-4">Mağaza & Dükkan Yenileme Hizmetimiz</h2>
      <p class="text-muted leading-relaxed mb-4">
        Perakende mekanın tasarımı, müşterinin satın alma kararını doğrudan etkiler. Doğru aydınlatma, ürün sergileme düzeni ve müşteri yolculuğu planlaması satışlarınızı artırır.
      </p>
      <p class="text-muted leading-relaxed mb-4">
        Vitrin tasarımından iç mekana, ürün raflarından kasa alanına kadar tüm detayları marka kimliğiniz ve satış hedeflerinize göre optimize ediyoruz.
      </p>
      <p class="text-muted leading-relaxed">
        İstanbul genelinde Nişantaşı, Levent, Kadıköy, Bağcılar ve tüm ilçelerde hizmet veriyoruz.
      </p>
    </div>
    <div>
      <h3 class="font-semibold text-charcoal mb-4 text-xs uppercase tracking-wider">Hizmete Dahil Olanlar</h3>
      <ul class="space-y-3">
        {[
          'Marka kimliğine uygun konsept tasarım',
          'Fotorealistik 3D görselleştirme',
          'Vitrin ve ön cephe tasarımı',
          'Ürün sergileme ve raf planlaması',
          'Müşteri yolculuğu optimizasyonu',
          'Ticari aydınlatma tasarımı',
          'Zemin, duvar ve tavan kaplamaları',
          'Kasa ve ödeme alanı çözümleri',
        ].map(item => (
          <li class="flex items-start gap-3 text-sm text-muted">
            <span class="w-4 h-4 mt-0.5 shrink-0 bg-gold/15 rounded-full flex items-center justify-center">
              <svg class="w-2.5 h-2.5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Process -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-8">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Mağaza Yenileme Sürecimiz</h2>
    </div>
    <div class="grid md:grid-cols-5 gap-6">
      {[
        { step: '01', title: 'Ücretsiz Keşif', desc: 'Mağazanızı ve marka hedeflerinizi yerinde değerlendiriyoruz.' },
        { step: '02', title: 'Konsept & 3D', desc: 'Marka kimliğinize uygun tasarımı 3D ile görselleştiriyoruz.' },
        { step: '03', title: 'Sözleşme', desc: 'Kesin bütçe ve takvim belirlenerek sözleşme imzalanır.' },
        { step: '04', title: 'Uygulama', desc: 'Hızlı ve verimli uygulama, kapalı süre minimumda.' },
        { step: '05', title: 'Teslim', desc: 'Hazır mağazanızı teslim alıp açılışa geçiyorsunuz.' },
      ].map(item => (
        <div class="text-center">
          <div class="w-12 h-12 bg-gold/10 rounded-full flex items-center justify-center mx-auto mb-3">
            <span class="text-gold font-display font-bold text-sm">{item.step}</span>
          </div>
          <h3 class="font-semibold text-charcoal text-sm mb-2">{item.title}</h3>
          <p class="text-muted text-xs leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Service Areas -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Hizmet Verdiğimiz İlçeler</h2>
    </div>
    <div class="flex flex-wrap gap-2">
      {['Nişantaşı', 'Levent', 'Kadıköy', 'Beşiktaş', 'Şişli', 'Bağcılar', 'Bakırköy', 'Ataşehir', 'Maltepe', 'Ümraniye', 'Sarıyer', 'Üsküdar'].map(ilce => (
        <span class="px-3 py-1.5 border border-border text-charcoal text-xs font-medium">{ilce}</span>
      ))}
    </div>
  </div>

  <!-- FAQ -->
  <div class="py-12">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Sık Sorulan Sorular</h2>
    </div>
    <div class="divide-y divide-border">
      {[
        { q: 'Mağaza yenileme ne kadar sürer?', a: 'Ortalama bir mağaza yenileme projesi (60–150 m²) 4–7 hafta içinde tamamlanmaktadır. Kapalı kalma süresini minimize etmek için hızlı uygulama planı oluşturuyoruz.' },
        { q: 'Mağaza yenileme bütçesi nasıl belirlenir?', a: 'Bütçe; mekanın büyüklüğü, mevcut yapı durumu ve seçilen malzeme kalitesine göre belirlenir. Ücretsiz keşif ziyaretimizde projenize özel bütçe sunuyoruz.' },
        { q: 'Hangi mağaza türleri için hizmet veriyorsunuz?', a: 'Giyim mağazaları, butikler, eczaneler, güzellik salonları, elektronik mağazaları ve her türlü perakende mekan için hizmet veriyoruz.' },
      ].map((faq, i) => (
        <details class="group py-5" open={i === 0}>
          <summary class="flex items-start justify-between cursor-pointer list-none gap-4">
            <h3 class="font-semibold text-charcoal text-sm md:text-base group-open:text-gold transition-colors">{faq.q}</h3>
            <svg class="shrink-0 w-5 h-5 text-gold mt-0.5 group-open:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <p class="mt-3 text-muted text-sm leading-relaxed pr-8">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>

</ServiceLayout>
