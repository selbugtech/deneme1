---
import ServiceLayout from '../../../layouts/ServiceLayout.astro';
import { CANONICAL_BASE } from '../../../config';
import { optimizedImage } from '../../../lib/cloudinary';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Cafe ve Restaurant Tadilat",
  "name": "İstanbul Cafe ve Restaurant Tadilat",
  "description": "İstanbul'da anahtar teslim cafe, restoran ve bar iç mekan tadilat. Müşteri deneyimini artıran, ciro potansiyelini güçlendiren profesyonel tasarım ve uygulama.",
  "provider": { "@type": "Organization", "@id": `${CANONICAL_BASE}/#organization`, "name": "Master İç Mimarlık" },
  "areaServed": { "@type": "City", "name": "İstanbul" },
  "url": `${CANONICAL_BASE}/hizmetler/anahtar-teslim/cafe-restaurant-tadilat`,
  "offers": { "@type": "Offer", "priceCurrency": "TRY", "description": "Ücretsiz keşif ve özel teklif için iletişime geçin", "availability": "https://schema.org/InStock" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Cafe tadilat ne kadar sürer?", "acceptedAnswer": { "@type": "Answer", "text": "Ortalama bir cafe tadilatı (80–150 m²) 4–8 hafta içinde tamamlanmaktadır. İşletmenizin kapalı kalma süresini minimize etmek için detaylı planlama yapıyoruz." } },
    { "@type": "Question", "name": "Restoran tadilat bütçesi nasıl belirlenir?", "acceptedAnswer": { "@type": "Answer", "text": "Bütçe; mekanın büyüklüğü, mevcut yapı durumu ve seçilen malzeme kalitesine göre belirlenir. Ücretsiz keşif ziyaretimizde projenize özel bütçe sunuyoruz." } },
    { "@type": "Question", "name": "İşletme açıkken tadilat yapılabilir mi?", "acceptedAnswer": { "@type": "Answer", "text": "Kısmi tadilatlarda mümkün olabilir. Ancak kapsamlı projelerde işletmenin geçici olarak kapatılması daha verimli sonuç verir. Bu konuyu planlamada birlikte değerlendiriyoruz." } }
  ]
};
---

<ServiceLayout
  title="İstanbul Cafe ve Restaurant Tadilat | Master İç Mimarlık"
  description="İstanbul'da cafe, restoran ve bar iç mekan tadilat. Müşteri deneyimini artıran tasarım, anahtar teslim uygulama. Beşiktaş, Kadıköy, Nişantaşı. Ücretsiz keşif: 0533 039 15 65"
  canonicalUrl={`${CANONICAL_BASE}/hizmetler/anahtar-teslim/cafe-restaurant-tadilat`}
  h1="İstanbul Cafe ve Restaurant Tadilat"
  eyebrow="Anahtar Teslim"
  lead="Müşteri deneyimini ve ciro potansiyelini artıran cafe, restoran ve bar iç mekan tadilat. Konsept geliştirmeden anahtar teslime kadar tüm süreci yönetiyoruz."
  breadcrumb={[
    { label: "Ana Sayfa", href: "/" },
    { label: "Hizmetler", href: "/#hizmetler" },
    { label: "Anahtar Teslim Hizmetler", href: "/hizmetler/anahtar-teslim" },
    { label: "Cafe & Restaurant Tadilat" }
  ]}
  structuredData={[serviceSchema, faqSchema]}
>

  <!-- Proje Görselleri -->
  <div class="w-full mb-12 grid grid-cols-1 md:grid-cols-2 gap-3">
    <img src={optimizedImage('/images/restoran1.jpeg')} alt="Cafe ve restaurant tadilat — iç mekan tasarımı" class="w-full h-64 object-cover" loading="lazy" decoding="async" />
    <img src={optimizedImage('/images/salon9.jpeg')} alt="Cafe ve restaurant tadilat — modern mekan" class="w-full h-64 object-cover" loading="lazy" decoding="async" />
  </div>

  <!-- Scope -->
  <div class="grid md:grid-cols-2 gap-12 py-12 border-b border-border">
    <div>
      <h2 class="font-display text-3xl font-bold text-charcoal mb-4">Cafe & Restaurant Tadilat Hizmetimiz</h2>
      <p class="text-muted leading-relaxed mb-4">
        Bir cafe veya restoranın iç mekanı, müşteri sadakati ve ortalama harcama tutarı üzerinde doğrudan etkiye sahiptir. Doğru aydınlatma, akustik tasarım ve alan planlaması işletmenizin potansiyelini artırır.
      </p>
      <p class="text-muted leading-relaxed mb-4">
        Konsept geliştirmeden malzeme seçimine, mutfak yerleşiminden oturma düzenine kadar tüm detayları işletme hedeflerinize göre tasarlıyoruz.
      </p>
      <p class="text-muted leading-relaxed">
        İstanbul genelinde Beşiktaş, Kadıköy, Nişantaşı, Levent ve tüm ilçelerde hizmet veriyoruz.
      </p>
    </div>
    <div>
      <h3 class="font-semibold text-charcoal mb-4 text-xs uppercase tracking-wider">Hizmete Dahil Olanlar</h3>
      <ul class="space-y-3">
        {[
          'Konsept ve tema tasarımı',
          'Fotorealistik 3D görselleştirme',
          'Oturma düzeni ve trafik akışı planı',
          'Aydınlatma ve akustik tasarım',
          'Malzeme seçimi ve tedariki',
          'Bar, tezgah ve counter uygulamaları',
          'Duvar, zemin ve tavan kaplamaları',
          'Son temizlik ve anahtar teslim',
        ].map(item => (
          <li class="flex items-start gap-3 text-sm text-muted">
            <span class="w-4 h-4 mt-0.5 shrink-0 bg-gold/15 rounded-full flex items-center justify-center">
              <svg class="w-2.5 h-2.5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Process -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-8">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Cafe Tadilat Sürecimiz</h2>
    </div>
    <div class="grid md:grid-cols-5 gap-6">
      {[
        { step: '01', title: 'Ücretsiz Keşif', desc: 'İşletmenizi ve hedeflerinizi yerinde değerlendiriyoruz.' },
        { step: '02', title: 'Konsept & 3D', desc: 'Mekanınızı gerçekçi görsellerle tasarlayıp onaylıyoruz.' },
        { step: '03', title: 'Sözleşme', desc: 'Kesin bütçe ve takvim belirlenerek sözleşme imzalanır.' },
        { step: '04', title: 'Uygulama', desc: 'Şantiye yönetimi bizde, kapalı süre minimumda tutulur.' },
        { step: '05', title: 'Teslim', desc: 'Hazır mekanınızı teslim alıp açılışa geçiyorsunuz.' },
      ].map(item => (
        <div class="text-center">
          <div class="w-12 h-12 bg-gold/10 rounded-full flex items-center justify-center mx-auto mb-3">
            <span class="text-gold font-display font-bold text-sm">{item.step}</span>
          </div>
          <h3 class="font-semibold text-charcoal text-sm mb-2">{item.title}</h3>
          <p class="text-muted text-xs leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Service Areas -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Hizmet Verdiğimiz İlçeler</h2>
    </div>
    <div class="flex flex-wrap gap-2">
      {['Beşiktaş', 'Kadıköy', 'Levent', 'Nişantaşı', 'Zekeriyaköy', 'Ataşehir', 'Acıbadem', 'Şişli', 'Sarıyer', 'Üsküdar', 'Bakırköy', 'Maltepe'].map(ilce => (
        <span class="px-3 py-1.5 border border-border text-charcoal text-xs font-medium">{ilce}</span>
      ))}
    </div>
  </div>

  <!-- FAQ -->
  <div class="py-12">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Sık Sorulan Sorular</h2>
    </div>
    <div class="divide-y divide-border">
      {[
        { q: 'Cafe tadilat ne kadar sürer?', a: 'Ortalama bir cafe tadilatı (80–150 m²) 4–8 hafta içinde tamamlanmaktadır. İşletmenizin kapalı kalma süresini minimize etmek için detaylı planlama yapıyoruz.' },
        { q: 'Restoran tadilat bütçesi nasıl belirlenir?', a: 'Bütçe; mekanın büyüklüğü, mevcut yapı durumu ve seçilen malzeme kalitesine göre belirlenir. Ücretsiz keşif ziyaretimizde projenize özel bütçe sunuyoruz.' },
        { q: 'İşletme açıkken tadilat yapılabilir mi?', a: 'Kısmi tadilatlarda mümkün olabilir. Ancak kapsamlı projelerde işletmenin geçici olarak kapatılması daha verimli sonuç verir. Bu konuyu planlamada birlikte değerlendiriyoruz.' },
      ].map((faq, i) => (
        <details class="group py-5" open={i === 0}>
          <summary class="flex items-start justify-between cursor-pointer list-none gap-4">
            <h3 class="font-semibold text-charcoal text-sm md:text-base group-open:text-gold transition-colors">{faq.q}</h3>
            <svg class="shrink-0 w-5 h-5 text-gold mt-0.5 group-open:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <p class="mt-3 text-muted text-sm leading-relaxed pr-8">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>

</ServiceLayout>
