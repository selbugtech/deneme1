---
import ServiceLayout from '../../../layouts/ServiceLayout.astro';
import { CANONICAL_BASE } from '../../../config';
import { optimizedImage } from '../../../lib/cloudinary';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Cafe ve Restaurant Tadilat",
  "name": "İstanbul Cafe ve Restaurant Tadilat",
  "description": "İstanbul'da anahtar teslim cafe, restoran ve bar tadilat. Elektrik, tesisat, mutfak altyapısı ve yapısal müdahale dahil kapsamlı F&B mekan dönüşümü.",
  "provider": { "@type": "Organization", "@id": `${CANONICAL_BASE}/#organization`, "name": "Master İç Mimarlık" },
  "areaServed": { "@type": "City", "name": "İstanbul" },
  "url": `${CANONICAL_BASE}/hizmetler/anahtar-teslim/cafe-restaurant-tadilat`,
  "offers": { "@type": "Offer", "priceCurrency": "TRY", "description": "Ücretsiz keşif ve özel teklif için iletişime geçin", "availability": "https://schema.org/InStock" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Cafe tadilat ne kadar sürer?", "acceptedAnswer": { "@type": "Answer", "text": "Ortalama bir cafe veya restoran tadilatı (80–150 m²) 4–8 hafta içinde tamamlanmaktadır. Mutfak altyapısı, havalandırma veya elektrik güçlendirmesi gereken projelerde bu süre uzayabilir. İşletmenizin kapalı kalma süresini minimize etmek için detaylı uygulama planı oluşturuyoruz." } },
    { "@type": "Question", "name": "Restoran tadilat bütçesi nasıl belirlenir?", "acceptedAnswer": { "@type": "Answer", "text": "Bütçe; mekanın büyüklüğü, mevcut yapı durumu, mutfak altyapısı gereksinimleri ve seçilen malzeme kalitesine göre belirlenir. Profesyonel mutfak ekipmanı, endüstriyel havalandırma veya elektrik güçlendirmesi gibi F&B'ye özgü teknik işler maliyeti artırır. Ücretsiz keşif ziyaretimizde projenize özel şeffaf bütçe sunuyoruz." } },
    { "@type": "Question", "name": "İşletme açıkken tadilat yapılabilir mi?", "acceptedAnswer": { "@type": "Answer", "text": "Elektrik veya mutfak altyapısı değişimi gibi kapsamlı teknik işlerde işletmenin geçici kapatılması zorunlu olabilir. Kısmi tadilatlarda ise bölgeli uygulama ile daha az aksaklıkla ilerlenmesi mümkündür. İşletmenizin kapanma süresini minimize edecek en verimli planlamayı keşif ziyaretimizde birlikte oluşturuyoruz." } },
    { "@type": "Question", "name": "Tadilat sonrası işletme ruhsatı etkileniyor mu?", "acceptedAnswer": { "@type": "Answer", "text": "Yapısal değişiklik veya mutfak alanı büyütme gibi işlemler belediye izni gerektirebilir ve işletme ruhsatını etkileyebilir. Standart kaplama, aydınlatma veya mobilya değişikliği için herhangi bir resmi işlem gerekmez. Projeniz izin gerektiriyorsa bu süreci sizin adınıza takip ediyoruz." } }
  ]
};
---

<ServiceLayout
  title="İstanbul Cafe ve Restaurant Tadilat"
  description="İstanbul'da cafe, restoran ve bar tadilat. Mutfak altyapısı, elektrik ve yapısal müdahale dahil kapsamlı F&B mekan dönüşümü. Beşiktaş, Kadıköy, Nişantaşı. Ücretsiz keşif: 0533 039 15 65"
  canonicalUrl={`${CANONICAL_BASE}/hizmetler/anahtar-teslim/cafe-restaurant-tadilat`}
  h1="İstanbul Cafe ve Restaurant Tadilat"
  eyebrow="Anahtar Teslim"
  lead="Mutfak altyapısından havalandırmaya, elektrik güçlendirmesinden yapısal düzenlemeye kadar teknik müdahale gerektiren kapsamlı cafe ve restoran dönüşümleri. Müşteri deneyimini ve ciro potansiyelini artıran mekanlar."
  breadcrumb={[
    { label: "Ana Sayfa", href: "/" },
    { label: "Hizmetler", href: "/#hizmetler" },
    { label: "Anahtar Teslim Hizmetler", href: "/hizmetler/anahtar-teslim" },
    { label: "Cafe & Restaurant Tadilat" }
  ]}
  structuredData={[serviceSchema, faqSchema]}
>

  <!-- Proje Görselleri -->
  <div class="w-full mb-12 grid grid-cols-1 md:grid-cols-2 gap-3">
    <img src={optimizedImage('/images/restoran1.jpeg')} alt="Cafe ve restaurant tadilat — iç mekan tasarımı" class="w-full h-64 object-cover" loading="lazy" decoding="async" />
    <img src={optimizedImage('/images/salon9.jpeg')} alt="Cafe ve restaurant tadilat — modern mekan dönüşümü" class="w-full h-64 object-cover" loading="lazy" decoding="async" />
  </div>

  <!-- Scope -->
  <div class="grid md:grid-cols-2 gap-12 py-12 border-b border-border">
    <div>
      <h2 class="font-display text-3xl font-bold text-charcoal mb-4">Cafe & Restaurant Tadilat Hizmetimiz</h2>
      <p class="text-muted leading-relaxed mb-4">
        Cafe ve restoran tadilat; yalnızca estetik değil, mutfak havalandırması, elektrik kapasitesi, baca sistemi ve sıhhi tesisat gibi F&B'ye özgü teknik altyapı gereksinimlerini de kapsar. Eski veya yetersiz altyapıyla açılan işletmeler ilerleyen dönemde ciddi operasyonel sorunlarla karşılaşabilir.
      </p>
      <p class="text-muted leading-relaxed mb-4">
        Konsept geliştirmeden malzeme seçimine, mutfak yerleşiminden oturma düzenine, elektrik altyapısından havalandırma sistemine kadar tüm detayları işletme hedeflerinize göre tasarlıyoruz. <a href="/hizmetler/3d-tasarim" class="text-gold hover:underline">3D görselleştirme</a> ile mekanın yeni görünümünü uygulamadan önce onaylayabilirsiniz.
      </p>
      <p class="text-muted leading-relaxed">
        Altyapınız sorunsuzsa ve yalnızca estetik güncelleme istiyorsanız <a href="/hizmetler/anahtar-teslim/cafe-restaurant-yenileme" class="text-gold hover:underline">cafe yenileme</a> hizmetimiz daha hızlı bir seçenek olabilir. Beşiktaş, Kadıköy, Nişantaşı, Levent ve tüm İstanbul'da hizmet veriyoruz.
      </p>
    </div>
    <div>
      <h3 class="font-semibold text-charcoal mb-4 text-xs uppercase tracking-wider">Hizmete Dahil Olanlar</h3>
      <ul class="space-y-3">
        {[
          'Konsept ve tema tasarımı',
          'Fotorealistik 3D görselleştirme',
          'Mutfak havalandırma ve altyapı yenileme',
          'Elektrik güçlendirme ve pano yenileme',
          'Oturma düzeni ve trafik akışı planı',
          'Aydınlatma ve akustik tasarım',
          'Bar, tezgah ve counter uygulamaları',
          'Duvar, zemin ve tavan kaplamaları',
        ].map(item => (
          <li class="flex items-start gap-3 text-sm text-muted">
            <span class="w-4 h-4 mt-0.5 shrink-0 bg-gold/15 rounded-full flex items-center justify-center">
              <svg class="w-2.5 h-2.5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Ne Zaman Gerekir -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-8">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Cafe & Restaurant Tadilat Ne Zaman Gerekir?</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      {[
        {
          title: 'Mutfak Altyapısı Yetersiz',
          desc: 'Artan menü kapasitesi veya yeni ekipman eklenmesi elektrik ve havalandırma altyapısının güçlendirilmesini gerektirebilir. Yetersiz baca sistemi veya havalandırma hem yasal uyumluluk hem de çalışan güvenliği açısından ciddi risk oluşturur.',
        },
        {
          title: 'Konsept veya Marka Yenilendi',
          desc: 'İşletme konseptinin değişmesi veya markanın yeniden konumlanması mekanın fiziksel kimliğini de değiştirmeyi gerektirir. Yalnızca logo değişikliği yetmez; mekanın her unsuru yeni konseptle uyumlu olmalıdır. Bu tür köklü dönüşümler yapısal müdahale içerir.',
        },
        {
          title: 'Yeni Kiralanan Mekan Dönüştürülüyor',
          desc: 'Ham mekan veya farklı sektörden devreden bir yer, F&B işletmesi gereksinimlerini karşılamak için kapsamlı tadilat gerektirir. Mutfak konumu, servis alanı ve müşteri trafiği planlaması baştan kurgulanmalıdır.',
        },
      ].map(item => (
        <div class="bg-white p-6 border border-border">
          <h3 class="font-semibold text-charcoal mb-3 text-sm">{item.title}</h3>
          <p class="text-muted text-sm leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Process -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-8">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Cafe Tadilat Sürecimiz</h2>
    </div>
    <div class="grid md:grid-cols-5 gap-6">
      {[
        { step: '01', title: 'Ücretsiz Keşif', desc: 'İşletmenizi, hedeflerinizi ve teknik altyapı durumunu yerinde değerlendiriyoruz. Gerekli izin ve belgeler bu aşamada tespit edilir.' },
        { step: '02', title: 'Konsept & 3D', desc: 'Mekanınızı gerçekçi görsellerle tasarlayıp onaylıyoruz. Mutfak düzeni ve müşteri trafik planı da bu aşamada netleşir.' },
        { step: '03', title: 'Sözleşme', desc: 'Kesin bütçe ve takvim belirlenerek sözleşme imzalanır. İşletmenin kapalı kalma süresi sözleşmede taahhüt edilir.' },
        { step: '04', title: 'Uygulama', desc: 'Şantiye yönetimi bizde; kapalı süre minimumda tutulur. Teknik altyapı ve estetik işler paralel yürütülür.' },
        { step: '05', title: 'Teslim', desc: 'Hazır mekanınızı teslim alıp açılışa geçiyorsunuz. Teslim sonrası işçilik garantisi sözleşmede belirtilir.' },
      ].map(item => (
        <div class="text-center">
          <div class="w-12 h-12 bg-gold/10 rounded-full flex items-center justify-center mx-auto mb-3">
            <span class="text-gold font-display font-bold text-sm">{item.step}</span>
          </div>
          <h3 class="font-semibold text-charcoal text-sm mb-2">{item.title}</h3>
          <p class="text-muted text-xs leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Service Areas -->
  <div class="py-12 border-b border-border">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Hizmet Verdiğimiz İlçeler</h2>
    </div>
    <div class="flex flex-wrap gap-2">
      {['Beşiktaş', 'Kadıköy', 'Levent', 'Nişantaşı', 'Zekeriyaköy', 'Ataşehir', 'Acıbadem', 'Şişli', 'Sarıyer', 'Üsküdar', 'Bakırköy', 'Maltepe'].map(ilce => (
        <span class="px-3 py-1.5 border border-border text-charcoal text-xs font-medium">{ilce}</span>
      ))}
    </div>
  </div>

  <!-- FAQ -->
  <div class="py-12">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-8 h-px bg-gold"></span>
      <h2 class="font-display text-2xl font-bold text-charcoal">Sık Sorulan Sorular</h2>
    </div>
    <div class="divide-y divide-border">
      {[
        { q: 'Cafe tadilat ne kadar sürer?', a: 'Ortalama bir cafe veya restoran tadilatı (80–150 m²) 4–8 hafta içinde tamamlanmaktadır. Mutfak altyapısı, havalandırma veya elektrik güçlendirmesi gereken projelerde bu süre uzayabilir. İşletmenizin kapalı kalma süresini minimize etmek için detaylı uygulama planı oluşturuyoruz.' },
        { q: 'Restoran tadilat bütçesi nasıl belirlenir?', a: "Bütçe; mekanın büyüklüğü, mevcut yapı durumu, mutfak altyapısı gereksinimleri ve seçilen malzeme kalitesine göre belirlenir. Profesyonel mutfak ekipmanı, endüstriyel havalandırma veya elektrik güçlendirmesi gibi F&B'ye özgü teknik işler maliyeti artırır. Ücretsiz keşif ziyaretimizde projenize özel şeffaf bütçe sunuyoruz." },
        { q: 'İşletme açıkken tadilat yapılabilir mi?', a: 'Elektrik veya mutfak altyapısı değişimi gibi kapsamlı teknik işlerde işletmenin geçici kapatılması zorunlu olabilir. Kısmi tadilatlarda ise bölgeli uygulama ile daha az aksaklıkla ilerlenmesi mümkündür. İşletmenizin kapanma süresini minimize edecek en verimli planlamayı keşif ziyaretimizde birlikte oluşturuyoruz.' },
        { q: 'Tadilat sonrası işletme ruhsatı etkileniyor mu?', a: 'Yapısal değişiklik veya mutfak alanı büyütme gibi işlemler belediye izni gerektirebilir ve işletme ruhsatını etkileyebilir. Standart kaplama, aydınlatma veya mobilya değişikliği için herhangi bir resmi işlem gerekmez. Projeniz izin gerektiriyorsa bu süreci sizin adınıza takip ediyoruz.' },
      ].map((faq, i) => (
        <details class="group py-5" open={i === 0}>
          <summary class="flex items-start justify-between cursor-pointer list-none gap-4">
            <h3 class="font-semibold text-charcoal text-sm md:text-base group-open:text-gold transition-colors">{faq.q}</h3>
            <svg class="shrink-0 w-5 h-5 text-gold mt-0.5 group-open:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <p class="mt-3 text-muted text-sm leading-relaxed pr-8">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>

</ServiceLayout>
