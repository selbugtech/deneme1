---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import { CANONICAL_BASE } from '../../config';

const posts = [
  {
    title: 'Ev Tadilat Rehberi — Başlamadan Önce Bilmeniz Gerekenler',
    slug: 'ev-tadilati-ipuclari',
    date: '2025-03-25',
    readingTime: '8 dk',
    excerpt: 'Ev tadilat sürecine girmeden önce bilmeniz gereken her şey: planlama, bütçe, usta seçimi, sık yapılan hatalar ve adım adım iş sırası.',
    tag: 'Rehber',
  },
  {
    title: 'İstanbul Daire İç Mimarlık — Doğru İç Mimar Nasıl Seçilir?',
    slug: 'istanbul-daire-ic-mimarlik',
    date: '2025-03-15',
    readingTime: '6 dk',
    excerpt: 'İstanbul\'da daire iç mimarlık hizmeti almak isteyenler için kapsamlı rehber. İç mimar ne yapar, süreç nasıl işler, fiyatlar nasıl belirlenir?',
    tag: 'Bilgi',
  },
  {
    title: 'Mutfak Yenileme İstanbul — Tadilat Fikirleri ve Maliyet Rehberi',
    slug: 'mutfak-yenileme-istanbul',
    date: '2025-03-05',
    readingTime: '7 dk',
    excerpt: 'Mutfak yenileme neleri kapsar, dolap seçimi nasıl yapılır ve İstanbul\'da mutfak tadilat maliyetleri 2025\'te ne kadar? Uzman iç mimar rehberi.',
    tag: 'Rehber',
  },
  {
    title: 'Villa Tadilat İstanbul — Lüks Villa Yenileme Rehberi 2025',
    slug: 'villa-tadilati-istanbul',
    date: '2025-02-20',
    readingTime: '8 dk',
    excerpt: 'İstanbul\'da villa tadilat ve yenileme süreçleri nasıl işler? Daire yenilemesinden farkları, aşamalar, maliyet aralıkları ve dikkat edilmesi gerekenler.',
    tag: 'Rehber',
  },
  {
    title: '2025 İç Mimarlık Trendleri — İstanbul Perspektifinden',
    slug: 'ic-mimarlik-trendleri-2025',
    date: '2025-02-10',
    readingTime: '6 dk',
    excerpt: 'Wabi-sabi minimalizm, doğal malzemeler ve biyofilik tasarım. 2025\'in öne çıkan iç mimarlık trendleri ve İstanbul\'daki yansımaları.',
    tag: 'Trendler',
  },
  {
    title: 'Anahtar Teslim Ev Yenileme Nedir? Avantajları ve Süreci',
    slug: 'anahtar-teslim-ev-yenileme-nedir',
    date: '2025-01-25',
    readingTime: '5 dk',
    excerpt: '"Anahtar teslim" yenileme modeli nedir, kendin yönet modelinden farkları nelerdir ve hangi durumlarda tercih edilmeli? Kapsamlı bir karşılaştırma.',
    tag: 'Bilgi',
  },
  {
    title: 'Ev Yenileme Maliyeti 2025 — İstanbul Güncel Rehber',
    slug: 'ev-yenileme-maliyeti-2025',
    date: '2025-01-10',
    readingTime: '7 dk',
    excerpt: 'İstanbul\'da daire ve ev yenileme maliyetleri 2025 yılı itibarıyla ne kadar? Metrekare başına fiyatlar, etkileyen faktörler ve bütçe planlama ipuçları.',
    tag: 'Rehber',
  },
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": `${CANONICAL_BASE}/` },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": `${CANONICAL_BASE}/blog` }
  ]
};
---

<Layout
  title="Blog | İç Mimarlık ve Ev Yenileme Rehberi | Master İç Mimarlık"
  description="Master İç Mimarlık blog — İstanbul'da ev yenileme maliyetleri, iç mimarlık trendleri ve tadilat rehberleri."
  canonicalUrl={`${CANONICAL_BASE}/blog`}
  structuredData={breadcrumbSchema}
>
  <Header />

  <main class="pt-24 bg-warm-white min-h-screen">
    <div class="max-w-4xl mx-auto px-6 py-16">

      <nav class="flex items-center gap-2 mb-8 text-sm" aria-label="Breadcrumb">
        <a href={`${CANONICAL_BASE}/`} class="text-muted hover:text-gold transition-colors">Ana Sayfa</a>
        <span class="text-border">/</span>
        <span class="text-charcoal">Blog</span>
      </nav>

      <div class="flex items-center gap-3 mb-4">
        <span class="w-8 h-px bg-gold"></span>
        <span class="text-xs tracking-[0.3em] uppercase text-gold font-medium">Blog</span>
      </div>
      <h1 class="font-display text-4xl md:text-5xl font-bold text-charcoal leading-tight mb-4">
        İç Mimarlık &<br />
        <em class="not-italic text-gold">Ev Yenileme</em> Rehberi
      </h1>
      <p class="text-muted leading-relaxed max-w-xl mb-16">
        İstanbul'da ev yenileme, iç mimarlık trendleri ve tadilat süreçleri hakkında uzman içerikler.
      </p>

      <div class="space-y-8">
        {posts.map((post) => (
          <a href={`${CANONICAL_BASE}/blog/${post.slug}`} class="group block border border-border p-8 hover:border-gold transition-colors duration-200">
            <div class="flex items-center gap-4 mb-4">
              <span class="text-[10px] tracking-[0.25em] uppercase text-gold font-medium">{post.tag}</span>
              <span class="text-border">·</span>
              <time class="text-xs text-muted" datetime={post.date}>
                {new Date(post.date).toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <span class="text-border">·</span>
              <span class="text-xs text-muted">{post.readingTime} okuma</span>
            </div>
            <h2 class="font-display text-2xl font-bold text-charcoal mb-3 group-hover:text-gold transition-colors">{post.title}</h2>
            <p class="text-muted leading-relaxed text-sm mb-4">{post.excerpt}</p>
            <span class="text-xs text-gold inline-flex items-center gap-1.5">
              Devamını oku
              <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </span>
          </a>
        ))}
      </div>

    </div>
  </main>

  <Footer />
  <WhatsAppFloat />
</Layout>
