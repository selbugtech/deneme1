---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import { CANONICAL_BASE } from '../../config';
import { projects, getProject } from '../../data/projects';

export async function getStaticPaths() {
  const { projects } = await import('../../data/projects');
  return projects.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const project = getProject(slug!)!;
const related = projects.filter((p) => p.slug !== slug).slice(0, 3);

const projectSchema = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  "name": project.title,
  "description": project.description[0],
  "dateCreated": project.year,
  "locationCreated": {
    "@type": "Place",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": project.location,
      "addressCountry": "TR"
    }
  },
  "creator": {
    "@type": "InteriorDesigner",
    "@id": `${CANONICAL_BASE}/#business`,
    "name": "Master İç Mimarlık"
  },
  "url": `${CANONICAL_BASE}/projeler/${project.slug}`
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": `${CANONICAL_BASE}/` },
    { "@type": "ListItem", "position": 2, "name": "Projeler", "item": `${CANONICAL_BASE}/projeler` },
    { "@type": "ListItem", "position": 3, "name": project.title }
  ]
};
---

<Layout
  title={project.metaTitle}
  description={project.metaDesc}
  canonicalUrl={`${CANONICAL_BASE}/projeler/${project.slug}`}
  structuredData={[breadcrumbSchema, projectSchema]}
>
  <Header />

  <main class="bg-charcoal min-h-screen">

    <!-- Hero image -->
    <div class="relative w-full h-[55vh] md:h-[70vh] overflow-hidden">
      <img
        src={project.heroImage}
        srcset={project.heroSrcset}
        sizes="100vw"
        alt={`${project.title} — ${project.category} projesi`}
        fetchpriority="high"
        decoding="async"
        class="w-full h-full object-cover object-center"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-charcoal via-charcoal/40 to-transparent"></div>

      <div class="absolute top-0 left-0 right-0 pt-28 px-6">
        <nav class="flex items-center gap-2 text-sm" aria-label="Breadcrumb">
          <a href="/" class="text-white/50 hover:text-gold transition-colors">Ana Sayfa</a>
          <span class="text-white/20">/</span>
          <a href="/projeler" class="text-white/50 hover:text-gold transition-colors">Projeler</a>
          <span class="text-white/20">/</span>
          <span class="text-white/80">{project.title}</span>
        </nav>
      </div>

      <div class="absolute bottom-0 left-0 right-0 pb-10 px-6">
        <div class="max-w-6xl mx-auto">
          <div class="flex items-center gap-3 mb-3">
            <span class="w-6 h-px bg-gold"></span>
            <span class="text-[10px] tracking-[0.3em] uppercase text-gold font-medium">{project.category}</span>
          </div>
          <h1 class="font-display text-4xl md:text-6xl font-bold text-white">{project.title}</h1>
        </div>
      </div>
    </div>

    <!-- Photo gallery — CSS masonry columns for elegant, non-cramped layout -->
    <div class="max-w-6xl mx-auto px-6 py-16">
      <div class="flex items-center gap-3 mb-8">
        <span class="w-8 h-px bg-gold"></span>
        <span class="text-xs tracking-[0.3em] uppercase text-gold font-medium">Proje Fotoğrafları</span>
      </div>
      <div class="gallery-masonry">
        {project.gallery.map((img, i) => (
          <button
            type="button"
            data-lightbox-image={img.src}
            data-lightbox-srcset={img.srcset}
            data-lightbox-title={`${project.title} — Fotoğraf ${i + 1}`}
            class="gallery-item group relative overflow-hidden cursor-zoom-in mb-5 md:mb-6 w-full"
            aria-label={`Fotoğraf ${i + 1} büyüt`}
          >
            <img
              src={img.src}
              srcset={img.srcset}
              sizes="(min-width:1024px) 33vw, (min-width:640px) 50vw, 100vw"
              alt={`${project.title} — fotoğraf ${i + 1}`}
              loading={i < 2 ? 'eager' : 'lazy'}
              decoding={i < 2 ? 'sync' : 'async'}
              class="block w-full h-auto object-cover transition-transform duration-700 group-hover:scale-[1.03]"
            />
            <div class="absolute inset-0 bg-charcoal/0 group-hover:bg-charcoal/25 transition-colors duration-300 flex items-center justify-center">
              <svg class="w-8 h-8 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300 drop-shadow-lg" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/>
              </svg>
            </div>
          </button>
        ))}
      </div>
    </div>

    <style>
      .gallery-masonry {
        column-count: 1;
        column-gap: 1.25rem;
      }
      @media (min-width: 640px) {
        .gallery-masonry { column-count: 2; column-gap: 1.25rem; }
      }
      @media (min-width: 1024px) {
        .gallery-masonry { column-count: 3; column-gap: 1.5rem; }
      }
      .gallery-item {
        break-inside: avoid;
        -webkit-column-break-inside: avoid;
        page-break-inside: avoid;
        display: block;
      }
    </style>

    <!-- Content -->
    <div class="max-w-6xl mx-auto px-6 pb-16">
      <div class="grid md:grid-cols-3 gap-12">

        <div class="md:col-span-2 space-y-5">
          <div class="flex items-center gap-3 mb-6">
            <span class="w-8 h-px bg-gold"></span>
            <span class="text-xs tracking-[0.3em] uppercase text-gold font-medium">Proje Hakkında</span>
          </div>
          {project.description.map(para => (
            <p class="text-white/60 leading-relaxed">{para}</p>
          ))}
        </div>

        <div>
          <h2 class="text-xs tracking-[0.3em] uppercase text-white/30 mb-4">Uygulanan Hizmetler</h2>
          <ul class="space-y-2">
            {project.services.map(s => (
              <li class="flex items-start gap-3 text-sm text-white/60">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-gold shrink-0"></span>
                {s}
              </li>
            ))}
          </ul>

          <div class="mt-10 pt-8 border-t border-white/10">
            <p class="text-xs tracking-wide text-white/30 mb-4 uppercase">Bu proje gibi bir çalışma ister misiniz?</p>
            <a
              href={`https://wa.me/905330391565?text=Merhaba%2C%20${encodeURIComponent(project.title)}%20projesi%20gibi%20bir%20%C3%A7al%C4%B1%C5%9Fma%20yapmak%20istiyorum.`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 bg-gold text-charcoal px-6 py-3 text-xs font-semibold tracking-wide hover:bg-[#B8965A] transition-colors w-full justify-center"
            >
              Ücretsiz Keşif Al
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Lightbox Modal -->
    <div
      id="project-lightbox"
      class="fixed inset-0 z-[200] flex items-center justify-center"
      style="display: none;"
      role="dialog"
      aria-modal="true"
      aria-label="Proje fotoğrafı"
    >
      <div id="lightbox-backdrop" class="absolute inset-0 bg-charcoal/95 backdrop-blur-sm"></div>
      <div class="relative z-10 max-w-5xl w-full mx-4 flex flex-col items-center">
        <button
          id="lightbox-close"
          type="button"
          class="absolute -top-12 right-0 text-white/60 hover:text-white transition-colors p-2"
          aria-label="Kapat"
        >
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
        <button
          id="lightbox-prev"
          type="button"
          class="absolute left-0 md:-left-14 top-1/2 -translate-y-1/2 z-20 text-white/70 hover:text-white bg-charcoal/40 hover:bg-charcoal/70 transition-colors p-2 md:p-3"
          aria-label="Önceki fotoğraf"
        >
          <svg class="w-6 h-6 md:w-8 md:h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"/>
          </svg>
        </button>
        <button
          id="lightbox-next"
          type="button"
          class="absolute right-0 md:-right-14 top-1/2 -translate-y-1/2 z-20 text-white/70 hover:text-white bg-charcoal/40 hover:bg-charcoal/70 transition-colors p-2 md:p-3"
          aria-label="Sonraki fotoğraf"
        >
          <svg class="w-6 h-6 md:w-8 md:h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"/>
          </svg>
        </button>
        <img id="lightbox-img" src="" srcset="" sizes="100vw" alt="" class="max-h-[82vh] max-w-full object-contain shadow-2xl select-none" style="touch-action: pan-y;" draggable="false" />
        <p id="lightbox-caption" class="mt-4 text-white/50 text-sm text-center"></p>
        <p id="lightbox-counter" class="mt-1 text-white/30 text-xs tracking-wide"></p>
      </div>
    </div>

    <script>
      const lightbox = document.getElementById('project-lightbox') as HTMLElement;
      const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
      const lightboxCaption = document.getElementById('lightbox-caption') as HTMLElement;
      const lightboxCounter = document.getElementById('lightbox-counter') as HTMLElement;
      const closeBtn = document.getElementById('lightbox-close');
      const prevBtn = document.getElementById('lightbox-prev');
      const nextBtn = document.getElementById('lightbox-next');
      const backdrop = document.getElementById('lightbox-backdrop');

      const triggers = Array.from(document.querySelectorAll<HTMLElement>('[data-lightbox-image]'));
      const images = triggers.map((b) => b.dataset.lightboxImage ?? '');
      const srcsets = triggers.map((b) => b.dataset.lightboxSrcset ?? '');
      const titles = triggers.map((b) => b.dataset.lightboxTitle ?? '');
      const total = images.length;
      let currentIndex = 0;

      function render() {
        if (!total) return;
        lightboxImg.srcset = srcsets[currentIndex];
        lightboxImg.src = images[currentIndex];
        lightboxImg.alt = titles[currentIndex];
        lightboxCaption.textContent = titles[currentIndex];
        lightboxCounter.textContent = `${currentIndex + 1} / ${total}`;
      }

      function openLightbox(index: number) {
        currentIndex = index;
        render();
        lightbox.style.display = 'flex';
        lightbox.style.opacity = '0';
        requestAnimationFrame(() => {
          lightbox.style.transition = 'opacity 0.22s ease';
          lightbox.style.opacity = '1';
        });
        document.body.style.overflow = 'hidden';
      }

      function closeLightbox() {
        lightbox.style.opacity = '0';
        setTimeout(() => {
          lightbox.style.display = 'none';
          document.body.style.overflow = '';
        }, 220);
      }

      function next() {
        if (!total) return;
        currentIndex = (currentIndex + 1) % total;
        render();
      }

      function prev() {
        if (!total) return;
        currentIndex = (currentIndex - 1 + total) % total;
        render();
      }

      triggers.forEach((btn, i) => {
        btn.addEventListener('click', () => openLightbox(i));
      });

      closeBtn?.addEventListener('click', closeLightbox);
      backdrop?.addEventListener('click', closeLightbox);
      nextBtn?.addEventListener('click', (e) => { e.stopPropagation(); next(); });
      prevBtn?.addEventListener('click', (e) => { e.stopPropagation(); prev(); });

      document.addEventListener('keydown', (e) => {
        if (lightbox.style.display === 'none') return;
        if (e.key === 'Escape') closeLightbox();
        else if (e.key === 'ArrowRight') next();
        else if (e.key === 'ArrowLeft') prev();
      });

      // Touch swipe (mobile)
      let touchStartX = 0;
      let touchStartY = 0;
      let touchActive = false;
      lightboxImg.addEventListener('touchstart', (e) => {
        if (e.touches.length !== 1) return;
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
        touchActive = true;
      }, { passive: true });
      lightboxImg.addEventListener('touchend', (e) => {
        if (!touchActive) return;
        touchActive = false;
        const t = e.changedTouches[0];
        const dx = t.clientX - touchStartX;
        const dy = t.clientY - touchStartY;
        if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)) {
          if (dx < 0) next();
          else prev();
        }
      });
    </script>

    <!-- Related projects -->
    <div class="border-t border-white/10 py-16">
      <div class="max-w-6xl mx-auto px-6">
        <div class="flex items-center justify-between mb-8">
          <div class="flex items-center gap-3">
            <span class="w-8 h-px bg-gold"></span>
            <span class="text-xs tracking-[0.3em] uppercase text-gold font-medium">Diğer Projeler</span>
          </div>
          <a href="/projeler" class="text-xs text-white/30 hover:text-gold transition-colors tracking-wide">Tümünü Gör →</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {related.map(p => (
            <a href={`/projeler/${p.slug}`} class="group block relative overflow-hidden">
              <img
                src={p.heroImage}
                srcset={p.heroSrcset}
                sizes="(min-width:768px) 33vw, 100vw"
                alt={p.title}
                loading="lazy"
                decoding="async"
                class="w-full h-48 object-cover object-center group-hover:scale-105 transition-transform duration-500"
              />
              <div class="absolute inset-0 bg-charcoal/60 group-hover:bg-charcoal/40 transition-colors duration-300 flex flex-col justify-end p-4">
                <p class="text-[10px] tracking-[0.25em] uppercase text-gold mb-1">{p.category}</p>
                <p class="font-display text-white font-semibold text-sm">{p.title}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="bg-charcoal border-t border-white/10 py-20">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <div class="flex items-center justify-center gap-3 mb-4">
          <span class="w-8 h-px bg-gold"></span>
          <span class="text-xs tracking-[0.3em] uppercase text-gold font-medium">Projenizi Konuşalım</span>
          <span class="w-8 h-px bg-gold"></span>
        </div>
        <h2 class="font-display text-3xl font-bold text-white mb-4">Hayalinizdeki Mekanı Tasarlayalım</h2>
        <p class="text-white/40 mb-8 max-w-md mx-auto leading-relaxed">Ücretsiz keşif ve fiyat teklifi için WhatsApp'tan yazın ya da arayın. En kısa sürede size dönüyoruz.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="https://wa.me/905330391565?text=Merhaba%2C%20proje%20hakk%C4%B1nda%20g%C3%B6r%C3%BC%C5%9Fmek%20istiyorum."
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-3 bg-[#25D366] text-white px-10 py-4 text-sm font-semibold hover:bg-[#1EBD5A] transition-colors"
          >
            WhatsApp'tan Yaz
          </a>
          <a
            href="tel:+905330391565"
            class="inline-flex items-center justify-center gap-3 bg-gold text-charcoal px-10 py-4 text-sm font-semibold hover:bg-[#B8965A] transition-colors"
          >
            0533 039 15 65
          </a>
        </div>
      </div>
    </div>

  </main>

  <Footer />
  <WhatsAppFloat />
</Layout>
