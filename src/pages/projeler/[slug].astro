export async function getStaticPaths() {
  const projects = [
    { slug: 'beyoglu-galata' },
    { slug: 'beykoz-pasabahce' },
    { slug: 'caddebostan' },
    { slug: 'mecidiyekoy' },
    { slug: 'artas-ofis' },
    { slug: 'artas-ofis-2' },
    { slug: 'tepekent' },
    { slug: 'kozyatagi-banyo' },
    { slug: 'zeytinburnu' },
  ];
  return projects.map(p => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const project = allProjects.find(p => p.slug === slug)!;
const related = allProjects.filter(p => p.slug !== slug).slice(0, 3);

const projectSchema = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  "name": project.title,
  "description": project.description[0],
  "dateCreated": project.year,
  "locationCreated": {
    "@type": "Place",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": project.location,
      "addressCountry": "TR"
    }
  },
  "creator": {
    "@type": "InteriorDesigner",
    "@id": `${CANONICAL_BASE}/#business`,
    "name": "Master İç Mimarlık"
  },
  "url": `${CANONICAL_BASE}/projeler/${project.slug}`
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": `${CANONICAL_BASE}/` },
    { "@type": "ListItem", "position": 2, "name": "Projeler", "item": `${CANONICAL_BASE}/projeler` },
    { "@type": "ListItem", "position": 3, "name": project.title }
  ]
};
---

<Layout
  title={project.metaTitle}
  description={project.metaDesc}
  canonicalUrl={`${CANONICAL_BASE}/projeler/${project.slug}`}
  structuredData={[breadcrumbSchema, projectSchema]}
>
  <Header />

  <main class="bg-charcoal min-h-screen">

    <!-- Hero image -->
    <div class="relative w-full h-[55vh] md:h-[70vh] overflow-hidden">
      <img
        src={project.heroImage}
        alt={`${project.title} — ${project.category} projesi`}
        class="w-full h-full object-cover object-center"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-charcoal via-charcoal/40 to-transparent"></div>

      <!-- Breadcrumb overlay -->
      <div class="absolute top-0 left-0 right-0 pt-28 px-6">
        <nav class="flex items-center gap-2 text-sm" aria-label="Breadcrumb">
          <a href="/" class="text-white/50 hover:text-gold transition-colors">Ana Sayfa</a>
          <span class="text-white/20">/</span>
          <a href="/projeler" class="text-white/50 hover:text-gold transition-colors">Projeler</a>
          <span class="text-white/20">/</span>
          <span class="text-white/80">{project.title}</span>
        </nav>
      </div>

      <!-- Title overlay at bottom -->
      <div class="absolute bottom-0 left-0 right-0 pb-10 px-6">
        <div class="max-w-6xl mx-auto">
          <div class="flex items-center gap-3 mb-3">
            <span class="w-6 h-px bg-gold"></span>
            <span class="text-[10px] tracking-[0.3em] uppercase text-gold font-medium">{project.category}</span>
          </div>
          <h1 class="font-display text-4xl md:text-6xl font-bold text-white">{project.title}</h1>
        </div>
      </div>
    </div>

    <!-- Project meta strip -->
    <div class="border-b border-white/10">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-white/10">
          {[
            { label: 'Konum', value: project.location },
            { label: 'Alan', value: project.area },
            { label: 'Süre', value: project.duration },
            { label: 'Yıl', value: project.year },
          ].map(item => (
            <div class="py-6 px-4 first:pl-0">
              <p class="text-[10px] tracking-[0.25em] uppercase text-white/30 mb-1">{item.label}</p>
              <p class="text-white font-medium text-sm">{item.value}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Content -->
    <div class="max-w-6xl mx-auto px-6 py-16">
      <div class="grid md:grid-cols-3 gap-12">

        <!-- Description -->
        <div class="md:col-span-2 space-y-5">
          <div class="flex items-center gap-3 mb-6">
            <span class="w-8 h-px bg-gold"></span>
            <span class="text-xs tracking-[0.3em] uppercase text-gold font-medium">Proje Hakkında</span>
          </div>
          {project.description.map(para => (
            <p class="text-white/60 leading-relaxed">{para}</p>
          ))}
        </div>

        <!-- Services list -->
        <div>
          <h2 class="text-xs tracking-[0.3em] uppercase text-white/30 mb-4">Uygulanan Hizmetler</h2>
          <ul class="space-y-2">
            {project.services.map(s => (
              <li class="flex items-start gap-3 text-sm text-white/60">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-gold shrink-0"></span>
