---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import RelatedDistricts from '../../components/RelatedDistricts.astro';
import DistrictFAQ from '../../components/DistrictFAQ.astro';
import ProcessStrip from '../../components/ProcessStrip.astro';
import { CANONICAL_BASE } from '../../config';
import { optimizedImageW } from '../../lib/cloudinary';

const heroPath = '/images/ofis2.jpeg';
const heroAbs = optimizedImageW(heroPath, 1600);

const localSchema = {
  "@context": "https://schema.org",
  "@type": "InteriorDesigner",
  "name": "Master İç Mimarlık",
  "@id": `${CANONICAL_BASE}/#business`,
  "areaServed": { "@type": "Place", "name": "Levent, İstanbul" },
  "url": `${CANONICAL_BASE}/istanbul/levent-ic-mimarlik`,
  "description": "Levent ve çevresinde lüks rezidans iç mimarlığı, kurumsal ofis yenileme ve anahtar teslim daire tadilatı.",
  "image": heroAbs,
};

const faqItems = [
  {
    q: "Levent'te ofis yenileme ve daire tadilatı ne kadar sürer?",
    a: "Levent'teki orta ölçek daire yenilemeleri 5–8 hafta, lüks rezidans projeleri 6–10 hafta ve 200–400 m² kurumsal ofis yenilemeleri 6–12 hafta sürmektedir. Ofis projelerinde mesai sonrası ve hafta sonu çalışma planı yaparak iş kesintisini en aza indiriyoruz.",
  },
  {
    q: "Levent'te hangi mahalle ve plazalarda hizmet veriyorsunuz?",
    a: "1. Levent, 4. Levent, Sanayi Mahallesi, Çırağan, Etiler sınırı ve Maslak sınırındaki plazalar dahil bölgenin tamamında çalışıyoruz. Levent ofis kuleleri ve lüks rezidanslar için hem kurumsal hem konut deneyimimiz güçlüdür.",
  },
  {
    q: "Levent için keşif ve teklif süreci nasıl işliyor?",
    a: "WhatsApp veya telefon üzerinden randevu alıyor, Levent'teki adresinize ya da plazanıza gelerek ücretsiz keşif yapıyoruz. Yerinde ölçü ve ihtiyaç görüşmesinin ardından 2–3 iş günü içinde detaylı teklif ve mood-board paylaşıyoruz.",
  },
  {
    q: "Levent'te örnek projeleriniz var mı?",
    a: "Levent Ofis projemiz 320 m²'lik kurumsal bir alanın açık ofis, toplantı odaları ve lobi tasarımıyla yenilenmesini içerir. Müşteri yorumumuz: 'Çalışanlar ve müşteriler değişimden çok etkilendi' (Serra D.). Konut tarafında da Levent'teki lüks daire referanslarımızı keşif sırasında paylaşıyoruz.",
  },
];
---

<ServiceLayout
  title="Levent İç Mimarlık, Ev ve Ofis Yenileme"
  description="Levent'te iç mimarlık, ev yenileme ve ofis yenileme hizmetleri. Kurumsal mekan ve lüks daire projelerinde Master İç Mimarlık. 0533 039 15 65"
  canonicalUrl={`${CANONICAL_BASE}/istanbul/levent-ic-mimarlik`}
  h1="Levent İç Mimarlık ve Ofis Yenileme"
  eyebrow="İstanbul · Levent"
  lead="Levent'in kurumsal ve lüks konut dokusuna uygun, hem ev hem ofis yenileme projelerinde deneyimli ekibimizle hizmetinizdeyiz. Plaza ofisleri, lüks rezidanslar ve klasik daireler için 8+ yıllık uygulama deneyimimiz var."
  heroImage={heroPath}
  breadcrumb={[
    { label: "Ana Sayfa", href: `${CANONICAL_BASE}/` },
    { label: "İstanbul", href: "/#hizmetler" },
    { label: "Levent" }
  ]}
  structuredData={localSchema}
>

  <div class="grid md:grid-cols-2 gap-12 py-12 border-b border-border">
    <div>
      <h2 class="font-display text-3xl font-bold text-charcoal mb-4">Levent'te İç Mimarlık ve Yenileme</h2>
      <p class="text-muted leading-relaxed mb-4">
        Levent; İstanbul'un finans ve iş merkezi olmasının yanı sıra, üst gelir grubuna hitap eden lüks rezidans ve konutlarıyla da öne çıkan bir semttir. Bu yapı, hem kurumsal ofis projelerinde hem de lüks ev yenilemelerinde uzmanlaşmamızı gerektirdi.
      </p>
      <p class="text-muted leading-relaxed mb-4">
        Levent Ofis projemizde 320 m²'lik kurumsal bir alanı yeniledik. Açık ofis alanları, toplantı odaları ve lobi tasarımıyla çalışan motivasyonunu artıran bir ortam yarattık. Konut tarafında ise Boğaz manzaralı rezidans daireleri ve klasik Levent apartmanlarında uyguladığımız malzeme seçimi ve detay işçiliği farkımızı oluşturuyor.
      </p>
      <p class="text-muted leading-relaxed">
        1. Levent, 4. Levent, Sanayi Mahallesi, Çırağan, Etiler sınırı ve Maslak sınırı başta olmak üzere Levent ve çevresinde aktif olarak hizmet veriyoruz.
      </p>
    </div>
    <div>
      <h3 class="font-semibold text-charcoal mb-4">Levent'te Sunduğumuz Hizmetler</h3>
      <ul class="space-y-3">
        {[
          'Kurumsal ofis yenileme',
          'Lüks konut iç mimarlığı',
          'Anahtar teslim ev yenileme',
          'Toplantı odası ve lobi tasarımı',
          'Açık ofis ve çalışma alanı planlaması',
          '3D görselleştirme ve proje',
        ].map(item => (
          <li class="flex items-start gap-3 text-sm text-muted">
            <span class="w-4 h-4 mt-0.5 shrink-0 bg-gold/15 rounded-full flex items-center justify-center">
              <svg class="w-2.5 h-2.5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            {item}
          </li>
        ))}
      </ul>
      <div class="mt-6 p-4 bg-gold/5 border border-gold/20">
        <p class="text-sm text-charcoal font-medium">Müşteri Yorumu · Levent Ofis</p>
        <p class="text-muted text-sm mt-2 italic">"320 m²'lik ofis alanımızı yenilettik. Çalışanlar ve müşteriler değişimden çok etkilendi; süreç boyunca iş akışımız hiç kesilmedi."</p>
        <p class="text-xs text-gold mt-2">— Serra D., Levent · 5 yıldız</p>
      </div>
    </div>
  </div>

  <ProcessStrip districtName="Levent" />

  <DistrictFAQ districtName="Levent" items={faqItems} />

  <div class="py-12 border-t border-border">
    <h2 class="font-display text-2xl font-bold text-charcoal mb-6">Diğer Hizmetlerimiz</h2>
    <div class="flex flex-wrap gap-3">
      {[
        { label: 'Anahtar Teslim Hizmetler', href: `${CANONICAL_BASE}/hizmetler/anahtar-teslim` },
        { label: 'Villa Yenileme', href: `${CANONICAL_BASE}/hizmetler/anahtar-teslim/villa-yenileme` },
        { label: 'Ofis Yenileme', href: `${CANONICAL_BASE}/hizmetler/anahtar-teslim/ofis-yenileme` },
        { label: '3D Tasarım', href: `${CANONICAL_BASE}/hizmetler/3d-tasarim` },
      ].map(l => (
        <a href={l.href} class="px-4 py-2 border border-border text-sm text-charcoal hover:border-gold hover:text-gold transition-colors">{l.label}</a>
      ))}
    </div>
  </div>

  <RelatedDistricts currentSlug="levent-ic-mimarlik" />

</ServiceLayout>
