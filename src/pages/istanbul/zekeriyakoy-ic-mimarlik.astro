---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import { CANONICAL_BASE } from '../../config';

const localSchema = {
  "@context": "https://schema.org",
  "@type": "InteriorDesigner",
  "name": "Master İç Mimarlık",
  "@id": `${CANONICAL_BASE}/#business`,
  "areaServed": { "@type": "Place", "name": "Zekeriyaköy, İstanbul" },
  "url": `${CANONICAL_BASE}/istanbul/zekeriyakoy-ic-mimarlik`
};
---

<ServiceLayout
  title="Zekeriyaköy Villa Yenileme ve İç Mimarlık | Master İç Mimarlık"
  description="Zekeriyaköy'de villa yenileme ve lüks iç mimarlık hizmetleri. Zekeriyaköy Villa projemizle referansımızı kanıtladık. Ücretsiz keşif: 0533 039 15 65"
  canonicalUrl={`${CANONICAL_BASE}/istanbul/zekeriyakoy-ic-mimarlik`}
  h1="Zekeriyaköy Villa Yenileme ve İç Mimarlık"
  eyebrow="İstanbul · Zekeriyaköy"
  lead="Zekeriyaköy'ün lüks villa dokusuna yakışır, doğayla bütünleşik ve sofistike yaşam alanları tasarlıyoruz. Zekeriyaköy Villa projemiz portföyümüzün önemli bir referans eseridir."
  breadcrumb={[
    { label: "Ana Sayfa", href: `${CANONICAL_BASE}/` },
    { label: "İstanbul", href: `${CANONICAL_BASE}/hizmetler` },
    { label: "Zekeriyaköy" }
  ]}
  structuredData={localSchema}
>

  <div class="grid md:grid-cols-2 gap-12 py-12 border-b border-border">
    <div>
      <h2 class="font-display text-3xl font-bold text-charcoal mb-4">Zekeriyaköy'de Villa Yenileme</h2>
      <p class="text-muted leading-relaxed mb-4">
        Zekeriyaköy; İstanbul'un kuzeyinde, doğayla iç içe, lüks villa ve müstakil ev projelerinin yoğunlaştığı prestijli bir semttir. Bu bölgedeki projeler büyük alan yönetimi, kaliteli malzeme seçimi ve detay odaklı işçilik gerektirmektedir.
      </p>
      <p class="text-muted leading-relaxed mb-4">
        Zekeriyaköy Villa projemizde 450 m²'lik bir villanın tüm iç mekanlarını yeniledik. Referans müşterimiz Murat B., 3D görselleştirme sayesinde süreci sürprizsiz tamamladıklarını belirtti.
      </p>
      <p class="text-muted leading-relaxed">
        Zekeriyaköy, Göktürk, Kemerburgaz ve kuzey İstanbul'un tüm villa bölgelerinde hizmet veriyoruz.
      </p>
    </div>
    <div>
      <h2 class="font-display text-2xl font-bold text-charcoal mb-4">Referans Proje</h2>
      <div class="border border-border p-6">
        <div class="w-full h-40 bg-charcoal/5 flex items-center justify-center mb-4" aria-label="Zekeriyaköy villa yenileme projesi fotoğrafı">
          <span class="text-muted/30 text-xs tracking-widest uppercase">[ Zekeriyaköy Villa Fotoğrafı ]</span>
        </div>
        <h3 class="font-display font-semibold text-charcoal">Zekeriyaköy Villa</h3>
        <p class="text-muted text-xs mt-1">450 m² · Villa yenileme · 2024</p>
        <p class="text-muted text-xs mt-2">"Villayı yeniletirken 3D görselleştirme sayesinde her şeyi önceden gördük. Süreç tam vaat edildiği gibi ilerledi." — Murat B., 5 yıldız</p>
      </div>
    </div>
  </div>

</ServiceLayout>
