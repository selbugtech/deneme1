---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import { CANONICAL_BASE, TEL_URL, EMAIL_URL, WHATSAPP_URL_PROJECT, WHATSAPP_URL_SERVICE } from '../config';
import { optimizedImage } from '../lib/cloudinary';
import { getAggregateRating } from '../lib/google-places';

const aggRating = await getAggregateRating();
const displayRating = aggRating.rating > 0 ? String(aggRating.rating) : '4.9';

interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
  h1: string;
  eyebrow?: string;
  lead: string;
  breadcrumb: { label: string; href?: string }[];
  structuredData?: object | object[];
  heroImage?: string;
  ogImage?: string;
}

const {
  title, description, canonicalUrl, h1,
  eyebrow = 'Hizmetlerimiz', lead,
  breadcrumb, structuredData,
  heroImage, ogImage,
} = Astro.props;

const allServices = [
  { title: 'Anahtar Teslim Hizmetler',    slug: 'anahtar-teslim', desc: 'Tasarımdan uygulamaya tüm süreci biz yönetiyoruz.', image: optimizedImage('/images/salon2.jpeg'), keyword: 'En çok tercih edilen' },
  { title: 'İç Mimarlık Danışmanlığı',    slug: 'ic-mimarlik-danismanligi',    desc: 'Uzman görüş, malzeme seçimi ve rehberlik.',         image: optimizedImage('/images/salon4.jpeg'), keyword: 'Esnek paketler' },
  { title: '3D Tasarım & Proje',          slug: '3d-tasarim',                  desc: 'Uygulamadan önce mekanınızı gerçekçi görselle görün.', image: optimizedImage('/images/mutfak3.jpeg'), keyword: 'Tüm projelerde standart' },
];

const currentSlug = canonicalUrl.split('/').pop() ?? '';
const relatedServices = allServices.filter(s => s.slug !== currentSlug).slice(0, 3);

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumb.map((item, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": item.label,
    ...(item.href ? { "item": item.href } : {})
  }))
};

const allSchema = [
  breadcrumbSchema,
  ...(structuredData ? (Array.isArray(structuredData) ? structuredData : [structuredData]) : [])
];
---

<Layout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage ?? heroImage}
  structuredData={allSchema}
>
  {!heroImage && (
    <style>
      #site-header {
        background: rgba(20, 20, 18, 0.92) !important;
        backdrop-filter: blur(14px) !important;
        box-shadow: 0 1px 24px rgba(0,0,0,0.35) !important;
      }
    </style>
  )}

  <Header />

  <main class="bg-[#F5EFE6] min-h-screen">

    <!-- Hero image (optional) -->
    {heroImage && (
      <div class="relative w-full h-[50vh] md:h-[60vh] overflow-hidden">
        <img src={heroImage} alt={h1} class="w-full h-full object-cover object-center" />
        <div class="absolute inset-0 bg-gradient-to-t from-charcoal via-charcoal/50 to-transparent"></div>

        <div class="absolute top-0 left-0 right-0 pt-28 px-6">
          <div class="max-w-6xl mx-auto">
            <nav class="flex items-center gap-2 text-sm flex-wrap" aria-label="Breadcrumb">
              {breadcrumb.map((item, i) => (
                <>
                  {i > 0 && <span class="text-white/20">/</span>}
                  {item.href
                    ? <a href={item.href} class="text-white/50 hover:text-gold transition-colors">{item.label}</a>
                    : <span class="text-white/70">{item.label}</span>
                  }
                </>
              ))}
            </nav>
          </div>
        </div>

        <div class="absolute bottom-0 left-0 right-0 pb-12 px-6">
          <div class="max-w-6xl mx-auto">
            <div class="flex items-center gap-3 mb-3">
              <span class="w-6 h-px bg-gold"></span>
              <span class="text-[10px] tracking-[0.3em] uppercase text-gold font-medium">{eyebrow}</span>
            </div>
            <h1 class="font-display text-3xl md:text-5xl font-bold text-white max-w-3xl leading-tight">{h1}</h1>
          </div>
        </div>
      </div>
    )}

    <!-- Lead + CTA + Stats -->
    <div class={`max-w-6xl mx-auto px-6 ${heroImage ? 'py-12' : 'pt-28 pb-12'}`}>
      {!heroImage && (
        <nav class="flex items-center gap-2 mb-8 text-sm flex-wrap" aria-label="Breadcrumb">
          {breadcrumb.map((item, i) => (
            <>
              {i > 0 && <span class="text-border">/</span>}
              {item.href
                ? <a href={item.href} class="text-muted hover:text-gold transition-colors">{item.label}</a>
                : <span class="text-charcoal">{item.label}</span>
              }
            </>
          ))}
        </nav>
      )}

      <div class="grid md:grid-cols-2 gap-12 items-start">
        <div>
          {!heroImage && (
            <>
              <div class="flex items-center gap-3 mb-4">
                <span class="w-8 h-px bg-gold"></span>
                <span class="text-xs tracking-[0.3em] uppercase text-gold font-medium">{eyebrow}</span>
              </div>
              <h1 class="font-display text-4xl md:text-5xl font-bold text-charcoal leading-tight mb-6">{h1}</h1>
            </>
          )}
          <p class="text-muted leading-relaxed text-lg mb-8 max-w-lg">{lead}</p>
          <div class="flex flex-col sm:flex-row gap-4 flex-wrap">
            <a
              href={WHATSAPP_URL_SERVICE}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-3 bg-[#25D366] text-white px-8 py-4 text-sm font-semibold tracking-wide hover:bg-[#1EBD5A] transition-colors"
            >
              <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Ücretsiz Keşif Randevusu
            </a>
            <a
              href={TEL_URL}
              class="inline-flex items-center justify-center gap-3 border border-charcoal/20 text-charcoal px-8 py-4 text-sm font-semibold tracking-wide hover:bg-charcoal hover:text-white transition-colors"
            >
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              0533 039 15 65
            </a>
            <a
              href={EMAIL_URL}
              class="inline-flex items-center justify-center gap-3 border border-charcoal/20 text-charcoal px-8 py-4 text-sm font-semibold tracking-wide hover:bg-charcoal hover:text-white transition-colors"
            >
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              E-posta Gönder
            </a>
          </div>
        </div>

        <div class="bg-charcoal p-8 text-white">
          <div class="grid grid-cols-2 gap-6">
            <div>
              <p class="font-display text-3xl font-bold text-gold">150+</p>
              <p class="text-white/50 text-xs tracking-wide mt-1">Tamamlanan Proje</p>
            </div>
            <div>
              <p class="font-display text-3xl font-bold text-gold">8+</p>
              <p class="text-white/50 text-xs tracking-wide mt-1">Yıllık Deneyim</p>
            </div>
            <div>
              <p class="font-display text-3xl font-bold text-gold">200+</p>
              <p class="text-white/50 text-xs tracking-wide mt-1">Mutlu Müşteri</p>
            </div>
            <div>
              <p class="font-display text-3xl font-bold text-gold">{displayRating}</p>
              <p class="text-white/50 text-xs tracking-wide mt-1">Google Puan</p>
            </div>
          </div>
          <div class="mt-6 pt-6 border-t border-white/10">
            <p class="text-white/40 text-xs tracking-wide">Ücretsiz keşif · Hızlı geri dönüş · Anahtar teslim</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Page-specific content slot -->
    <div class="max-w-6xl mx-auto px-6 pb-16">
      <slot />
    </div>

    <!-- Related services -->
    <div class="border-t border-border py-16">
      <div class="max-w-6xl mx-auto px-6">
        <div class="flex items-center justify-between mb-8">
          <div class="flex items-center gap-3">
            <span class="w-8 h-px bg-gold"></span>
            <span class="text-xs tracking-[0.3em] uppercase text-gold font-medium">Diğer Hizmetler</span>
          </div>
          <a href="/#hizmetler" class="text-xs text-muted hover:text-gold transition-colors">Tümünü Gör →</a>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {relatedServices.map(s => (
            <a href={`/hizmetler/${s.slug}`} class="group block border border-border hover:border-gold transition-colors duration-200">
              <div class="overflow-hidden">
                <img src={s.image} alt={s.title} loading="lazy" decoding="async" class="w-full h-44 object-cover group-hover:scale-105 transition-transform duration-500" />
              </div>
              <div class="p-5">
                <p class="text-[10px] tracking-[0.25em] uppercase text-gold mb-2">{s.keyword}</p>
                <h3 class="font-display text-base font-bold text-charcoal group-hover:text-gold transition-colors mb-1">{s.title}</h3>
                <p class="text-muted text-xs leading-relaxed">{s.desc}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Final CTA -->
    <div class="bg-charcoal py-20">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <div class="flex items-center justify-center gap-3 mb-4">
          <span class="w-8 h-px bg-gold"></span>
          <span class="text-xs tracking-[0.3em] uppercase text-gold font-medium">Projenizi Konuşalım</span>
          <span class="w-8 h-px bg-gold"></span>
        </div>
        <h2 class="font-display text-3xl font-bold text-white mb-4">Hayalinizdeki Mekânı Birlikte Tasarlayalım</h2>
        <p class="text-white/50 mb-8 max-w-lg mx-auto">Ücretsiz keşif ve fiyat teklifi için WhatsApp'tan yazın ya da arayın. En kısa sürede size dönüyoruz.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href={WHATSAPP_URL_PROJECT}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-3 bg-[#25D366] text-white px-10 py-4 text-sm font-semibold hover:bg-[#1EBD5A] transition-colors"
          >
            WhatsApp'tan Yaz
          </a>
          <a
            href={TEL_URL}
            class="inline-flex items-center justify-center gap-3 bg-gold text-charcoal px-10 py-4 text-sm font-semibold hover:bg-[#B8965A] transition-colors"
          >
            0533 039 15 65
          </a>
        </div>
      </div>
    </div>

  </main>

  <Footer />
  <WhatsAppFloat />
</Layout>
