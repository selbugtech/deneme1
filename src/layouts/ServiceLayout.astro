---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import Projects from '../components/Projects.astro';
import Contact from '../components/Contact.astro';
import { CANONICAL_BASE, TEL_URL, WHATSAPP_URL_PROJECT, WHATSAPP_URL_SERVICE } from '../config';
import { optimizedImage, optimizedImageW, srcsetImage } from '../lib/cloudinary';
import { getReviewsForDisplay } from '../lib/google-places';

interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
  h1: string;
  eyebrow?: string;
  lead: string;
  breadcrumb: { label: string; href?: string }[];
  structuredData?: object | object[];
  heroImage?: string;
  ogImage?: string;
}

const {
  title, description, canonicalUrl, h1,
  eyebrow = 'Hizmetlerimiz', lead,
  breadcrumb, structuredData,
  heroImage, ogImage,
} = Astro.props;

const reviewData = await getReviewsForDisplay();

const allServices = [
  { title: 'Anahtar Teslim Hizmetler',    slug: 'anahtar-teslim', desc: 'Tasarımdan uygulamaya tüm süreci biz yönetiyoruz.', image: optimizedImage('/images/salon2.jpeg'), keyword: 'En çok tercih edilen' },
  { title: 'İç Mimarlık Danışmanlığı',    slug: 'ic-mimarlik-danismanligi',    desc: 'Uzman görüş, malzeme seçimi ve rehberlik.',         image: optimizedImage('/images/salon4.jpeg'), keyword: 'Esnek paketler' },
  { title: '3D Tasarım & Proje',          slug: '3d-tasarim',                  desc: 'Uygulamadan önce mekanınızı gerçekçi görselle görün.', image: optimizedImage('/images/mutfak3.jpeg'), keyword: 'Tüm projelerde standart' },
];

const currentSlug = canonicalUrl.split('/').pop() ?? '';
const relatedServices = allServices.filter(s => s.slug !== currentSlug).slice(0, 3);

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumb.map((item, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": item.label,
    ...(item.href ? { "item": item.href } : {})
  }))
};

const allSchema = [
  breadcrumbSchema,
  ...(structuredData ? (Array.isArray(structuredData) ? structuredData : [structuredData]) : [])
];
---

<Layout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage ?? heroImage}
  structuredData={allSchema}
>
  <Header />

  <main class="bg-[#F5EFE6] min-h-screen">

    <!-- Hero -->
    <section class="relative w-full overflow-hidden min-h-[88vh] md:min-h-[85vh] flex items-end">
      {heroImage ? (
        <img
          src={heroImage.startsWith('http') ? heroImage : optimizedImageW(heroImage, 1600)}
          srcset={heroImage.startsWith('http') ? undefined : srcsetImage(heroImage, [800, 1200, 1600, 2000])}
          sizes="100vw"
          width="1600"
          height="900"
          alt={h1}
          fetchpriority="high"
          decoding="async"
          class="absolute inset-0 w-full h-full object-cover object-center"
        />
      ) : (
        <div class="absolute inset-0 bg-charcoal"></div>
      )}
      <div class="absolute inset-0 bg-charcoal/75"></div>
      <div class="absolute bottom-0 left-0 right-0 h-28 bg-gradient-to-t from-charcoal/35 to-transparent"></div>

      <!-- Content -->
      <div class="relative z-10 w-full max-w-6xl mx-auto px-6 pt-40 pb-16">
        <div class="max-w-2xl">

          <!-- Breadcrumb -->
          <nav class="flex items-center gap-2 text-xs flex-wrap mb-8" aria-label="Breadcrumb">
            {breadcrumb.map((item, i) => (
              <>
                {i > 0 && <span class="text-white/20">/</span>}
                {item.href
                  ? <a href={item.href} class="text-white/50 hover:text-gold transition-colors">{item.label}</a>
                  : <span class="text-white/70">{item.label}</span>
                }
              </>
            ))}
          </nav>

          <div class="flex items-center gap-3 mb-7">
            <span class="w-8 h-px bg-gold"></span>
            <span class="text-[10px] sm:text-xs tracking-[0.2em] sm:tracking-[0.3em] uppercase text-gold font-medium">{eyebrow}</span>
          </div>

          <h1 class="font-display text-[2.2rem] sm:text-5xl md:text-6xl lg:text-[4rem] font-bold leading-[1.05] text-white mb-6">{h1}</h1>

          <p class="text-white/85 text-base sm:text-lg leading-relaxed max-w-xl mb-8">{lead}</p>

          <!-- Free site visit badge -->
          <div class="mb-5">
            <span class="inline-flex items-center gap-3 bg-[#faf6f1] text-charcoal px-7 py-3.5 sm:px-8 sm:py-4 text-base sm:text-lg tracking-[0.2em] uppercase font-bold shadow-lg shadow-black/30">
              <span class="w-2.5 h-2.5 rounded-full bg-gold"></span>
              Ücretsiz Keşif
            </span>
          </div>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-4 mb-10">
            <a
              href={WHATSAPP_URL_SERVICE}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-3 bg-[#25D366] text-white px-8 py-4 text-sm font-semibold tracking-wide hover:bg-[#1EBD5A] transition-colors duration-200 shadow-lg shadow-green-900/40"
            >
              <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Ücretsiz Keşif Randevusu
            </a>
            <a
              href={TEL_URL}
              class="inline-flex items-center justify-center gap-3 bg-white/10 backdrop-blur-sm border border-white/25 text-white px-8 py-4 text-sm font-semibold tracking-wide hover:bg-white/20 transition-colors duration-200"
            >
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z"/>
              </svg>
              0533 039 15 65
            </a>
          </div>

          <!-- Info strip -->
          <div class="flex flex-wrap items-center gap-6 pt-6 border-t border-white/15">
            <div>
              <p class="text-[10px] tracking-[0.25em] uppercase text-white/45 mb-1">Telefon / WhatsApp</p>
              <a href={TEL_URL} class="text-white font-semibold hover:text-gold transition-colors">0533 039 15 65</a>
            </div>
            <div class="w-px h-8 bg-white/15"></div>
            <div>
              <p class="text-[10px] tracking-[0.25em] uppercase text-white/45 mb-1">Hizmet Bölgesi</p>
              <p class="text-white font-semibold">İstanbul &amp; Çevre İller</p>
            </div>
            <div class="w-px h-8 bg-white/15 hidden sm:block"></div>
            <div class="hidden sm:block">
              <p class="text-[10px] tracking-[0.25em] uppercase text-white/45 mb-1">Ücretsiz Keşif</p>
              <p class="text-white font-semibold">Randevu Alın</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Projects (social proof) -->
    <Projects />

    <!-- Page-specific content with auto-collapse -->
    <div class="max-w-6xl mx-auto px-6 py-16">
      <div class="article-collapse" data-collapsed="true">
        <div class="prose prose-charcoal max-w-none service-content">
          <slot />
        </div>
        <div class="article-fade" aria-hidden="true"></div>
      </div>
      <button type="button" class="article-toggle" aria-expanded="false">
        <span class="article-toggle-open">Detaylı Bilgiyi Gör</span>
        <span class="article-toggle-close">Daralt</span>
        <svg class="w-4 h-4 article-toggle-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </button>
    </div>

    <!-- Related services -->
    <div class="border-t border-border py-16">
      <div class="max-w-6xl mx-auto px-6">
        <div class="flex items-center justify-between mb-8">
          <div class="flex items-center gap-3">
            <span class="w-8 h-px bg-gold"></span>
            <span class="text-xs tracking-[0.3em] uppercase text-gold font-medium">Diğer Hizmetler</span>
          </div>
          <a href="/#hizmetler" class="text-xs text-muted hover:text-gold transition-colors">Tümünü Gör →</a>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {relatedServices.map(s => (
            <a href={`/hizmetler/${s.slug}`} class="group block border border-border hover:border-gold transition-colors duration-200">
              <div class="overflow-hidden">
                <img src={s.image} alt={s.title} loading="lazy" decoding="async" class="w-full h-44 object-cover group-hover:scale-105 transition-transform duration-500" />
              </div>
              <div class="p-5">
                <p class="text-[10px] tracking-[0.25em] uppercase text-gold mb-2">{s.keyword}</p>
                <h3 class="font-display text-base font-bold text-charcoal group-hover:text-gold transition-colors mb-1">{s.title}</h3>
                <p class="text-muted text-xs leading-relaxed">{s.desc}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Contact section (full) -->
    <Contact rating={reviewData.rating} totalRatings={reviewData.totalRatings} />

  </main>

  <Footer />
  <WhatsAppFloat />
</Layout>

<style is:global>
  .service-content h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: #1C1C1A;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .service-content h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: #1C1C1A;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .service-content p {
    color: #787874;
    line-height: 1.75;
    margin-bottom: 1.25rem;
  }
  .service-content ul {
    color: #787874;
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .service-content ul li {
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }
  .service-content strong {
    color: #1C1C1A;
    font-weight: 600;
  }
  .service-content a {
    color: #A8894A;
    text-decoration: underline;
  }

  /* Article auto-collapse (shared with BlogPost) */
  .article-collapse {
    position: relative;
    overflow: hidden;
    transition: max-height 0.4s ease;
  }
  .article-collapse[data-collapsed="true"] {
    max-height: 600px;
  }
  .article-collapse[data-collapsed="false"] {
    max-height: none;
  }
  .article-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 180px;
    background: linear-gradient(to bottom, rgba(245, 239, 230, 0), #F5EFE6 85%);
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .article-collapse[data-collapsed="false"] .article-fade {
    opacity: 0;
  }
  .article-toggle {
    margin-top: 1.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #1C1C1A;
    color: #fff;
    padding: 0.875rem 1.75rem;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    cursor: pointer;
    border: none;
    transition: background 0.2s ease;
  }
  .article-toggle:hover {
    background: #A8894A;
  }
  .article-toggle-close,
  .article-toggle[aria-expanded="true"] .article-toggle-open {
    display: none;
  }
  .article-toggle[aria-expanded="true"] .article-toggle-close {
    display: inline;
  }
  .article-toggle[aria-expanded="true"] .article-toggle-icon {
    transform: rotate(180deg);
  }
  .article-toggle-icon {
    transition: transform 0.3s ease;
  }
</style>

<script is:inline>
  document.querySelectorAll('.article-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const wrap = btn.parentElement?.querySelector('.article-collapse');
      if (!wrap) return;
      const collapsed = wrap.getAttribute('data-collapsed') === 'true';
      wrap.setAttribute('data-collapsed', collapsed ? 'false' : 'true');
      btn.setAttribute('aria-expanded', collapsed ? 'true' : 'false');
      if (!collapsed) {
        wrap.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });
</script>
