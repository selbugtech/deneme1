---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import { CANONICAL_BASE } from '../config';

interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
  h1: string;
  eyebrow?: string;
  lead: string;
  breadcrumb: { label: string; href?: string }[];
  structuredData?: object | object[];
}

const { title, description, canonicalUrl, h1, eyebrow = 'Hizmetlerimiz', lead, breadcrumb, structuredData } = Astro.props;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumb.map((item, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": item.label,
    ...(item.href ? { "item": item.href } : {})
  }))
};

const allSchema = [
  breadcrumbSchema,
  ...(structuredData ? (Array.isArray(structuredData) ? structuredData : [structuredData]) : [])
];
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl} structuredData={allSchema}>
  <Header />

  <main class="pt-24 bg-warm-white min-h-screen">

    <!-- Page hero -->
    <div class="max-w-6xl mx-auto px-6 py-16">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 mb-8 text-sm flex-wrap" aria-label="Breadcrumb">
        {breadcrumb.map((item, i) => (
          <>
            {i > 0 && <span class="text-border">/</span>}
            {item.href
              ? <a href={item.href} class="text-muted hover:text-gold transition-colors">{item.label}</a>
              : <span class="text-charcoal">{item.label}</span>
            }
          </>
        ))}
      </nav>

      <div class="grid md:grid-cols-2 gap-12 items-start">
        <div>
          <div class="flex items-center gap-3 mb-4">
            <span class="w-8 h-px bg-gold"></span>
            <span class="text-xs tracking-[0.3em] uppercase text-gold font-medium">{eyebrow}</span>
          </div>
          <h1 class="font-display text-4xl md:text-5xl font-bold text-charcoal leading-tight mb-6">
            {h1}
          </h1>
          <p class="text-muted leading-relaxed text-lg mb-8 max-w-lg">{lead}</p>

          <!-- CTA buttons -->
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="https://wa.me/905330391565?text=Merhaba%2C%20hizmet%20hakk%C4%B1nda%20bilgi%20almak%20istiyorum."
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-3 bg-[#25D366] text-white px-8 py-4 text-sm font-semibold tracking-wide hover:bg-[#1EBD5A] transition-colors"
            >
              <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Ücretsiz Keşif Randevusu
            </a>
            <a
              href="tel:+905330391565"
              class="inline-flex items-center justify-center gap-3 border border-charcoal/20 text-charcoal px-8 py-4 text-sm font-semibold tracking-wide hover:bg-charcoal hover:text-white transition-colors"
            >
              0533 039 15 65
            </a>
          </div>
        </div>

        <!-- Stats card -->
        <div class="bg-charcoal p-8 text-white">
          <div class="grid grid-cols-2 gap-6">
            <div>
              <p class="font-display text-3xl font-bold text-gold">150+</p>
              <p class="text-white/50 text-xs tracking-wide mt-1">Tamamlanan Proje</p>
            </div>
            <div>
              <p class="font-display text-3xl font-bold text-gold">8+</p>
              <p class="text-white/50 text-xs tracking-wide mt-1">Yıllık Deneyim</p>
            </div>
            <div>
              <p class="font-display text-3xl font-bold text-gold">200+</p>
              <p class="text-white/50 text-xs tracking-wide mt-1">Mutlu Müşteri</p>
            </div>
            <div>
              <p class="font-display text-3xl font-bold text-gold">5.0</p>
              <p class="text-white/50 text-xs tracking-wide mt-1">Google Puan</p>
            </div>
          </div>
          <div class="mt-6 pt-6 border-t border-white/10">
            <p class="text-white/40 text-xs tracking-wide">Ücretsiz keşif · Hızlı geri dönüş · Anahtar teslim</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Main content slot -->
    <div class="max-w-6xl mx-auto px-6 pb-16">
      <slot />
    </div>

    <!-- Final CTA -->
    <div class="bg-charcoal py-20">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <h2 class="font-display text-3xl font-bold text-white mb-4">Projenizi Konuşalım</h2>
        <p class="text-white/50 mb-8 max-w-lg mx-auto">Ücretsiz keşif ve fiyat teklifi için WhatsApp'tan yazın ya da arayın. En kısa sürede size dönüyoruz.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="https://wa.me/905330391565?text=Merhaba%2C%20proje%20hakk%C4%B1nda%20g%C3%B6r%C3%BC%C5%9Fmek%20istiyorum."
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-3 bg-[#25D366] text-white px-10 py-4 text-sm font-semibold hover:bg-[#1EBD5A] transition-colors"
          >
            WhatsApp'tan Yaz
          </a>
          <a
            href="tel:+905330391565"
            class="inline-flex items-center justify-center gap-3 bg-gold text-charcoal px-10 py-4 text-sm font-semibold hover:bg-[#B8965A] transition-colors"
          >
            0533 039 15 65
          </a>
        </div>
      </div>
    </div>

  </main>

  <Footer />
  <WhatsAppFloat />
</Layout>
