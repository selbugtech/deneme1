---
import { SEO } from 'astro-seo';
import { CANONICAL_BASE, OG_IMAGE, SITE_NAME, SITE_PHONE } from '../config';
import { getAggregateRating } from '../lib/google-places';
import type { GoogleReview } from '../lib/google-places';

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  ogType?: string;
  structuredData?: object | object[];
  reviewData?: { reviews: GoogleReview[]; rating: number; totalRatings: number };
  lcpImage?: string;
  lcpImageSrcset?: string;
  lcpImageSizes?: string;
}

const {
  title = 'Master İç Mimarlık | Anahtar Teslim Ev, Villa ve Mağaza Yenileme | İstanbul',
  description = 'İstanbul\'da anahtar teslim ev yenileme, villa yenileme, mağaza ve ofis yenileme hizmetleri. Master İç Mimarlık ile mekanınızı hayalinizdeki tasarıma kavuşturun. 0533 039 15 65',
  canonicalUrl,
  ogImage = OG_IMAGE,
  ogType = 'website',
  structuredData,
  reviewData,
  lcpImage,
  lcpImageSrcset,
  lcpImageSizes,
} = Astro.props;

// aggregateRating: reviewData varsa ondan al, yoksa API'den çek
const aggRating = reviewData
  ? { rating: reviewData.rating, totalRatings: reviewData.totalRatings }
  : await getAggregateRating();

const canonical = canonicalUrl ?? `${CANONICAL_BASE}${Astro.url.pathname}`;

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${CANONICAL_BASE}/#website`,
  "url": `${CANONICAL_BASE}/`,
  "name": SITE_NAME,
  "description": "İstanbul'da anahtar teslim ev yenileme, villa yenileme, mağaza ve ofis yenileme hizmetleri.",
  "inLanguage": "tr-TR",
  "publisher": { "@id": `${CANONICAL_BASE}/#organization` }
};

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": `${CANONICAL_BASE}/#organization`,
  "name": SITE_NAME,
  "url": `${CANONICAL_BASE}/`,
  "logo": {
    "@type": "ImageObject",
    "url": `${CANONICAL_BASE}/favicon.png`,
    "contentUrl": `${CANONICAL_BASE}/favicon.png`
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": SITE_PHONE,
    "contactType": "customer service",
    "availableLanguage": "Turkish"
  }
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "InteriorDesigner",
  "@id": `${CANONICAL_BASE}/#business`,
  "name": SITE_NAME,
  "url": `${CANONICAL_BASE}/`,
  "logo": `${CANONICAL_BASE}/favicon.png`,
  "image": OG_IMAGE,
  "description": "İstanbul'da anahtar teslim ev yenileme, villa yenileme, mağaza ve ofis yenileme hizmetleri.",
  "telephone": SITE_PHONE,
  "priceRange": "₺₺₺",
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
      "opens": "09:00",
      "closes": "19:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Saturday",
      "opens": "10:00",
      "closes": "17:00"
    }
  ],
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Akasya A Kule, No: 25/A, Çeçen Sok., Acıbadem",
    "addressLocality": "Üsküdar",
    "addressRegion": "İstanbul",
    "postalCode": "34660",
    "addressCountry": "TR"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 41.001739,
    "longitude": 29.0543556
  },
  "areaServed": [
    { "@type": "City", "name": "İstanbul" },
    { "@type": "AdministrativeArea", "name": "İstanbul ili" }
  ],
  ...(aggRating.rating > 0 ? {
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": String(aggRating.rating),
      "reviewCount": String(aggRating.totalRatings),
      "bestRating": "5",
      "worstRating": "1"
    }
  } : {}),
  ...(reviewData && reviewData.reviews.length > 0 ? {
    "review": reviewData.reviews.map(r => ({
      "@type": "Review",
      "author": { "@type": "Person", "name": r.author_name },
      "reviewRating": {
        "@type": "Rating",
        "ratingValue": String(r.rating),
        "bestRating": "5",
        "worstRating": "1"
      },
      "reviewBody": r.text,
      "datePublished": new Date(r.time * 1000).toISOString().split('T')[0]
    }))
  } : {})
};

const allStructuredData = [
  websiteSchema,
  organizationSchema,
  localBusinessSchema,
  ...(structuredData ? (Array.isArray(structuredData) ? structuredData : [structuredData]) : [])
];
---

<!DOCTYPE html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <SEO
      title={title}
      description={description}
      canonical={canonical}
      openGraph={{
        basic: {
          title: title,
          type: ogType,
          image: ogImage,
          url: canonical,
        },
        optional: {
          description: description,
          locale: 'tr_TR',
          siteName: SITE_NAME,
        },
        image: {
          width: 1200,
          height: 630,
          alt: `${SITE_NAME} — İstanbul İç Mimarlık ve Ev Yenileme`,
        },
      }}
      twitter={{
        card: 'summary_large_image',
        title: title,
        description: description,
        image: ogImage,
      }}
      extend={{
        meta: [
          { name: 'author', content: SITE_NAME },
          { name: 'robots', content: 'index, follow' },
        ],
      }}
    />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- LCP image preload — responsive (mobilde küçük, masaüstünde büyük boyut) -->
    {lcpImage && (
      <link
        rel="preload"
        as="image"
        href={lcpImage}
        imagesrcset={lcpImageSrcset}
        imagesizes={lcpImageSizes ?? '100vw'}
        fetchpriority="high"
      />
    )}

    <!-- Google Fonts — non-blocking (critical rendering path dışında) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" />
    </noscript>

    <!-- Schema.org Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(allStructuredData).replace(/<\//g, '<\\/')} />

    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-KKHH7KWV');</script>
    <!-- End Google Tag Manager -->
  </head>
  <body class="bg-warm-white text-charcoal font-sans antialiased">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-KKHH7KWV"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    <slot />

    <script>
      // Google Ads + GA4 — tarayıcı boşta kaldığında yükle (FCP/LCP engelleme yok)
      function _loadTracking() {
        // Google Ads (gtag.js)
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=AW-18023437304';
        s.onload = function() {
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          window.gtag = gtag;
          gtag('js', new Date());
          gtag('config', 'AW-18023437304');
        };
        document.head.appendChild(s);

        // Google Analytics GA4 (G-G7QH86RT87)
        var ga = document.createElement('script');
        ga.async = true;
        ga.src = 'https://www.googletagmanager.com/gtag/js?id=G-G7QH86RT87';
        ga.onload = function() {
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          window.gtag = window.gtag || gtag;
          gtag('js', new Date());
          gtag('config', 'G-G7QH86RT87');
        };
        document.head.appendChild(ga);
      }
      if ('requestIdleCallback' in window) {
        requestIdleCallback(_loadTracking, { timeout: 3000 });
      } else {
        setTimeout(_loadTracking, 3000);
      }
    </script>

    <script>
      // Scroll reveal — requestIdleCallback ile ertele (TBT azalır)
      function _initReveal() {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
              }
            });
          },
          { threshold: 0.1 }
        );
        document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
      }
      if ('requestIdleCallback' in window) {
        requestIdleCallback(_initReveal);
      } else {
        setTimeout(_initReveal, 0);
      }
    </script>
  </body>
</html>

<style is:global>
  html { scroll-behavior: auto; overflow-x: hidden; }
  body { overflow-x: hidden; }

  @media (prefers-reduced-motion: no-preference) {
    html { scroll-behavior: smooth; }
  }

  /* Reveal animasyonu — azaltılmış hareket tercih etmeyenler için */
  @media (prefers-reduced-motion: no-preference) {
    .reveal {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 0.65s ease, transform 0.65s ease;
    }
    .reveal-d1 { transition-delay: 0.1s; }
    .reveal-d2 { transition-delay: 0.2s; }
    .reveal-d3 { transition-delay: 0.3s; }
    .reveal-d4 { transition-delay: 0.4s; }
    .reveal-d5 { transition-delay: 0.5s; }
  }

  /* Azaltılmış hareket tercih edenler: animasyon yok, direkt göster */
  @media (prefers-reduced-motion: reduce) {
    .reveal { opacity: 1; transform: none; }
  }

  .reveal.is-visible { opacity: 1; transform: translateY(0); }
</style>
