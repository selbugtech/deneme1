---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import Projects from '../components/Projects.astro';
import Contact from '../components/Contact.astro';
import { CANONICAL_BASE, TEL_URL, WHATSAPP_URL_PROJECT } from '../config';
import { allPosts } from '../data/blog-posts';
import { getReviewsForDisplay } from '../lib/google-places';

interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
  publishDate: string;
  readingTime?: string;
  ogImage?: string;
  heroImage?: string;
  tag?: string;
}

const { title, description, canonicalUrl, publishDate, readingTime = '5 dk okuma', ogImage, heroImage, tag = 'Rehber' } = Astro.props;

const reviewData = await getReviewsForDisplay();

// Derive current slug from canonicalUrl, then pick 3 other posts as related
const currentSlug = canonicalUrl.split('/').pop() ?? '';
const relatedPosts = allPosts.filter(p => p.slug !== currentSlug).slice(0, 3);

const displayTitle = title.split('|')[0].trim();
const formattedDate = new Date(publishDate).toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' });

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": displayTitle,
  "description": description,
  "author": {
    "@type": "Organization",
    "name": "Master İç Mimarlık",
    "@id": `${CANONICAL_BASE}/#organization`
  },
  "publisher": {
    "@type": "Organization",
    "name": "Master İç Mimarlık",
    "logo": {
      "@type": "ImageObject",
      "url": `${CANONICAL_BASE}/favicon.png`
    }
  },
  "datePublished": publishDate,
  "dateModified": publishDate,
  "url": canonicalUrl,
  "image": ogImage ?? heroImage ?? `${CANONICAL_BASE}/og-image.png`,
  "inLanguage": "tr-TR",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalUrl
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": `${CANONICAL_BASE}/` },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": `${CANONICAL_BASE}/blog` },
    { "@type": "ListItem", "position": 3, "name": displayTitle, "item": canonicalUrl }
  ]
};
---

<Layout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage ?? heroImage}
  ogType="article"
  structuredData={[articleSchema, breadcrumbSchema]}
>
  <Header />

  <main class="bg-warm-white min-h-screen">

    <!-- Hero -->
    <section class="relative w-full overflow-hidden min-h-[88vh] md:min-h-[85vh] flex items-end">
      {heroImage ? (
        <img
          src={heroImage}
          alt={displayTitle}
          fetchpriority="high"
          decoding="async"
          class="absolute inset-0 w-full h-full object-cover object-center"
        />
      ) : (
        <div class="absolute inset-0 bg-charcoal"></div>
      )}
      <div class="absolute inset-0 bg-charcoal/75"></div>
      <div class="absolute bottom-0 left-0 right-0 h-28 bg-gradient-to-t from-charcoal/35 to-transparent"></div>

      <!-- Top breadcrumb -->
      <div class="absolute top-0 left-0 right-0 pt-28 px-6">
        <div class="max-w-6xl mx-auto">
          <nav class="flex items-center gap-2 text-sm flex-wrap" aria-label="Breadcrumb">
            <a href="/" class="text-white/50 hover:text-gold transition-colors">Ana Sayfa</a>
            <span class="text-white/20">/</span>
            <a href="/blog" class="text-white/50 hover:text-gold transition-colors">Blog</a>
            <span class="text-white/20">/</span>
            <span class="text-white/70">{displayTitle.length > 50 ? displayTitle.substring(0, 50) + '…' : displayTitle}</span>
          </nav>
        </div>
      </div>

      <!-- Content -->
      <div class="relative z-10 w-full max-w-6xl mx-auto px-6 pt-32 pb-16">
        <div class="max-w-2xl">

          <!-- Eyebrow -->
          <div class="flex items-center gap-3 mb-7">
            <span class="w-8 h-px bg-gold"></span>
            <span class="text-[10px] sm:text-xs tracking-[0.2em] sm:tracking-[0.3em] uppercase text-gold font-medium">{tag}</span>
          </div>

          <!-- H1 -->
          <h1 class="font-display text-[2.2rem] sm:text-5xl md:text-6xl lg:text-[4rem] font-bold leading-[1.05] text-white mb-6">{displayTitle}</h1>

          <!-- Meta -->
          <div class="flex items-center gap-4 text-xs text-white/55 mb-7">
            <time datetime={publishDate}>{formattedDate}</time>
            <span>·</span>
            <span>{readingTime}</span>
            <span>·</span>
            <span>Master İç Mimarlık</span>
          </div>

          <!-- Lead -->
          <p class="text-white/85 text-base sm:text-lg leading-relaxed max-w-xl mb-8">{description}</p>

          <!-- Free site visit badge -->
          <div class="mb-5">
            <span class="inline-flex items-center gap-3 bg-[#faf6f1] text-charcoal px-7 py-3.5 sm:px-8 sm:py-4 text-base sm:text-lg tracking-[0.2em] uppercase font-bold shadow-lg shadow-black/30">
              <span class="w-2.5 h-2.5 rounded-full bg-gold"></span>
              Ücretsiz Keşif
            </span>
          </div>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-4 mb-10">
            <a
              href={WHATSAPP_URL_PROJECT}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-3 bg-[#25D366] text-white px-8 py-4 text-sm font-semibold tracking-wide hover:bg-[#1EBD5A] transition-colors duration-200 shadow-lg shadow-green-900/40"
            >
              <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp'tan Yaz
            </a>
            <a
              href={TEL_URL}
              class="inline-flex items-center justify-center gap-3 bg-white/10 backdrop-blur-sm border border-white/25 text-white px-8 py-4 text-sm font-semibold tracking-wide hover:bg-white/20 transition-colors duration-200"
            >
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z"/>
              </svg>
              Hemen Ara
            </a>
          </div>

          <!-- Info strip -->
          <div class="flex flex-wrap items-center gap-6 pt-6 border-t border-white/15">
            <div>
              <p class="text-[10px] tracking-[0.25em] uppercase text-white/45 mb-1">Telefon / WhatsApp</p>
              <a href={TEL_URL} class="text-white font-semibold hover:text-gold transition-colors">0533 039 15 65</a>
            </div>
            <div class="w-px h-8 bg-white/15"></div>
            <div>
              <p class="text-[10px] tracking-[0.25em] uppercase text-white/45 mb-1">Hizmet Bölgesi</p>
              <p class="text-white font-semibold">İstanbul &amp; Çevre İller</p>
            </div>
            <div class="w-px h-8 bg-white/15 hidden sm:block"></div>
            <div class="hidden sm:block">
              <p class="text-[10px] tracking-[0.25em] uppercase text-white/45 mb-1">Ücretsiz Keşif</p>
              <p class="text-white font-semibold">Randevu Alın</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Projects (social proof) -->
    <Projects />

    <!-- Article + sidebar -->
    <div class="max-w-6xl mx-auto px-6 py-16">
      <div class="grid md:grid-cols-3 gap-12 items-start">

        <!-- Article content with auto-collapse -->
        <div class="md:col-span-2">
          <div class="article-collapse" data-collapsed="true">
            <article class="prose prose-charcoal max-w-none">
              <slot />
            </article>
            <div class="article-fade" aria-hidden="true"></div>
          </div>
          <button type="button" class="article-toggle" aria-expanded="false">
            <span class="article-toggle-open">Detaylı Bilgiyi Gör</span>
            <span class="article-toggle-close">Daralt</span>
            <svg class="w-4 h-4 article-toggle-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
        </div>

        <!-- Sidebar: related posts -->
        <aside class="md:sticky md:top-28">
          <div class="flex items-center gap-2 mb-4">
            <span class="w-5 h-px bg-gold"></span>
            <span class="text-[10px] tracking-[0.3em] uppercase text-gold font-medium">İlgili Yazılar</span>
          </div>
          <ul class="space-y-4">
            {relatedPosts.map(post => (
              <li>
                <a href={`/blog/${post.slug}`} class="group flex gap-3 items-start">
                  <img
                    src={post.image}
                    alt={post.title}
                    loading="lazy"
                    decoding="async"
                    class="w-16 h-14 object-cover shrink-0 group-hover:opacity-80 transition-opacity"
                  />
                  <div>
                    <p class="text-[10px] tracking-widest uppercase text-gold mb-1">{post.tag}</p>
                    <p class="text-xs text-charcoal font-medium leading-snug group-hover:text-gold transition-colors line-clamp-2">{post.title.split('|')[0].trim()}</p>
                    <p class="text-[10px] text-muted mt-1">{post.readingTime} okuma</p>
                  </div>
                </a>
              </li>
            ))}
          </ul>
          <a
            href="/blog"
            class="mt-5 inline-flex items-center gap-1.5 text-xs text-gold hover:underline"
          >
            Tüm yazıları gör
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </aside>

      </div>
    </div>

    <!-- Related posts visual strip -->
    <div class="border-t border-border py-16 bg-charcoal/3">
      <div class="max-w-6xl mx-auto px-6">
        <div class="flex items-center justify-between mb-8">
          <div class="flex items-center gap-3">
            <span class="w-8 h-px bg-gold"></span>
            <span class="text-xs tracking-[0.3em] uppercase text-gold font-medium">Diğer Yazılar</span>
          </div>
          <a href="/blog" class="text-xs text-muted hover:text-gold transition-colors tracking-wide">Tümünü Gör →</a>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {relatedPosts.map(post => (
            <a href={`/blog/${post.slug}`} class="group block">
              <div class="overflow-hidden mb-4">
                <img
                  src={post.image}
                  alt={post.title}
                  loading="lazy"
                  decoding="async"
                  class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-500"
                />
              </div>
              <div class="flex items-center gap-3 mb-2">
                <span class="text-[10px] tracking-[0.25em] uppercase text-gold font-medium">{post.tag}</span>
                <span class="text-border">·</span>
                <time class="text-[10px] text-muted" datetime={post.date}>
                  {new Date(post.date).toLocaleDateString('tr-TR', { month: 'short', year: 'numeric' })}
                </time>
              </div>
              <h3 class="font-display text-base font-bold text-charcoal group-hover:text-gold transition-colors leading-snug mb-2">
                {post.title.split('|')[0].trim()}
              </h3>
              <p class="text-muted text-xs leading-relaxed line-clamp-2">{post.excerpt}</p>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Contact section (full) -->
    <Contact rating={reviewData.rating} totalRatings={reviewData.totalRatings} />

  </main>

  <Footer />
  <WhatsAppFloat />
</Layout>

<style is:global>
  article.prose h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: #1C1C1A;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  article.prose h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: #1C1C1A;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  article.prose p {
    color: #787874;
    line-height: 1.75;
    margin-bottom: 1.25rem;
  }
  article.prose ul {
    color: #787874;
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  article.prose ul li {
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }
  article.prose strong {
    color: #1C1C1A;
    font-weight: 600;
  }
  article.prose a {
    color: #A8894A;
    text-decoration: underline;
  }
  article.prose blockquote {
    border-left: 3px solid #A8894A;
    padding-left: 1.25rem;
    font-style: italic;
    color: #787874;
    margin: 1.5rem 0;
  }
  article.prose table {
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    width: 100%;
  }
  article.prose pre {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    max-width: 100%;
  }
  article.prose code {
    word-break: break-word;
  }
  article.prose img {
    max-width: 100%;
    height: auto;
  }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Article auto-collapse */
  .article-collapse {
    position: relative;
    overflow: hidden;
    transition: max-height 0.4s ease;
  }
  .article-collapse[data-collapsed="true"] {
    max-height: 600px;
  }
  .article-collapse[data-collapsed="false"] {
    max-height: none;
  }
  .article-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 180px;
    background: linear-gradient(to bottom, rgba(250, 246, 241, 0), #faf6f1 85%);
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .article-collapse[data-collapsed="false"] .article-fade {
    opacity: 0;
  }
  .article-toggle {
    margin-top: 1.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #1C1C1A;
    color: #fff;
    padding: 0.875rem 1.75rem;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    cursor: pointer;
    border: none;
    transition: background 0.2s ease;
  }
  .article-toggle:hover {
    background: #A8894A;
  }
  .article-toggle-close,
  .article-toggle[aria-expanded="true"] .article-toggle-open {
    display: none;
  }
  .article-toggle[aria-expanded="true"] .article-toggle-close {
    display: inline;
  }
  .article-toggle[aria-expanded="true"] .article-toggle-icon {
    transform: rotate(180deg);
  }
  .article-toggle-icon {
    transition: transform 0.3s ease;
  }
</style>

<script is:inline>
  document.querySelectorAll('.article-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const wrap = btn.parentElement?.querySelector('.article-collapse');
      if (!wrap) return;
      const collapsed = wrap.getAttribute('data-collapsed') === 'true';
      wrap.setAttribute('data-collapsed', collapsed ? 'false' : 'true');
      btn.setAttribute('aria-expanded', collapsed ? 'true' : 'false');
      if (collapsed) {
        // expanded — scroll position kept
      } else {
        // re-collapsed — scroll back near article start
        wrap.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });
</script>
