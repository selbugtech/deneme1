---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import { CANONICAL_BASE } from '../config';

interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
  publishDate: string;
  readingTime?: string;
  ogImage?: string;
}

const { title, description, canonicalUrl, publishDate, readingTime = '5 dk okuma', ogImage } = Astro.props;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "author": { "@type": "Organization", "name": "Master İç Mimarlık" },
  "publisher": {
    "@type": "Organization",
    "name": "Master İç Mimarlık",
    "logo": { "@type": "ImageObject", "url": `${CANONICAL_BASE}/favicon.svg` }
  },
  "datePublished": publishDate,
  "dateModified": publishDate,
  "url": canonicalUrl,
  "image": ogImage ?? `${CANONICAL_BASE}/og-image.jpg`
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": `${CANONICAL_BASE}/` },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": `${CANONICAL_BASE}/blog` },
    { "@type": "ListItem", "position": 3, "name": title, "item": canonicalUrl }
  ]
};
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl} ogImage={ogImage} ogType="article" structuredData={[articleSchema, breadcrumbSchema]}>
  <Header />

  <main class="pt-24 bg-warm-white min-h-screen">

    <!-- Article header -->
    <div class="max-w-3xl mx-auto px-6 py-16">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 mb-8 text-sm flex-wrap" aria-label="Breadcrumb">
        <a href={`${CANONICAL_BASE}/`} class="text-muted hover:text-gold transition-colors">Ana Sayfa</a>
        <span class="text-border">/</span>
        <a href={`${CANONICAL_BASE}/blog`} class="text-muted hover:text-gold transition-colors">Blog</a>
        <span class="text-border">/</span>
        <span class="text-charcoal">{title.split('|')[0].trim()}</span>
      </nav>

      <!-- Meta -->
      <div class="flex items-center gap-4 text-xs text-muted mb-6">
        <time datetime={publishDate}>{new Date(publishDate).toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
        <span>·</span>
        <span>{readingTime}</span>
        <span>·</span>
        <span>Master İç Mimarlık</span>
      </div>

      <h1 class="font-display text-4xl md:text-5xl font-bold text-charcoal leading-tight mb-6">{title.split('|')[0].trim()}</h1>
      <p class="text-muted text-lg leading-relaxed">{description}</p>
    </div>

    <!-- Article content -->
    <article class="max-w-3xl mx-auto px-6 pb-16 prose prose-charcoal max-w-none">
      <slot />
    </article>

    <!-- Article CTA -->
    <div class="bg-charcoal py-16">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <h2 class="font-display text-2xl font-bold text-white mb-3">Projenizi Konuşalım</h2>
        <p class="text-white/50 mb-6 text-sm">Ücretsiz keşif randevusu için WhatsApp'tan yazın veya arayın.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="https://wa.me/905330391565?text=Merhaba%2C%20proje%20hakk%C4%B1nda%20g%C3%B6r%C3%BC%C5%9Fmek%20istiyorum."
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-3 bg-[#25D366] text-white px-10 py-4 text-sm font-semibold hover:bg-[#1EBD5A] transition-colors"
          >
            WhatsApp'tan Yaz
          </a>
          <a
            href="tel:+905330391565"
            class="inline-flex items-center justify-center gap-3 bg-gold text-charcoal px-10 py-4 text-sm font-semibold hover:bg-[#B8965A] transition-colors"
          >
            0533 039 15 65
          </a>
        </div>
      </div>
    </div>

  </main>

  <Footer />
  <WhatsAppFloat />
</Layout>

<style is:global>
  article.prose h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: #1C1C1A;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  article.prose h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: #1C1C1A;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  article.prose p {
    color: #787874;
    line-height: 1.75;
    margin-bottom: 1.25rem;
  }
  article.prose ul {
    color: #787874;
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  article.prose ul li {
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }
  article.prose strong {
    color: #1C1C1A;
    font-weight: 600;
  }
  article.prose a {
    color: #C4A472;
    text-decoration: underline;
  }
  article.prose blockquote {
    border-left: 3px solid #C4A472;
    padding-left: 1.25rem;
    font-style: italic;
    color: #787874;
    margin: 1.5rem 0;
  }
</style>
