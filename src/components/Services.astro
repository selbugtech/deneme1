---
const services = [
  {
    title: 'Anahtar Teslim Ev Yenileme',
    description: 'Tasarımdan uygulamaya tüm süreci biz yönetiyoruz. Siz anahtarı teslim alırken eviniz hazır.',
    icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>`,
  },
  {
    title: 'Villa Yenileme',
    description: 'Villalarınızı lüks, konforlu ve kişisel tarzınızı yansıtan mekanlara dönüştürüyoruz.',
    icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`,
  },
  {
    title: 'Mağaza Yenileme',
    description: 'Markanızı güçlendiren, müşteri deneyimini artıran çarpıcı ticari mekanlar tasarlıyoruz.',
    icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>`,
  },
  {
    title: 'Ofis Yenileme',
    description: 'Ekibinizin verimliliğini ve motivasyonunu artıran modern, estetik çalışma ortamları.',
    icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  },
  {
    title: 'İç Mimarlık Danışmanlığı',
    description: 'Projeniz için profesyonel görüş, malzeme seçimi ve uygulama sürecinde uzman rehberlik.',
    icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>`,
  },
  {
    title: '3D Tasarım & Proje',
    description: 'Uygulamaya başlamadan önce mekanınızı gerçekçi 3D görseller ile deneyimleyin.',
    icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>`,
  },
];
---

<section id="hizmetler" class="py-24 bg-white">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Section header -->
    <div class="mb-16 reveal">
      <div class="flex items-center gap-3 mb-4">
        <span class="w-8 h-px bg-gold"></span>
        <span class="text-xs tracking-[0.3em] uppercase text-gold font-medium">Hizmetlerimiz</span>
      </div>
      <h2 class="font-display text-4xl md:text-5xl font-bold text-charcoal max-w-md leading-tight">
        Her Mekân İçin<br />Çözüm Üretiyoruz
      </h2>
    </div>

    <!-- Services grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-border">
      {services.map((s, i) => (
        <div
          class={`bg-white p-8 group hover:bg-warm-white transition-colors duration-300 reveal reveal-d${(i % 3) + 1}`}
        >
          <div class="text-gold mb-5 group-hover:scale-110 transition-transform duration-300 inline-block" set:html={s.icon} />
          <h3 class="font-display text-lg font-semibold text-charcoal mb-3">{s.title}</h3>
          <p class="text-muted text-sm leading-relaxed">{s.description}</p>
        </div>
      ))}
    </div>

  </div>
</section>
