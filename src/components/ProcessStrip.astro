---
interface Props {
  districtName?: string;
}

const { districtName } = Astro.props;

const steps = [
  {
    n: '01',
    title: 'Ücretsiz Keşif',
    desc: 'Mekanı yerinde inceler, ölçü alır ve ihtiyacınızı dinleriz.',
    icon: 'M9 12l2 2 4-4M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    n: '02',
    title: 'Tasarım & 3D',
    desc: 'Konseptten 3D görselleştirmeye kadar her detayı önceden görürsünüz.',
    icon: 'M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z',
  },
  {
    n: '03',
    title: 'Uygulama',
    desc: 'Yetkin ekibimizle tadilat ve montaj süreçlerini biz yönetiriz.',
    icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5M18.5 2.5a2.121 2.121 0 113 3L12 15l-4 1 1-4 9.5-9.5z',
  },
  {
    n: '04',
    title: 'Anahtar Teslim',
    desc: 'Final kontrol sonrası temizlenmiş ve kullanıma hazır şekilde teslim ederiz.',
    icon: 'M5 13l4 4L19 7',
  },
];
---

<section class="py-12 border-t border-border">
  <div class="flex items-center gap-3 mb-4">
    <span class="w-8 h-px bg-gold"></span>
    <span class="text-xs tracking-[0.3em] uppercase text-gold font-medium">Süreç</span>
  </div>
  <h2 class="font-display text-2xl md:text-3xl font-bold text-charcoal mb-3">
    {districtName ? `${districtName}'de` : 'Projenizde'} nasıl çalışıyoruz?
  </h2>
  <p class="text-muted leading-relaxed mb-8 max-w-2xl text-sm md:text-base">
    Her projede aynı şeffaf 4 adımlı süreci izliyoruz. {districtName ? `${districtName} ` : ''}projelerinde
    ortalama anahtar teslim süre <strong class="text-charcoal font-semibold">4–10 hafta</strong>; daire
    boyutu, malzeme tedariği ve uygulama kapsamına göre netleştiriyoruz.
  </p>

  <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
    {steps.map(s => (
      <div class="border border-border p-5 bg-white/40 hover:border-gold/40 transition-colors">
        <div class="flex items-center gap-3 mb-3">
          <span class="text-xs tracking-[0.25em] text-gold font-medium">{s.n}</span>
          <span class="w-6 h-px bg-gold/40"></span>
        </div>
        <div class="w-9 h-9 mb-3 bg-gold/10 flex items-center justify-center">
          <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={s.icon}/>
          </svg>
        </div>
        <h3 class="font-display text-base font-bold text-charcoal mb-1">{s.title}</h3>
        <p class="text-muted text-xs leading-relaxed">{s.desc}</p>
      </div>
    ))}
  </div>
</section>
