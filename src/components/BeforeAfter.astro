---
const comparisons = [
  {
    title: 'Beşiktaş Dairesi',
    category: 'Anahtar Teslim Ev Yenileme',
    // Fotoğraf gelince: before: '/images/besiktas-before.jpg', after: '/images/besiktas-after.jpg'
    beforeGradient: 'linear-gradient(145deg, #2A2318 0%, #3E3428 50%, #524639 100%)',
    afterGradient:  'linear-gradient(145deg, #5E3E22 0%, #9A6A40 50%, #C4A472 100%)',
  },
  {
    title: 'Zekeriyaköy Villa',
    category: 'Villa Yenileme',
    beforeGradient: 'linear-gradient(145deg, #1E2220 0%, #2E3530 50%, #3D4840 100%)',
    afterGradient:  'linear-gradient(145deg, #253530 0%, #3D5A4E 50%, #5E8070 100%)',
  },
  {
    title: 'Nişantaşı Butik',
    category: 'Mağaza Yenileme',
    beforeGradient: 'linear-gradient(145deg, #201C18 0%, #352E26 50%, #4A4035 100%)',
    afterGradient:  'linear-gradient(145deg, #3C2E1A 0%, #6B4E2A 50%, #9A7245 100%)',
  },
];
---

<section class="py-24 bg-[#111110]">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Section header -->
    <div class="mb-12 reveal">
      <div class="flex items-center gap-3 mb-4">
        <span class="w-8 h-px bg-gold"></span>
        <span class="text-xs tracking-[0.3em] uppercase text-gold font-medium">Dönüşüm</span>
      </div>
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
        <h2 class="font-display text-4xl md:text-5xl font-bold text-white max-w-sm leading-tight">
          Dönüşümü<br />Görün
        </h2>
        <p class="text-white/45 max-w-xs leading-relaxed text-sm">
          Çubuğu sürükleyerek projelerin başlangıç ve bitiş hallerini karşılaştırın.
        </p>
      </div>
    </div>

    <!-- Project tabs -->
    <div class="flex gap-2 mb-6 reveal" id="ba-tabs">
      {comparisons.map((c, i) => (
        <button
          class="ba-tab px-4 py-2 text-xs tracking-wide border transition-colors duration-200"
          data-index={i}
          style={i === 0
            ? 'border-color: #C4A472; color: #C4A472; background: rgba(196,164,114,0.08);'
            : 'border-color: rgba(255,255,255,0.15); color: rgba(255,255,255,0.4);'}
        >
          {c.title}
        </button>
      ))}
    </div>

    <!-- Before/After slider -->
    <div class="reveal">
      {comparisons.map((c, i) => (
        <div
          class="ba-panel"
          data-index={i}
          style={i === 0 ? 'display:block;' : 'display:none;'}
        >
          <!-- Slider container -->
          <div
            class="ba-container relative overflow-hidden select-none cursor-ew-resize"
            style="height: clamp(260px, 50vw, 520px);"
          >
            <!-- After image (behind) -->
            <div
              class="ba-after absolute inset-0 w-full h-full"
              style={`background: ${c.afterGradient};`}
            >
              <!-- After placeholder label -->
              <div class="absolute bottom-5 right-6 text-right">
                <span class="text-white/20 text-[9px] tracking-[0.35em] uppercase block">[ {c.category} Sonrası ]</span>
              </div>
            </div>

            <!-- Before image (clipped on top) -->
            <div
              class="ba-before absolute inset-0 w-full h-full"
              style={`background: ${c.beforeGradient}; clip-path: inset(0 50% 0 0);`}
            >
              <!-- Before placeholder label -->
              <div class="absolute bottom-5 left-6">
                <span class="text-white/20 text-[9px] tracking-[0.35em] uppercase block">[ {c.category} Öncesi ]</span>
              </div>
            </div>

            <!-- Labels -->
            <div class="absolute top-5 left-5 z-10 pointer-events-none">
              <span class="inline-flex items-center gap-1.5 bg-black/50 backdrop-blur-sm text-white/80 text-[10px] tracking-[0.2em] uppercase px-3 py-1.5">
                <svg class="w-3 h-3 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
                Öncesi
              </span>
            </div>
            <div class="absolute top-5 right-5 z-10 pointer-events-none">
              <span class="inline-flex items-center gap-1.5 bg-gold/80 backdrop-blur-sm text-charcoal text-[10px] tracking-[0.2em] uppercase px-3 py-1.5 font-semibold">
                Sonrası
                <svg class="w-3 h-3 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </span>
            </div>

            <!-- Divider handle -->
            <div
              class="ba-handle absolute top-0 bottom-0 z-20 pointer-events-none"
              style="left: 50%; transform: translateX(-50%);"
            >
              <!-- Line -->
              <div class="absolute inset-y-0 left-1/2 -translate-x-1/2 w-0.5 bg-white/80"></div>
              <!-- Circle -->
              <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white shadow-xl flex items-center justify-center">
                <svg class="w-5 h-5 text-charcoal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8 9l-4 3 4 3M16 9l4 3-4 3"/>
                </svg>
              </div>
            </div>

          </div>

          <!-- Project info below -->
          <div class="flex items-center justify-between mt-4 px-1">
            <div>
              <p class="text-[10px] tracking-[0.25em] uppercase text-gold">{c.category}</p>
              <p class="font-display text-white font-semibold mt-0.5">{c.title}</p>
            </div>
            <a
              href="https://wa.me/905330391565?text=Merhaba%2C%20projeniz%20hakk%C4%B1nda%20bilgi%20almak%20istiyorum."
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs tracking-wide text-white/40 hover:text-gold transition-colors flex items-center gap-1.5"
            >
              Benzer Proje İçin Yazın
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  // Tab switching
  const tabs = document.querySelectorAll<HTMLElement>('.ba-tab');
  const panels = document.querySelectorAll<HTMLElement>('.ba-panel');

  tabs.forEach((tab, i) => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => {
        t.style.borderColor = 'rgba(255,255,255,0.15)';
        t.style.color = 'rgba(255,255,255,0.4)';
        t.style.background = '';
      });
      tab.style.borderColor = '#C4A472';
      tab.style.color = '#C4A472';
      tab.style.background = 'rgba(196,164,114,0.08)';

      panels.forEach(p => { p.style.display = 'none'; });
      panels[i].style.display = 'block';

      // Re-initialize the slider for the shown panel
      initSlider(panels[i].querySelector<HTMLElement>('.ba-container')!);
    });
  });

  function initSlider(container: HTMLElement) {
    if (!container) return;
    const before = container.querySelector<HTMLElement>('.ba-before')!;
    const handle = container.querySelector<HTMLElement>('.ba-handle')!;
    let dragging = false;

    function setPos(clientX: number) {
      const rect = container.getBoundingClientRect();
      let pct = (clientX - rect.left) / rect.width;
      pct = Math.max(0.03, Math.min(0.97, pct));
      const pctStr = (pct * 100).toFixed(2) + '%';
      before.style.clipPath = `inset(0 ${(100 - pct * 100).toFixed(2)}% 0 0)`;
      handle.style.left = pctStr;
    }

    // Mouse events
    container.addEventListener('mousedown', (e) => {
      dragging = true;
      setPos(e.clientX);
    });
    window.addEventListener('mousemove', (e) => {
      if (dragging) setPos(e.clientX);
    });
    window.addEventListener('mouseup', () => { dragging = false; });

    // Touch events
    container.addEventListener('touchstart', (e) => {
      dragging = true;
      setPos(e.touches[0].clientX);
    }, { passive: true });
    window.addEventListener('touchmove', (e) => {
      if (dragging) setPos(e.touches[0].clientX);
    }, { passive: true });
    window.addEventListener('touchend', () => { dragging = false; });
  }

  // Initialize all visible containers
  document.querySelectorAll<HTMLElement>('.ba-container').forEach(initSlider);
</script>
