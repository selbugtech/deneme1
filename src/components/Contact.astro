---
const wa = 'https://wa.me/905330391565?text=Merhaba%2C%20i%C3%A7%20mimarl%C4%B1k%20hizmeti%20hakk%C4%B1nda%20bilgi%20almak%20istiyorum.';
const tel = 'tel:+905330391565';
---

<section id="iletisim" class="py-24 bg-[#F5EFE6]">
  <div class="max-w-6xl mx-auto px-6">

    <div class="grid lg:grid-cols-2 gap-16 items-start">

      <!-- Left: Text -->
      <div>
        <div class="flex items-center gap-3 mb-5 reveal">
          <span class="w-8 h-px bg-gold"></span>
          <span class="text-xs tracking-[0.3em] uppercase text-gold font-medium">İletişim</span>
        </div>

        <h2 class="font-display text-4xl md:text-5xl font-bold text-charcoal leading-tight mb-6 reveal reveal-d1">
          Projenizi<br />Konuşalım
        </h2>

        <p class="text-muted leading-relaxed mb-10 max-w-sm reveal reveal-d2">
          Yeni bir mekân hayaliniz mi var? Ücretsiz keşif ve fiyat teklifi için
          WhatsApp'tan yazın ya da telefon edin — size en kısa sürede dönüyoruz.
        </p>

        <!-- Contact details -->
        <div class="space-y-6 reveal reveal-d3">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 border border-border flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs tracking-[0.2em] uppercase text-muted mb-1">Telefon / WhatsApp</p>
              <a href={tel} class="text-charcoal font-semibold text-lg hover:text-gold transition-colors">0533 039 15 65</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 border border-border flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs tracking-[0.2em] uppercase text-muted mb-1">Hizmet Bölgesi</p>
              <p class="text-charcoal font-semibold">İstanbul &amp; Çevre İller</p>
              <p class="text-muted text-sm mt-0.5">Büyük projelerde tüm Türkiye</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 border border-border flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs tracking-[0.2em] uppercase text-muted mb-1">Çalışma Saatleri</p>
              <p class="text-charcoal font-semibold">Hft. içi 09:00 – 19:00</p>
              <p class="text-muted text-sm mt-0.5">Cumartesi 10:00 – 17:00</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: CTA cards -->
      <div class="flex flex-col gap-4 reveal reveal-d2">

        <!-- WhatsApp card -->
        <a
          href={wa}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-6 bg-[#F0FAF3] border border-[#C3E6CB] p-6 hover:bg-[#25D366] transition-colors duration-300"
        >
          <div class="w-14 h-14 bg-[#25D366] group-hover:bg-white/20 flex items-center justify-center shrink-0 transition-colors duration-300">
            <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>
          <div>
            <p class="font-semibold text-charcoal group-hover:text-white transition-colors duration-300">WhatsApp'tan Yaz</p>
            <p class="text-sm text-muted group-hover:text-white/80 transition-colors duration-300 mt-0.5">Hızlı yanıt için mesaj gönderin</p>
          </div>
          <svg class="w-5 h-5 text-muted group-hover:text-white ml-auto transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>

        <!-- Phone card -->
        <a
          href={tel}
          class="group flex items-center gap-6 bg-warm-white border border-border p-6 hover:bg-charcoal transition-colors duration-300"
        >
          <div class="w-14 h-14 bg-charcoal group-hover:bg-white/10 flex items-center justify-center shrink-0 transition-colors duration-300">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z"/>
            </svg>
          </div>
          <div>
            <p class="font-semibold text-charcoal group-hover:text-white transition-colors duration-300">0533 039 15 65</p>
            <p class="text-sm text-muted group-hover:text-white/70 transition-colors duration-300 mt-0.5">Hemen arayın, danışın</p>
          </div>
          <svg class="w-5 h-5 text-muted group-hover:text-white ml-auto transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>

        <!-- Note -->
        <p class="text-xs text-muted text-center pt-2 tracking-wide">
          Ücretsiz keşif &amp; fiyat teklifi · Hızlı geri dönüş
        </p>
      </div>

    </div>
  </div>
</section>
