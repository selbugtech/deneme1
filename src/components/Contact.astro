---
import GoogleRatingCard from './GoogleRatingCard.astro';
import { WHATSAPP_URL_WITH_MESSAGE, TEL_URL } from '../config';

interface Props {
  rating?: number;
  totalRatings?: number;
}

const { rating = 0, totalRatings = 0 } = Astro.props;

const wa = WHATSAPP_URL_WITH_MESSAGE;
const tel = TEL_URL;
---

<section id="iletisim" class="py-24 bg-[#F5EFE6]">
  <div class="max-w-6xl mx-auto px-6">

    {rating > 0 && (
      <div class="mb-12 reveal">
        <GoogleRatingCard rating={rating} totalRatings={totalRatings} />
      </div>
    )}

    <div class="grid lg:grid-cols-2 gap-16 items-start">

      <!-- Left: Text -->
      <div>
        <div class="flex items-center gap-3 mb-5 reveal">
          <span class="w-8 h-px bg-gold"></span>
          <span class="text-xs tracking-[0.3em] uppercase text-gold font-medium">İletişim</span>
        </div>

        <h2 class="font-display text-4xl md:text-5xl font-bold text-charcoal leading-tight mb-6 reveal reveal-d1">
          Projenizi<br />Konuşalım
        </h2>

        <p class="text-muted leading-relaxed mb-10 max-w-sm reveal reveal-d2">
          Yeni bir mekân hayaliniz mi var? <strong class="font-semibold text-charcoal">Ücretsiz keşif ve fiyat teklifi</strong> için
          WhatsApp'tan yazın ya da telefon edin — size en kısa sürede dönüyoruz.
        </p>

        <!-- Contact details -->
        <div class="space-y-6 reveal reveal-d3">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 border border-border flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs tracking-[0.2em] uppercase text-muted mb-1">Telefon / WhatsApp</p>
              <a href={tel} class="text-charcoal font-semibold text-lg hover:text-gold transition-colors">0533 039 15 65</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 border border-border flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs tracking-[0.2em] uppercase text-muted mb-1">Adres</p>
              <p class="text-charcoal font-semibold">Akasya A Kule, No: 25/A</p>
              <p class="text-muted text-sm mt-0.5">Çeçen Sok., Acıbadem, 34660 Üsküdar / İstanbul</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 border border-border flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs tracking-[0.2em] uppercase text-muted mb-1">Çalışma Saatleri</p>
              <p class="text-charcoal font-semibold">Hft. içi 09:00 – 19:00</p>
              <p class="text-muted text-sm mt-0.5">Cumartesi 10:00 – 17:00</p>
            </div>
          </div>
        </div>

        <!-- Social media icons -->
        <div class="mt-8 pt-6 border-t border-border">
          <p class="text-xs tracking-[0.2em] uppercase text-muted mb-4">Bizi Takip Edin</p>
          <div class="flex items-center gap-4">
            <a href="https://www.facebook.com/master.mmrlk" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="text-muted hover:text-gold transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M24 12.073C24 5.406 18.627 0 12 0S0 5.406 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047v-2.66c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.235 2.686.235v2.97h-1.513c-1.491 0-1.956.93-1.956 1.883v2.269h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
              </svg>
            </a>
            <a href="https://x.com/mastericmimar" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)" class="text-muted hover:text-gold transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
            <a href="https://www.instagram.com/mastericmimarlik/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-muted hover:text-gold transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
            </a>
            <a href="https://tr.pinterest.com/mastericmimarlik/" target="_blank" rel="noopener noreferrer" aria-label="Pinterest" class="text-muted hover:text-gold transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 0C5.373 0 0 5.372 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/>
              </svg>
            </a>
            <a href="https://www.youtube.com/channel/UC1vs1O0VUe_VNZIpo8B1KzA" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="text-muted hover:text-gold transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
            </a>
            <a href="mailto:mastericmimarlik@gmail.com" aria-label="E-posta" class="text-muted hover:text-gold transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Right: Map + CTA cards -->
      <div class="flex flex-col gap-4 reveal reveal-d2">

        <!-- Google Maps iframe -->
        <div class="overflow-hidden border border-border">
          <iframe
            src="https://maps.google.com/maps?q=41.001739,29.0543556&hl=tr&z=16&output=embed"
            width="100%"
            height="220"
            style="border:0; display:block;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Master İç Mimarlık Konum"
          ></iframe>
        </div>

        <!-- WhatsApp card -->
        <a
          href={wa}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-6 bg-[#F0FAF3] border border-[#C3E6CB] p-6 hover:bg-[#25D366] transition-colors duration-300"
        >
          <div class="w-14 h-14 bg-[#25D366] group-hover:bg-white/20 flex items-center justify-center shrink-0 transition-colors duration-300">
            <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>
          <div>
            <p class="font-semibold text-charcoal group-hover:text-white transition-colors duration-300">WhatsApp'tan Yaz</p>
            <p class="text-sm text-muted group-hover:text-white/80 transition-colors duration-300 mt-0.5">Hızlı yanıt için mesaj gönderin</p>
          </div>
          <svg class="w-5 h-5 text-muted group-hover:text-white ml-auto transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>

        <!-- Phone card -->
        <a
          href={tel}
          class="group flex items-center gap-6 bg-warm-white border border-border p-6 hover:bg-charcoal transition-colors duration-300"
        >
          <div class="w-14 h-14 bg-charcoal group-hover:bg-white/10 flex items-center justify-center shrink-0 transition-colors duration-300">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z"/>
            </svg>
          </div>
          <div>
            <p class="font-semibold text-charcoal group-hover:text-white transition-colors duration-300">0533 039 15 65</p>
            <p class="text-sm text-muted group-hover:text-white/70 transition-colors duration-300 mt-0.5">Ücretsiz keşif için hemen arayın</p>
          </div>
          <svg class="w-5 h-5 text-muted group-hover:text-white ml-auto transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>

        <!-- Email card -->
        <a
          href="mailto:mastericmimarlik@gmail.com"
          class="group flex items-center gap-6 bg-warm-white border border-border p-6 hover:bg-gold transition-colors duration-300"
        >
          <div class="w-14 h-14 bg-charcoal group-hover:bg-white/20 flex items-center justify-center shrink-0 transition-colors duration-300">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
            </svg>
          </div>
          <div>
            <p class="font-semibold text-charcoal group-hover:text-white transition-colors duration-300">E-posta Gönderin</p>
            <p class="text-sm text-muted group-hover:text-white/80 transition-colors duration-300 mt-0.5">mastericmimarlik@gmail.com</p>
          </div>
          <svg class="w-5 h-5 text-muted group-hover:text-white ml-auto transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>

        <!-- Note -->
        <p class="text-xs text-muted text-center pt-2 tracking-wide">
          Ücretsiz keşif &amp; fiyat teklifi · Hızlı geri dönüş
        </p>
      </div>

    </div>
  </div>
</section>
