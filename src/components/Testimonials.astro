---
// Google Maps yorumları — güncelleme için bu diziyi düzenleyin
// Gelecekte Google Places API'ye geçilirse buraya API verisi gelebilir
const reviews = [
  {
    name: 'Ayşe K.',
    location: 'Kadıköy',
    rating: 5,
    text: 'Dairemizin tüm yenileme sürecini Master İç Mimarlık yönetti. Hem tasarım hem de uygulama aşamasında son derece profesyoneldiler. Hayal ettiğimizden daha güzel bir ev çıktı ortaya.',
    project: 'Anahtar Teslim Ev Yenileme',
  },
  {
    name: 'Murat B.',
    location: 'Zekeriyaköy',
    rating: 5,
    text: 'Villayı yeniletirken 3D görselleştirme sayesinde her şeyi önceden gördük. Süreç tam vaat edildiği gibi ilerledi, teslimatta sürprizle karşılaşmadık. Kesinlikle tavsiye ederim.',
    project: 'Villa Yenileme',
  },
  {
    name: 'Serra D.',
    location: 'Levent',
    rating: 5,
    text: 'Ofisimizi kısa sürede ve bütçemize uygun teslim aldık. Hem çalışanlar hem müşteriler ofisimizin değişiminden çok etkilendi. Çok memnun kaldık, teşekkürler.',
    project: 'Ofis Yenileme',
  },
];
---

<section class="py-24 bg-warm-white">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Section header -->
    <div class="mb-14 reveal">
      <div class="flex items-center gap-3 mb-4">
        <span class="w-8 h-px bg-gold"></span>
        <span class="text-xs tracking-[0.3em] uppercase text-gold font-medium">Müşteri Yorumları</span>
      </div>
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
        <h2 class="font-display text-4xl md:text-5xl font-bold text-charcoal max-w-sm leading-tight">
          Müşterilerimiz<br />Ne Diyor?
        </h2>
        <!-- Google rating badge -->
        <div class="flex items-center gap-3 bg-white border border-border rounded-lg px-4 py-3 self-start md:self-auto shadow-sm">
          <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          <div>
            <div class="flex items-center gap-1">
              {[1,2,3,4,5].map(() => (
                <svg class="w-3.5 h-3.5 text-[#FBBC05]" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
              <span class="text-charcoal font-semibold text-sm ml-1">5.0</span>
            </div>
            <p class="text-muted text-[10px] tracking-wide mt-0.5">Google Yorumları</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Review cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {reviews.map((r, i) => (
        <div class={`bg-white border border-border p-7 flex flex-col reveal reveal-d${i + 1}`}>

          <!-- Stars -->
          <div class="flex gap-1 mb-5">
            {Array.from({ length: r.rating }).map(() => (
              <svg class="w-4 h-4 text-[#FBBC05]" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <!-- Quote mark -->
          <div class="text-gold/20 font-display text-6xl leading-none mb-2 -mt-2">"</div>

          <!-- Review text -->
          <p class="text-muted leading-relaxed text-sm flex-1 -mt-4">{r.text}</p>

          <!-- Divider -->
          <div class="w-8 h-px bg-border mt-6 mb-5"></div>

          <!-- Author -->
          <div class="flex items-center justify-between">
            <div>
              <p class="text-charcoal font-semibold text-sm">{r.name}</p>
              <p class="text-muted text-[11px] tracking-wide mt-0.5">{r.location}</p>
            </div>
            <span class="text-[10px] tracking-[0.2em] uppercase text-gold/70 text-right max-w-[100px] leading-tight">{r.project}</span>
          </div>

        </div>
      ))}
    </div>

    <!-- View on Google CTA -->
    <div class="mt-10 text-center reveal">
      <a
        href="https://www.google.com/maps/place/Master+%C4%B0%C3%A7+Mimarl%C4%B1k"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-muted hover:text-gold text-sm tracking-wide transition-colors duration-200"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        Google'da Tüm Yorumları Gör
        <svg class="w-3.5 h-3.5 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
        </svg>
      </a>
    </div>

  </div>
</section>
