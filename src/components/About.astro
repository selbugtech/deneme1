---
import { optimizedImage, optimizedImageW, srcsetImage } from '../lib/cloudinary';
import GoogleRatingCard from './GoogleRatingCard.astro';

interface Props {
  rating: number;
  totalRatings: number;
}

const { rating, totalRatings } = Astro.props;
---

<section id="hakkimizda" class="py-24 bg-[#EDE5D8]">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Left: Image placeholder -->
      <div class="relative reveal overflow-hidden">
        <img
          src={optimizedImageW('/images/salon5.jpeg', 800)}
          srcset={srcsetImage('/images/salon5.jpeg', [400, 600, 800, 1200])}
          sizes="(min-width: 1024px) 40vw, 100vw"
          alt="Master İç Mimarlık showroom"
          loading="lazy"
          decoding="async"
          class="aspect-[4/5] w-full object-cover object-center"
        />
        <!-- Decorative gold border -->
        <div class="absolute -bottom-4 -right-4 w-2/3 h-2/3 border border-gold opacity-40 pointer-events-none"></div>
      </div>

      <!-- Right: Content -->
      <div>
        <div class="flex items-center gap-3 mb-5 reveal">
          <span class="w-8 h-px bg-gold"></span>
          <span class="text-xs tracking-[0.3em] uppercase text-gold font-medium">Hakkımızda</span>
        </div>

        <h2 class="font-display text-4xl md:text-5xl font-bold text-charcoal leading-tight mb-6 reveal reveal-d1">
          Tasarım &amp;<br />Uygulamada<br />Güvenilir Adres
        </h2>

        <p class="text-muted leading-relaxed mb-5 reveal reveal-d2">
          Master İç Mimarlık olarak 8 yılı aşkın deneyimimizle İstanbul'da yüzlerce evi, villayı ve
          ticari mekanı yeniledik. Her projeye özgün bir bakış açısı, titiz bir işçilik ve
          müşteri memnuniyetini ön planda tutan bir anlayışla yaklaşıyoruz.
        </p>

        <p class="text-muted leading-relaxed mb-8 reveal reveal-d2">
          Tasarım sürecinden anahtar teslime kadar tüm aşamaları sizin adınıza yönetiyoruz.
          İstanbul'da ana hizmet bölgemiz olmakla birlikte, büyük projelerde çevre illere de gidiyoruz.
        </p>

        <div class="reveal reveal-d3">
          <GoogleRatingCard rating={rating} totalRatings={totalRatings} />
        </div>
      </div>

    </div>
  </div>
</section>
