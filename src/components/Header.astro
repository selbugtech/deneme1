---
const { pathname } = Astro.url;
const isHome = pathname === '/deneme1/' || pathname === '/deneme1';
const hizmetlerHref = isHome ? '#hizmetler' : '/deneme1/hizmetler';
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 py-6 transition-all duration-300">
  <div class="max-w-6xl mx-auto px-6 flex items-center justify-between">

    <!-- Logo -->
    <a href="/deneme1/" class="flex items-center gap-3 group">
      <img src="/deneme1/favicon.png" alt="Master İç Mimarlık" class="w-10 h-10 shrink-0 object-contain" />
      <div class="leading-none">
        <span class="block font-display font-semibold text-[19px] tracking-wide text-white">Master</span>
        <span class="block text-[10px] tracking-[0.25em] uppercase mt-0.5 text-white/55">İç Mimarlık</span>
      </div>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8">
      <a href={hizmetlerHref} class="nav-link text-[15px] tracking-wide text-white/80 hover:text-gold transition-colors duration-200">Hizmetler</a>
      <a href="/deneme1/#hakkimizda" class="nav-link text-[15px] tracking-wide text-white/80 hover:text-gold transition-colors duration-200">Hakkımızda</a>
      <a href="/deneme1/projeler" class="nav-link text-[15px] tracking-wide text-white/80 hover:text-gold transition-colors duration-200">Projeler</a>
      <a href="/deneme1/blog" class="nav-link text-[15px] tracking-wide text-white/80 hover:text-gold transition-colors duration-200">Blog</a>
      <a
        href="https://wa.me/905330391565?text=Merhaba%2C%20bilgi%20almak%20istiyorum."
        target="_blank"
        rel="noopener noreferrer"
        class="text-[15px] tracking-wide border border-white/30 text-white px-6 py-2.5 hover:bg-gold hover:border-gold transition-colors duration-200"
      >
        İletişim
      </a>
    </nav>

    <!-- Mobile Menu Button -->
    <button id="mobile-menu-btn" class="md:hidden p-2 flex flex-col gap-1.5" aria-label="Menü aç">
      <span class="block w-6 h-px bg-white transition-all duration-300" id="ml1"></span>
      <span class="block w-6 h-px bg-white transition-all duration-300" id="ml2"></span>
      <span class="block w-4 h-px bg-white transition-all duration-300" id="ml3"></span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-white/10 mt-3" style="background: rgba(20,20,18,0.97);">
    <nav class="max-w-6xl mx-auto px-6 py-6 flex flex-col gap-5">
      <a href={hizmetlerHref} class="text-[15px] tracking-wide text-white/70 hover:text-gold transition-colors mobile-link">Hizmetler</a>
      <a href="/deneme1/#hakkimizda" class="text-[15px] tracking-wide text-white/70 hover:text-gold transition-colors mobile-link">Hakkımızda</a>
      <a href="/deneme1/projeler" class="text-[15px] tracking-wide text-white/70 hover:text-gold transition-colors mobile-link">Projeler</a>
      <a href="/deneme1/blog" class="text-[15px] tracking-wide text-white/70 hover:text-gold transition-colors mobile-link">Blog</a>
      <a href="/deneme1/sikca-sorulan-sorular" class="text-[15px] tracking-wide text-white/70 hover:text-gold transition-colors mobile-link">SSS</a>
      <div class="flex gap-3 pt-2">
        <a
          href="https://wa.me/905330391565?text=Merhaba%2C%20bilgi%20almak%20istiyorum."
          target="_blank"
          class="flex-1 text-sm bg-[#25D366] text-white text-center py-3 tracking-wide font-medium"
        >
          WhatsApp
        </a>
        <a
          href="tel:+905330391565"
          class="flex-1 text-sm bg-white/10 border border-white/20 text-white text-center py-3 tracking-wide font-medium"
        >
          Ara
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('site-header')!;
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  window.addEventListener('scroll', () => {
    header.classList.toggle('is-scrolled', window.scrollY > 60);
  }, { passive: true });

  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));

  document.querySelectorAll('.mobile-link').forEach((link) => {
    link.addEventListener('click', () => menu?.classList.add('hidden'));
  });
</script>

<style>
  #site-header {
    background: rgba(20, 20, 18, 0.60);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    transform: translateY(0);
    transition: transform 0.35s ease, background 0.3s ease, padding 0.2s ease;
  }

  #site-header.is-scrolled {
    background: rgba(20, 20, 18, 0.92);
    box-shadow: 0 1px 24px rgba(0, 0, 0, 0.35);
    padding-top: 0.75rem;
    padding-bottom: 0.75rem;
  }

</style>
