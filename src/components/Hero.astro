---
const wa = 'https://wa.me/905330391565?text=Merhaba%2C%20i%C3%A7%20mimarl%C4%B1k%20hizmeti%20hakk%C4%B1nda%20bilgi%20almak%20istiyorum.';
const tel = 'tel:+905330391565';

const slides = [
  {
    // Warm gold/walnut — living room
    bg: 'linear-gradient(135deg, #2C2010 0%, #4A3320 40%, #8B6540 70%, #C4A472 100%)',
    label: 'Salon & Oturma Odası',
  },
  {
    // Deep slate/sage — modern spaces
    bg: 'linear-gradient(135deg, #141C1A 0%, #253028 40%, #3D5248 75%, #5E7A6A 100%)',
    label: 'Mutfak & Ofis',
  },
  {
    // Rich mocha/copper — villa & boutique
    bg: 'linear-gradient(135deg, #180E08 0%, #2E1C0E 40%, #5C3820 70%, #9A6235 100%)',
    label: 'Villa & Mağaza',
  },
];
---

<section id="hero" class="relative min-h-screen flex items-center overflow-hidden">

  <!-- Background slides -->
  <div class="absolute inset-0 z-0" aria-hidden="true">
    {slides.map((slide, i) => (
      <div
        class="hero-slide absolute inset-0"
        data-index={i}
        style={`background: ${slide.bg}; opacity: ${i === 0 ? 1 : 0}; transition: opacity 1s ease;`}
      >
        <!-- Placeholder watermark — replace src with real image when ready -->
        <div class="absolute bottom-5 right-6 opacity-[0.07]">
          <span class="text-white text-[9px] tracking-[0.35em] uppercase">[{slide.label} Fotoğrafı]</span>
        </div>
      </div>
    ))}
    <!-- Readability overlay -->
    <div class="absolute inset-0 bg-charcoal/58"></div>
    <!-- Bottom gradient fade -->
    <div class="absolute bottom-0 left-0 right-0 h-28 bg-gradient-to-t from-charcoal/35 to-transparent"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 w-full max-w-6xl mx-auto px-6 pt-32 pb-24">
    <div class="max-w-xl">

      <!-- Eyebrow label -->
      <div class="flex items-center gap-3 mb-7 reveal">
        <span class="w-8 h-px bg-gold"></span>
        <span class="text-xs tracking-[0.3em] uppercase text-gold font-medium">İstanbul · İç Mimarlık</span>
      </div>

      <!-- Heading -->
      <h1 class="font-display text-5xl md:text-6xl lg:text-[4rem] xl:text-[4.5rem] font-bold leading-[1.08] text-white mb-6 reveal reveal-d1">
        Mekanınızı<br />
        <em class="not-italic text-gold">Hayalinize</em><br />
        Dönüştürüyoruz
      </h1>

      <!-- Description -->
      <p class="text-white/70 text-lg leading-relaxed mb-10 max-w-sm reveal reveal-d2">
        Anahtar teslim ev yenileme, villa tasarımı ve ticari mekan dönüşümlerinde
        İstanbul'un güvenilir iç mimarlık firması.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 mb-12 reveal reveal-d3">
        <a
          href={wa}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-3 bg-[#25D366] text-white px-8 py-4 text-sm font-semibold tracking-wide hover:bg-[#1EBD5A] transition-colors duration-200 shadow-lg shadow-green-900/40"
        >
          <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp'tan Yaz
        </a>
        <a
          href={tel}
          class="inline-flex items-center justify-center gap-3 bg-white/10 backdrop-blur-sm border border-white/25 text-white px-8 py-4 text-sm font-semibold tracking-wide hover:bg-white/20 transition-colors duration-200"
        >
          <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z"/>
          </svg>
          Hemen Ara
        </a>
      </div>

      <!-- Info strip -->
      <div class="flex flex-wrap items-center gap-6 pt-8 border-t border-white/15 reveal reveal-d4">
        <div>
          <p class="text-[10px] tracking-[0.25em] uppercase text-white/45 mb-1">Telefon / WhatsApp</p>
          <a href={tel} class="text-white font-semibold hover:text-gold transition-colors">0533 039 15 65</a>
        </div>
        <div class="w-px h-8 bg-white/15"></div>
        <div>
          <p class="text-[10px] tracking-[0.25em] uppercase text-white/45 mb-1">Hizmet Bölgesi</p>
          <p class="text-white font-semibold">İstanbul &amp; Çevre İller</p>
        </div>
        <div class="w-px h-8 bg-white/15 hidden sm:block"></div>
        <div class="hidden sm:block">
          <p class="text-[10px] tracking-[0.25em] uppercase text-white/45 mb-1">Ücretsiz Keşif</p>
          <p class="text-white font-semibold">Randevu Alın</p>
        </div>
      </div>

    </div>
  </div>

  <!-- Slide navigation dots -->
  <div class="absolute bottom-20 left-1/2 -translate-x-1/2 flex gap-2.5 z-10" aria-hidden="true">
    {slides.map((_, i) => (
      <button
        class="hero-dot rounded-full transition-all duration-500"
        data-index={i}
        style={i === 0 ? 'width:28px; height:3px; background:#C4A472;' : 'width:10px; height:3px; background:rgba(255,255,255,0.35);'}
        aria-label={`Slayt ${i + 1}`}
      />
    ))}
  </div>

  <!-- Scroll hint -->
  <div class="absolute bottom-7 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 z-10">
    <span class="text-[10px] tracking-[0.3em] uppercase text-white/35">Keşfet</span>
    <svg class="w-4 h-4 text-white/35 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>

</section>

<script>
  const slides = document.querySelectorAll<HTMLElement>('.hero-slide');
  const dots = document.querySelectorAll<HTMLElement>('.hero-dot');
  let current = 0;
  let paused = false;
  let timer: ReturnType<typeof setInterval>;

  function goTo(index: number) {
    slides[current].style.opacity = '0';
    dots[current].style.width = '10px';
    dots[current].style.background = 'rgba(255,255,255,0.35)';

    current = index;

    slides[current].style.opacity = '1';
    dots[current].style.width = '28px';
    dots[current].style.background = '#C4A472';
  }

  function resetTimer() {
    clearInterval(timer);
    timer = setInterval(() => { if (!paused) goTo((current + 1) % slides.length); }, 5000);
  }

  resetTimer();

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => { goTo(i); resetTimer(); });
  });

  const hero = document.getElementById('hero');
  hero?.addEventListener('mouseenter', () => { paused = true; });
  hero?.addEventListener('mouseleave', () => { paused = false; });
</script>
