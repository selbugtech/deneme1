---
import { optimizedImage } from '../lib/cloudinary';

const allProjects = [
  { slug: 'beyoglu-galata', title: 'Beyoğlu Galata', category: 'Anahtar Teslim Ev Yenileme', size: 'large', image: optimizedImage('/images/beyoglu galata/aakapak.jpg') },
  { slug: 'beykoz-pasabahce', title: 'Beykoz Paşabahçe', category: 'Villa Yenileme', size: 'small', image: optimizedImage('/images/beykoz pasabahce/aakapak.HEIC') },
  { slug: 'caddebostan', title: 'Caddebostan', category: 'Anahtar Teslim Ev Yenileme', size: 'small', image: optimizedImage('/images/caddebostan/aakapak.jpg') },
  { slug: 'mecidiyekoy', title: 'Mecidiyeköy', category: 'Anahtar Teslim Ev Yenileme', size: 'small', image: optimizedImage('/images/mecidiyeköy/aakapak.HEIC') },
  { slug: 'artas-ofis', title: 'Artas Ofis', category: 'Ofis Yenileme', size: 'small', image: optimizedImage('/images/artasOfis/aakapak.HEIC') },
  { slug: 'artas-ofis-2', title: 'Artas Ofis II', category: 'Ofis Yenileme', size: 'small', image: optimizedImage('/images/artasbaskaofis/aakapak.HEIC') },
  { slug: 'tepekent', title: 'Tepekent', category: 'Anahtar Teslim Ev Yenileme', size: 'large', image: optimizedImage('/images/tepekent/aakapak.HEIC') },
  { slug: 'kozyatagi-banyo', title: 'Kozyatağı Banyo', category: 'Kısmi Yenileme', size: 'small', image: optimizedImage('/images/kozyatağı banyo/aakapak.JPG') },
  { slug: 'zeytinburnu', title: 'Zeytinburnu', category: 'Anahtar Teslim Ev Yenileme', size: 'small', image: optimizedImage('/images/zeytinburnu/aakapak.jpg') },
];

// Ana sayfada yalnızca ilk 4 proje gösterilir
const projects = allProjects.slice(0, 4);
---

<section id="projeler" class="py-24 bg-charcoal">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Section header -->
    <div class="mb-14 reveal">
      <div class="flex items-center gap-3 mb-4">
        <span class="w-8 h-px bg-gold"></span>
        <span class="text-xs tracking-[0.3em] uppercase text-gold font-medium">Son Projelerimiz</span>
      </div>
      <h2 class="font-display text-4xl md:text-5xl font-bold text-white max-w-md leading-tight">
        Son Tamamlanan<br />Çalışmalarımız
      </h2>
    </div>

    <!-- Projects grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
      {projects.map((p, i) => (
        <a
          href={`/projeler/${p.slug}`}
          class={`relative group overflow-hidden reveal reveal-d${(i % 3) + 1} ${p.size === 'large' ? 'row-span-2' : ''}`}
        >
          <img
            src={p.image}
            alt={p.title}
            loading="lazy"
            decoding="async"
            class={`w-full object-cover object-center transition-transform duration-500 group-hover:scale-105 ${p.size === 'large' ? 'h-[400px] md:h-[480px]' : 'h-[190px] md:h-[230px]'}`}
          />

          <!-- Overlay on hover -->
          <div class="absolute inset-0 bg-charcoal/80 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col items-start justify-end p-5">
            <span class="text-[10px] tracking-[0.25em] uppercase text-gold mb-2">{p.category}</span>
            <h3 class="font-display text-white text-lg font-semibold">{p.title}</h3>
            <span class="mt-2 inline-flex items-center gap-1.5 text-white/60 text-xs">
              İncele
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </span>
          </div>

          <!-- Always-visible label (mobile) -->
          <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-charcoal/90 to-transparent p-4 md:hidden">
            <p class="text-[10px] tracking-widest uppercase text-gold">{p.category}</p>
            <p class="font-display text-white text-sm font-semibold">{p.title}</p>
          </div>
        </a>
      ))}
    </div>

    <!-- CTAs -->
    <div class="mt-12 flex flex-col sm:flex-row items-center justify-center gap-4 reveal">
      <a
        href="https://wa.me/905330391565?text=Merhaba%2C%20projeleriniz%20hakk%C4%B1nda%20bilgi%20almak%20istiyorum."
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 border border-gold text-gold px-8 py-4 text-sm tracking-wide hover:bg-gold hover:text-charcoal transition-colors duration-200"
      >
        Projenizi Konuşalım
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>

      <a
        href="/projeler"
        class="inline-flex items-center gap-2 text-white/55 hover:text-gold text-sm tracking-wide transition-colors duration-200"
      >
        Tüm Projeleri Gör
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>

  </div>
</section>
