---
import { projects as allProjects } from '../data/projects';

const projects = allProjects;

const leftProjects = projects.filter((_, i) => i % 2 === 0);
const rightProjects = projects.filter((_, i) => i % 2 === 1);
---

<section id="projeler" class="py-24 bg-charcoal">
  <div class="max-w-6xl mx-auto px-6">

    <div class="mb-14 reveal">
      <div class="flex items-center gap-3 mb-4">
        <span class="w-8 h-px bg-gold"></span>
        <span class="text-xs tracking-[0.3em] uppercase text-gold font-medium">Projelerimiz</span>
      </div>
      <h2 class="font-display text-4xl md:text-5xl font-bold text-white max-w-md leading-tight">
        Tamamlanan<br />Çalışmalarımız
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-8 md:gap-10">
      <div class="flex flex-col gap-10 md:gap-16">
        {leftProjects.map((p, i) => (
          <a
            href={`/projeler/${p.slug}`}
            class={`relative block group overflow-hidden reveal reveal-d${(i % 3) + 1}`}
          >
            <img
              src={p.heroImage}
              srcset={p.heroSrcset}
              sizes="(min-width:768px) 50vw, 100vw"
              alt={p.title}
              loading="lazy"
              decoding="async"
              class="w-full aspect-[5/3] object-cover transition-transform duration-500 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-r from-charcoal/70 via-charcoal/20 to-transparent pointer-events-none"></div>
            <div class="absolute top-6 left-6 right-6">
              <span class="text-[10px] tracking-[0.3em] uppercase text-gold font-medium">Projelerimiz</span>
              <h3 class="font-display text-2xl md:text-3xl font-bold text-white uppercase mt-2 leading-tight">{p.title}</h3>
              <span class="block w-12 h-px bg-gold mt-3"></span>
            </div>
          </a>
        ))}
      </div>

      <div class="flex flex-col gap-10 md:gap-16 md:mt-32">
        {rightProjects.map((p, i) => (
          <a
            href={`/projeler/${p.slug}`}
            class={`relative block group overflow-hidden reveal reveal-d${(i % 3) + 1}`}
          >
            <img
              src={p.heroImage}
              srcset={p.heroSrcset}
              sizes="(min-width:768px) 50vw, 100vw"
              alt={p.title}
              loading="lazy"
              decoding="async"
              class="w-full aspect-[5/3] object-cover transition-transform duration-500 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-r from-charcoal/70 via-charcoal/20 to-transparent pointer-events-none"></div>
            <div class="absolute top-6 left-6 right-6">
              <span class="text-[10px] tracking-[0.3em] uppercase text-gold font-medium">Projelerimiz</span>
              <h3 class="font-display text-2xl md:text-3xl font-bold text-white uppercase mt-2 leading-tight">{p.title}</h3>
              <span class="block w-12 h-px bg-gold mt-3"></span>
            </div>
          </a>
        ))}
      </div>
    </div>

    <div class="mt-16 flex flex-col sm:flex-row items-center justify-center gap-4 reveal">
      <a
        href="https://wa.me/905330391565?text=Merhaba%2C%20projeleriniz%20hakk%C4%B1nda%20bilgi%20almak%20istiyorum."
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 border border-gold text-gold px-8 py-4 text-sm tracking-wide hover:bg-gold hover:text-charcoal transition-colors duration-200"
      >
        Projenizi Konuşalım
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>

      <a
        href="/projeler"
        class="inline-flex items-center gap-2 text-white/55 hover:text-gold text-sm tracking-wide transition-colors duration-200"
      >
        Tüm Projeleri Gör
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>

  </div>
</section>
